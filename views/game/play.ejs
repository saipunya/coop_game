      { title: 'เอาใหม่นะ', message: 'คราวหน้ามีโอกาสทำได้ดีกว่านี้ สู้ ๆ' },
      { title: 'เกือบแล้ว', message: 'อย่าเพิ่งท้อ กลับมาเล่นใหม่แล้วลุยอีกครั้ง' }
    ];
    const timeoutFeedbackMessages = [
      { title: 'หมดเวลาแล้ว', message: 'ไม่เป็นไรนะ รอบหน้าลองตอบให้ไวขึ้นอีกนิด' },
      { title: 'เวลาไม่พอครับ', message: 'พักหายใจนิดหนึ่ง แล้วกลับมาสู้ใหม่ได้เลย' },
      { title: 'หมดเวลา', message: 'ไม่เป็นไรนะ รอบหน้าเอาใหม่' },
      { title: 'เวลาไม่พอ', message: 'ว้า เสียดายจังเลยเนาะ' },
      { title: 'หมดเวลาแล้ว', message: 'ไม่เป็นไรนะ รอบหน้าวางแผนให้ดีขึ้น' },
      { title: 'เวลาไม่พอครับ', message: 'เสียดายสุดๆ ใกล้มากแล้ว' },
      { title: 'หมดเวลา', message: 'ไม่เป็นไรนะ รอบหน้าเอาใหม่' },
      { title : 'เวลาไม่พอ', message: 'ถึงเวลาหมดแล้ว แต่อย่าพึ่งท้อ ลองใหม่อีกครั้ง' },
      { title: 'หมดเวลาแล้ว', message: 'เอาใหม่ ตอบให้ไวขึ้นอีกนิดนะ' },
      { title: 'เวลาไม่พอครับ', message: 'เสียดายสุดๆ ช้าไปนิดเดียวเอง' },
      
   
  
      
    ];

    const playerIntro = document.getElementById('playerIntro');
    const loadingPanel = document.getElementById('loading');
    const playerInfoForm = document.getElementById('playerInfoForm');
    const playerInfoMessage = document.getElementById('playerInfoMessage');
    const playerNameInput = document.getElementById('playerName');
    const phoneNumberInput = document.getElementById('phoneNumber');

    playerNameInput.value = initialPlayerName;
    phoneNumberInput.value = initialPhoneNumber;

    function replaceToGameEndUrl(url = gameEndRedirectUrl) {
      window.location.replace(url);
    }

    window.addEventListener('pageshow', (event) => {
      if (event.persisted && gameCompleted) {
        replaceToGameEndUrl();
      }
    });

    document.getElementById('finishResultLink')?.addEventListener('click', (event) => {
      event.preventDefault();
      gameCompleted = true;
      replaceToGameEndUrl(event.currentTarget.href);
    });

    document.getElementById('playAgainLink')?.addEventListener('click', (event) => {
      event.preventDefault();
      gameCompleted = true;
      replaceToGameEndUrl('/coopgame/game/start');
    });

    if (hasPlayerInfo) {
      if (isAdminPlay) {
        document.getElementById('gameArea').insertAdjacentHTML(
          'beforebegin',
          '<div class="panel-inner" style="padding-top:0"><div class="question-tag" style="margin-bottom:14px"><i class="bi bi-shield-check"></i> โหมดทดสอบผู้ดูแล: ไม่ต้องกรอกชื่อหรือเบอร์ และไม่ถูกนำไปจัดอันดับ</div></div>'
        );
      }
      showLoadingPanel();
      loadQuestion();
    } else {
      showPlayerIntro();
    }

    function showPlayerIntro(message = '') {
      if (isAdminPlay) {
        showLoadingPanel();
        loadQuestion();
        return;
      }
      playerIntro.classList.remove('hidden');
      loadingPanel.classList.add('hidden');
      document.getElementById('gameArea').classList.add('hidden');
      playerInfoMessage.textContent = message;
      setTimeout(() => playerNameInput.focus(), 50);
    }

    function showLoadingPanel() {
      playerIntro.classList.add('hidden');
      loadingPanel.classList.remove('hidden');
    }

    playerInfoForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const playerName = playerNameInput.value.trim();
      const phoneNumber = phoneNumberInput.value.replace(/[^\d]/g, '');
      const submitBtn = playerInfoForm.querySelector('button[type="submit"]');

      if (!playerName) {
        playerInfoMessage.textContent = 'กรุณากรอกชื่อผู้เล่น';
        return;
      }

      if (!/^\d{9,10}$/.test(phoneNumber)) {
        playerInfoMessage.textContent = 'กรุณากรอกเบอร์โทรศัพท์ 9-10 หลัก';
        return;
      }

      phoneNumberInput.value = phoneNumber;
      submitBtn.disabled = true;
      playerInfoMessage.textContent = 'กำลังบันทึกข้อมูลผู้เล่น...';

      try {
        const response = await fetch('/coopgame/game/api/player-info', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ attemptId, playerName, phoneNumber })
        });
        const result = await response.json();

        if (result.success) {
          hasPlayerInfo = true;
          playerInfoMessage.textContent = '';
          showLoadingPanel();
          loadQuestion();
        } else {
          const errorText = (result.errors && result.errors[0] && result.errors[0].msg)
            || result.message
            || 'ไม่สามารถบันทึกข้อมูลผู้เล่นได้';
          playerInfoMessage.textContent = errorText;
        }
      } catch (error) {
        console.error('Error saving player info:', error);
        playerInfoMessage.textContent = 'เกิดข้อผิดพลาด กรุณาลองใหม่';
      } finally {
        submitBtn.disabled = false;
      }
    });

    async function loadQuestion() {
      try {
        const response = await fetch(`/coopgame/game/api/question?attemptId=${attemptId}`);
        const result = await response.json();

        if (result.success && result.data && result.data.question) {
          displayQuestion(result.data.question);
        } else {
          if (result.errorCode === 'PLAYER_INFO_REQUIRED') {
            hasPlayerInfo = false;
            showPlayerIntro(result.message || 'กรุณากรอกชื่อและเบอร์โทรศัพท์ก่อนเริ่มเกม');
            return;
          }
          gameCompleted = true;
          replaceToGameEndUrl(`/coopgame/game/finish?attemptId=${attemptId}`);
        }
      } catch (error) {
        console.error('Error loading question:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
        replaceToGameEndUrl('/coopgame/game/start');
      }
    }

    function getDifficultyText(difficulty) {
      const texts = { easy: 'ง่าย', medium: 'ปานกลาง', hard: 'ยาก' };
      return texts[difficulty] || 'ระดับคำถาม';
    }

    function updateSharedStats() {
      const scoreEl = document.getElementById('score');
      const scoreSideEl = document.getElementById('scoreSide');
      const questionNumEl = document.getElementById('questionNum');
      const questionNumSideEl = document.getElementById('questionNumSide');
      const timerTextSideEl = document.getElementById('timerTextSide');

      if (scoreEl) scoreEl.textContent = score;
      if (scoreSideEl) scoreSideEl.textContent = score;
      if (questionNumEl && currentQuestion) questionNumEl.textContent = currentQuestion.questionNumber || 1;
      if (questionNumSideEl && currentQuestion) questionNumSideEl.textContent = currentQuestion.questionNumber || 1;
      if (timerTextSideEl) timerTextSideEl.textContent = timeLeft || 0;
    }

    function getRandomItem(items) {
      return items[Math.floor(Math.random() * items.length)];
    }

    function showAnswerFeedback(type, options = {}) {
      const duration = options.duration || 2100;
      const actionLabel = options.actionLabel || '';
      const feedback = document.getElementById('answerFeedback');
      const title = document.getElementById('answerFeedbackTitle');
      const message = document.getElementById('answerFeedbackMessage');
      const icon = document.getElementById('answerFeedbackIcon');
      const button = document.getElementById('answerFeedbackButton');
      const feedbackMap = {
        correct: {
          className: 'is-correct',
          iconClass: 'bi bi-check-lg',
          text: getRandomItem(correctFeedbackMessages)
        },
        wrong: {
          className: 'is-wrong',
          iconClass: 'bi bi-heartbreak-fill',
          text: getRandomItem(wrongFeedbackMessages)
        },
        timeout: {
          className: 'is-timeout',
          iconClass: 'bi bi-hourglass-split',
          text: getRandomItem(timeoutFeedbackMessages)
        }
      };
      const config = feedbackMap[type] || feedbackMap.wrong;

      feedback.className = `answer-feedback ${config.className}`;
      icon.className = config.iconClass;
      title.textContent = config.text.title;
      message.textContent = config.text.message;
      button.textContent = actionLabel || 'OK';
      button.classList.toggle('hidden', !actionLabel);
      button.onclick = null;

      return new Promise(resolve => {
        if (actionLabel) {
          button.onclick = () => {
            feedback.classList.add('hidden');
            button.classList.add('hidden');
            button.onclick = null;
            resolve();
          };
          setTimeout(() => button.focus(), 50);
          return;
        }

        window.setTimeout(() => {
          feedback.classList.add('hidden');
          resolve();
        }, duration);
      });
    }

    function isTopThreeRank(rankValue) {
      const rankNumber = Number(rankValue);
      return !isAdminPlay && Number.isInteger(rankNumber) && rankNumber >= 1 && rankNumber <= 3;
    }

    function showTopRankPopup(rankValue) {
      const rankNumber = Number(rankValue);
      const popup = document.getElementById('topRankPopup');
      const rankNumberEl = document.getElementById('topRankNumber');
      const messageEl = document.getElementById('topRankMessage');
      const okBtn = document.getElementById('topRankOkBtn');

      rankNumberEl.textContent = `#${rankNumber}`;
      messageEl.textContent = `ตอนนี้คุณมีคะแนนอยู่ในอันดับ ${rankNumber} ของกระดานผู้นำ เก่งมากครับ!`;
      popup.classList.remove('hidden');

      return new Promise(resolve => {
        okBtn.onclick = () => {
          popup.classList.add('hidden');
          okBtn.onclick = null;
          resolve();
        };
        setTimeout(() => okBtn.focus(), 50);
      });
    }

    function displayQuestion(question) {
      currentQuestion = question;
      isAnswering = false;

      document.getElementById('loading').classList.add('hidden');
      document.getElementById('gameArea').classList.remove('hidden');
      document.getElementById('resultArea').classList.add('hidden');

      document.getElementById('questionText').textContent = question.text;
      document.getElementById('textA').textContent = question.options.A;
      document.getElementById('textB').textContent = question.options.B;
      document.getElementById('textC').textContent = question.options.C;
      document.getElementById('textD').textContent = question.options.D;
      document.getElementById('progressCurrent').textContent = question.questionNumber;
      document.getElementById('progressTotal').textContent = question.totalQuestions || '-';

      const questionTag = document.getElementById('questionTag');
      if (questionTag) {
        questionTag.innerHTML = `<i class="bi bi-lightning-charge-fill"></i><span>${getDifficultyText(question.difficulty)}</span>`;
      }

      timeLeft = question.timeLimit;
      document.getElementById('timerText').textContent = timeLeft;
      document.getElementById('timerTextSide').textContent = timeLeft;
      document.getElementById('timerBar').style.width = '100%';
      document.getElementById('timerBar').className = 'timer-bar';
      const timerWrap = document.querySelector('.timer-wrap');
      if (timerWrap) {
        timerWrap.classList.remove('timer-warning', 'timer-critical');
      }

      startTimer(question.timeLimit);

      document.querySelectorAll('.option-btn').forEach(btn => {
        btn.disabled = false;
        btn.classList.remove('correct', 'wrong', 'disabled', 'selected');
      });

      questionStartTime = Date.now();
      isAnswering = true;
      updateSharedStats();
    }

    function startTimer(seconds) {
      if (timerInterval) clearInterval(timerInterval);

      timerInterval = setInterval(() => {
        timeLeft--;
        document.getElementById('timerText').textContent = timeLeft;
        document.getElementById('timerTextSide').textContent = timeLeft;

        const percentage = (timeLeft / seconds) * 100;
        document.getElementById('timerBar').style.width = percentage + '%';
        const timerWrap = document.querySelector('.timer-wrap');
        if (timerWrap) {
          timerWrap.classList.toggle('timer-warning', timeLeft <= 5 && timeLeft > 3);
          timerWrap.classList.toggle('timer-critical', timeLeft <= 3);
        }

        if (timeLeft <= 3) {
          document.getElementById('timerBar').classList.add('timer-critical');
        } else if (timeLeft <= 5) {
          document.getElementById('timerBar').classList.add('timer-warning');
        }

        if (timeLeft <= 0) {
          clearInterval(timerInterval);
          handleTimeout();
        }
      }, 1000);
    }

    function handleTimeout() {
      if (!isAnswering) return;
      isAnswering = false;
      submitAnswer(null, currentQuestion.timeLimit);
    }

    function handleAnswer(answer) {
      if (!isAnswering) return;
      isAnswering = false;

      clearInterval(timerInterval);
      const responseTime = Math.round((Date.now() - questionStartTime) / 1000);

      submitAnswer(answer, responseTime);
    }

    async function submitAnswer(answer, responseTime) {
      document.querySelectorAll('.option-btn').forEach(btn => {
        btn.disabled = true;
        btn.classList.add('disabled');
      });

      try {
        const response = await fetch('/coopgame/game/api/answer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            attemptId: attemptId,
            questionId: currentQuestion.id,
            answer: answer,
            responseTime: responseTime
          })
        });

        const result = await response.json();

        if (!result.success) {
          alert(result.errors?.[0]?.msg || result.message || 'เกิดข้อผิดพลาด กรุณาลองใหม่');
          replaceToGameEndUrl();
        } else if (result.data && result.data.gameOver) {
          gameCompleted = true;
          const resultData = result.data;
          const feedbackType = resultData.reason === 'timeout'
            ? 'timeout'
            : resultData.isCorrect ? 'correct' : 'wrong';
          if (isAdminPlay) {
            await showAnswerFeedback(feedbackType, { actionLabel: 'OK' });
            replaceToGameEndUrl();
            return;
          }

          if (!resultData.isCorrect || resultData.reason === 'timeout') {
            await showAnswerFeedback(feedbackType, { actionLabel: 'OK' });
            if (isTopThreeRank(resultData.rank)) {
              await showTopRankPopup(resultData.rank);
            }
            replaceToGameEndUrl();
            return;
          }

          await showAnswerFeedback(feedbackType);
          if (isTopThreeRank(resultData.rank)) {
            await showTopRankPopup(resultData.rank);
            replaceToGameEndUrl();
            return;
          }
          showGameOver(resultData);
        } else if (result.success && result.data) {
          if (result.data.isCorrect) {
            score++;
            updateSharedStats();
            await showAnswerFeedback('correct');
          }
          loadQuestion();
        } else {
          alert(result.message);
          replaceToGameEndUrl();
        }
      } catch (error) {
        console.error('Error submitting answer:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
        replaceToGameEndUrl();
      }
    }

    function showGameOver(result) {
      document.getElementById('gameArea').classList.add('hidden');
      document.getElementById('resultArea').classList.remove('hidden');

      const title = document.getElementById('resultTitle');
      const message = document.getElementById('resultMessage');
      const emoji = document.querySelector('#resultArea .result-emoji i');

      if (result.reason === 'timeout') {
        title.textContent = 'หมดเวลาแล้ว';
        message.textContent = `คุณตอบถูก ${result.finalScore} ข้อ อย่าเพิ่งท้อ ลองใหม่เพื่อทำคะแนนให้สูงขึ้น`;
        if (emoji) emoji.className = 'bi bi-hourglass-split';
      } else if (!result.isCorrect) {
        title.textContent = 'ตอบผิด';
        message.textContent = `คุณตอบถูก ${result.finalScore} ข้อ แต่ยังเล่นใหม่เพื่อไต่คะแนนได้อีก`;
        if (emoji) emoji.className = 'bi bi-x-circle-fill';
      } else {
        title.textContent = 'ผ่านทุกข้อ';
        message.textContent = `คุณตอบถูก ${result.finalScore} ข้อ ใช้เวลารวม ${result.totalTime} วินาที`;
        if (emoji) emoji.className = 'bi bi-trophy-fill';
      }
    }

    document.querySelectorAll('.option-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!isAnswering) return;

        document.querySelectorAll('.option-btn').forEach(item => item.classList.remove('selected'));
        btn.classList.add('selected');
        const answer = btn.dataset.answer;
        handleAnswer(answer);
      });
    });
  </script>
</body>
</html>
