<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - เกมตอบคำถามสหกรณ์</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/coopgame/css/styles.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700;800&display=swap');

    :root {
      --bg-1: #0d2317;
      --bg-2: #183623;
      --bg-3: #1f5a35;
      --card: rgba(255, 255, 255, 0.96);
      --card-soft: rgba(255, 255, 255, 0.84);
      --border: rgba(95, 196, 118, 0.24);
      --green-900: #10361f;
      --green-700: #1e6f37;
      --green-500: #35b559;
      --green-300: #7fd08d;
      --text: #18321f;
      --muted: #5b7264;
      --shadow: 0 24px 70px rgba(8, 24, 14, 0.26);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: 'Sarabun', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(87, 196, 108, 0.28), transparent 26%),
        radial-gradient(circle at top right, rgba(255, 255, 255, 0.12), transparent 22%),
        radial-gradient(circle at bottom left, rgba(255, 255, 255, 0.08), transparent 18%),
        linear-gradient(135deg, var(--bg-1) 0%, var(--bg-2) 44%, var(--bg-3) 100%);
      overflow-x: hidden;
    }

    .play-page {
      position: relative;
      min-height: 100vh;
      padding: 18px;
      isolation: isolate;
    }

    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(8px);
      pointer-events: none;
      z-index: 0;
      opacity: 0.85;
    }

    .orb-1 {
      width: 280px;
      height: 280px;
      top: -80px;
      left: -70px;
      background: radial-gradient(circle, rgba(127, 208, 141, 0.34), rgba(127, 208, 141, 0) 70%);
    }

    .orb-2 {
      width: 220px;
      height: 220px;
      right: -80px;
      top: 14%;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0) 70%);
    }

    .orb-3 {
      width: 260px;
      height: 260px;
      left: 8%;
      bottom: -110px;
      background: radial-gradient(circle, rgba(95, 196, 118, 0.18), rgba(95, 196, 118, 0) 72%);
    }

    .game-shell {
      position: relative;
      z-index: 1;
      max-width: 1280px;
      margin: 0 auto;
      display: grid;
      gap: 18px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      padding: 18px 22px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(18px);
      box-shadow: 0 18px 50px rgba(5, 20, 11, 0.14);
      color: #fff;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .brand-mark {
      width: 54px;
      height: 54px;
      display: grid;
      place-items: center;
      border-radius: 18px;
      background: linear-gradient(135deg, #ffffff, rgba(255,255,255,0.74));
      color: var(--green-700);
      font-size: 1.4rem;
      box-shadow: 0 14px 26px rgba(0, 0, 0, 0.16);
    }

    .brand-title {
      margin: 0;
      font-size: 1.2rem;
      font-weight: 800;
      line-height: 1.2;
    }

    .brand-subtitle {
      margin: 4px 0 0;
      color: rgba(255,255,255,0.78);
      font-size: 0.95rem;
    }

    .top-stats {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 10px;
    }

    .stat-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.16);
      border: 1px solid rgba(255,255,255,0.18);
      font-weight: 700;
      color: #fff;
      backdrop-filter: blur(12px);
    }

    .stat-pill i {
      color: #c9ffd5;
    }

    .content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.62fr);
      gap: 18px;
      align-items: start;
    }

    .panel {
      border-radius: 30px;
      background: var(--card);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      backdrop-filter: blur(16px);
      overflow: hidden;
    }

    .panel-inner {
      padding: 24px;
    }

    .loading-panel {
      min-height: 500px;
      display: grid;
      place-items: center;
      text-align: center;
    }

    .loading-visual {
      width: 96px;
      height: 96px;
      display: grid;
      place-items: center;
      border-radius: 30px;
      margin: 0 auto 18px;
      background: linear-gradient(135deg, rgba(53, 181, 89, 0.16), rgba(127, 208, 141, 0.24));
      color: var(--green-700);
      font-size: 2.2rem;
      animation: floaty 2.8s ease-in-out infinite;
    }

    .loading-title {
      font-size: 1.45rem;
      font-weight: 800;
      margin: 0 0 8px;
      color: var(--green-900);
    }

    .loading-text {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }

    .player-intro {
      min-height: 500px;
      display: grid;
      place-items: center;
    }

    .player-card {
      width: min(520px, 100%);
      padding: 28px;
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(249, 252, 249, 0.98));
      border: 1px solid rgba(95, 196, 118, 0.18);
      box-shadow: 0 20px 44px rgba(8, 24, 14, 0.08);
    }

    .player-icon {
      width: 76px;
      height: 76px;
      display: grid;
      place-items: center;
      margin: 0 0 18px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(53, 181, 89, 0.16), rgba(127, 208, 141, 0.24));
      color: var(--green-700);
      font-size: 2rem;
    }

    .player-title {
      margin: 0 0 8px;
      color: var(--green-900);
      font-size: 1.55rem;
      font-weight: 800;
    }

    .player-text {
      margin: 0 0 18px;
      color: var(--muted);
      line-height: 1.7;
    }

    .player-form {
      display: grid;
      gap: 14px;
    }

    .player-field label {
      display: block;
      margin-bottom: 8px;
      color: var(--green-900);
      font-weight: 800;
    }

    .player-field input {
      width: 100%;
      min-height: 52px;
      border-radius: 16px;
      border: 1px solid rgba(95, 196, 118, 0.22);
      background: #fff;
      padding: 12px 14px;
      font-size: 1rem;
      font-family: inherit;
      transition: border-color 0.18s ease, box-shadow 0.18s ease;
    }

    .player-field input:focus {
      outline: none;
      border-color: rgba(53, 181, 89, 0.6);
      box-shadow: 0 0 0 4px rgba(53, 181, 89, 0.1);
    }

    .player-message {
      min-height: 24px;
      color: #a41f2c;
      font-weight: 700;
      line-height: 1.5;
    }

    .question-banner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 18px;
      padding: 16px 18px;
      border-radius: 22px;
      background: linear-gradient(135deg, rgba(233, 247, 235, 0.95), rgba(245, 251, 246, 0.95));
      border: 1px solid rgba(95, 196, 118, 0.18);
    }

    .question-progress {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 800;
      color: var(--green-900);
    }

    .question-progress i {
      color: var(--green-700);
    }

    .question-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.76);
      color: var(--green-700);
      font-weight: 700;
      box-shadow: 0 8px 20px rgba(21, 67, 33, 0.06);
    }

    .timer-wrap {
      margin-bottom: 18px;
      padding: 18px;
      border-radius: 26px;
      background:
        radial-gradient(circle at 12% 0%, rgba(255,255,255,0.24), transparent 30%),
        linear-gradient(135deg, rgba(11, 64, 29, 0.98), rgba(22, 128, 54, 0.96) 62%, rgba(41, 164, 76, 0.96));
      border: 1px solid rgba(255, 255, 255, 0.22);
      color: #fff;
      box-shadow: 0 20px 44px rgba(8, 24, 14, 0.2);
      position: relative;
      overflow: hidden;
    }

    .timer-wrap::before {
      content: '';
      position: absolute;
      width: 140px;
      height: 140px;
      right: -44px;
      top: -58px;
      border-radius: 50%;
      background: rgba(255,255,255,0.12);
      pointer-events: none;
    }

    .timer-wrap::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(110deg, transparent 0%, rgba(255,255,255,0.1) 46%, transparent 72%);
      opacity: 0.46;
      pointer-events: none;
    }

    .timer-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
      font-weight: 800;
      position: relative;
      z-index: 1;
    }

    .timer-text {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #fff;
      font-size: 1rem;
      text-shadow: 0 1px 12px rgba(0, 0, 0, 0.18);
    }

    .timer-text i {
      color: #fff;
    }

    .timer-title {
      padding: 9px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.16);
      border: 1px solid rgba(255,255,255,0.2);
      backdrop-filter: blur(10px);
    }

    .timer-count {
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.22);
      border: 1px solid rgba(255,255,255,0.26);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.22);
      white-space: nowrap;
    }

    #timerText {
      display: inline-grid;
      place-items: center;
      min-width: 34px;
      color: #fff;
      font-size: 1.35rem;
      font-weight: 800;
      line-height: 1;
    }

    .timer-bar-shell {
      height: 24px;
      border-radius: 999px;
      padding: 4px;
      background: rgba(255,255,255,0.18);
      border: 1px solid rgba(255,255,255,0.24);
      box-shadow:
        inset 0 2px 5px rgba(0, 0, 0, 0.18),
        0 12px 26px rgba(5, 32, 13, 0.14);
      overflow: hidden;
      position: relative;
      z-index: 1;
    }

    .timer-bar {
      height: 100%;
      width: 100%;
      border-radius: inherit;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.58), rgba(255,255,255,0) 46%),
        repeating-linear-gradient(135deg, rgba(255,255,255,0.18) 0 8px, transparent 8px 16px),
        linear-gradient(90deg, #d4ffd8 0%, #86ee95 45%, #43c45d 100%);
      background-size: 200% 100%, 22px 22px, 100% 100%;
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.5),
        0 0 20px rgba(102, 255, 137, 0.32);
      transition: width 0.85s linear, background-color 0.25s ease, box-shadow 0.25s ease;
      position: relative;
      overflow: hidden;
    }

    .timer-bar::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(110deg, transparent 18%, rgba(255,255,255,0.55) 50%, transparent 82%);
      transform: translateX(-55%);
      animation: timerShine 2.8s linear infinite;
      opacity: 0.45;
    }

    .timer-bar.timer-warning {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.5), rgba(255,255,255,0) 46%),
        repeating-linear-gradient(135deg, rgba(255,255,255,0.16) 0 8px, transparent 8px 16px),
        linear-gradient(90deg, #fff4bc 0%, #ffd86b 50%, #ffbf3f 100%);
      box-shadow: 0 0 18px rgba(255, 211, 84, 0.28);
    }

    .timer-bar.timer-critical {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.46), rgba(255,255,255,0) 46%),
        repeating-linear-gradient(135deg, rgba(255,255,255,0.14) 0 8px, transparent 8px 16px),
        linear-gradient(90deg, #ffc0c7 0%, #ff748e 48%, #ff4d6d 100%);
      box-shadow: 0 0 18px rgba(255, 91, 118, 0.34);
    }

    .timer-wrap.timer-warning {
      background:
        radial-gradient(circle at 12% 0%, rgba(255,255,255,0.22), transparent 30%),
        linear-gradient(135deg, rgba(99, 67, 7, 0.98), rgba(209, 141, 24, 0.96));
      box-shadow: 0 20px 44px rgba(223, 150, 0, 0.18);
    }

    .timer-wrap.timer-critical {
      background:
        radial-gradient(circle at 12% 0%, rgba(255,255,255,0.2), transparent 30%),
        linear-gradient(135deg, rgba(98, 21, 38, 0.98), rgba(214, 54, 84, 0.96));
      box-shadow: 0 20px 44px rgba(224, 54, 83, 0.2);
    }

    .question-card {
      padding: 22px;
      border-radius: 26px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(249, 252, 249, 0.98));
      border: 1px solid rgba(95, 196, 118, 0.18);
      box-shadow: 0 16px 34px rgba(8, 24, 14, 0.06);
      margin-bottom: 18px;
    }

    .question-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(53, 181, 89, 0.12);
      color: var(--green-700);
      font-weight: 800;
      font-size: 0.95rem;
    }

    .question-text {
      margin: 0;
      font-size: clamp(1.35rem, 2vw, 1.75rem);
      line-height: 1.7;
      color: var(--green-900);
      font-weight: 800;
    }

    .options-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .option-btn {
      display: flex;
      align-items: center;
      gap: 14px;
      min-height: 92px;
      padding: 16px 18px;
      border: 1px solid rgba(95, 196, 118, 0.18);
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247, 251, 248, 0.98));
      box-shadow: 0 12px 24px rgba(8, 24, 14, 0.05);
      text-align: left;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background 0.18s ease;
      color: var(--text);
    }

    .option-btn:hover:not(:disabled) {
      transform: translateY(-2px);
      border-color: rgba(53, 181, 89, 0.45);
      box-shadow: 0 18px 34px rgba(8, 24, 14, 0.1);
    }

    .option-btn:disabled {
      cursor: not-allowed;
      opacity: 0.7;
    }

    .option-btn.selected {
      border-color: rgba(53, 181, 89, 0.72);
      box-shadow: 0 18px 30px rgba(53, 181, 89, 0.16);
      transform: translateY(-1px);
    }

    .option-btn.correct {
      background: linear-gradient(180deg, rgba(231, 248, 234, 0.98), rgba(214, 247, 219, 0.98));
      border-color: rgba(53, 181, 89, 0.5);
    }

    .option-btn.wrong {
      background: linear-gradient(180deg, rgba(255, 240, 240, 0.98), rgba(255, 228, 228, 0.98));
      border-color: rgba(255, 88, 88, 0.4);
    }

    .option-btn.disabled {
      opacity: 0.68;
    }

    .option-label {
      width: 48px;
      height: 48px;
      flex-shrink: 0;
      display: grid;
      place-items: center;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--green-700), var(--green-500));
      color: #fff;
      font-weight: 800;
      font-size: 1.1rem;
      box-shadow: 0 10px 20px rgba(29, 110, 52, 0.22);
    }

    .option-text {
      flex: 1;
      font-size: 1.05rem;
      font-weight: 700;
      line-height: 1.6;
      color: var(--green-900);
    }

    .side-stack {
      display: grid;
      gap: 18px;
    }

    .side-card {
      padding: 22px;
      border-radius: 28px;
      background: rgba(255,255,255,0.94);
      border: 1px solid rgba(95, 196, 118, 0.18);
      box-shadow: 0 18px 40px rgba(8, 24, 14, 0.08);
    }

    .side-title {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 0 0 14px;
      color: var(--green-900);
      font-size: 1.05rem;
      font-weight: 800;
    }

    .side-title i {
      color: var(--green-700);
    }

    .hint-list {
      display: grid;
      gap: 12px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .hint-list li {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      padding: 12px 14px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(53, 181, 89, 0.08), rgba(127, 208, 141, 0.14));
      color: var(--green-900);
      line-height: 1.6;
      font-weight: 600;
    }

    .hint-list i {
      color: var(--green-700);
      margin-top: 2px;
    }

    .result-area {
      padding: 24px;
    }

    .result-card {
      padding: 28px;
      border-radius: 28px;
      background:
        radial-gradient(circle at top right, rgba(255,255,255,0.18), transparent 28%),
        linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248, 252, 249, 0.98));
      border: 1px solid rgba(95, 196, 118, 0.18);
      box-shadow: 0 24px 50px rgba(8, 24, 14, 0.08);
      text-align: center;
    }

    .result-emoji {
      width: 88px;
      height: 88px;
      margin: 0 auto 16px;
      border-radius: 28px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, rgba(53, 181, 89, 0.14), rgba(127, 208, 141, 0.22));
      color: var(--green-700);
      font-size: 2.3rem;
    }

    .result-title {
      margin: 0 0 10px;
      font-size: 2rem;
      font-weight: 800;
      color: var(--green-900);
    }

    .result-message {
      margin: 0 0 22px;
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.75;
    }

    .result-actions {
      display: grid;
      gap: 10px;
      margin-top: 18px;
    }

    .btn-emerald {
      border: none;
      border-radius: 16px;
      padding: 14px 18px;
      font-weight: 800;
      color: #fff;
      background: linear-gradient(135deg, #166534 0%, #22a247 55%, #4ade80 100%);
      box-shadow: 0 14px 28px rgba(29, 110, 52, 0.22);
    }

    .btn-emerald:hover {
      color: #fff;
    }

    .btn-outline-emerald {
      border-radius: 16px;
      border: 1px solid rgba(53, 181, 89, 0.34);
      color: var(--green-700);
      background: #fff;
      font-weight: 800;
      padding: 14px 18px;
    }

    .btn-outline-emerald:hover {
      background: rgba(53, 181, 89, 0.08);
      color: var(--green-900);
    }

    .hidden {
      display: none !important;
    }

    .fade-in {
      animation: fadeIn 0.45s ease-out;
    }

    .spin-icon {
      animation: spin 1s linear infinite;
    }

    @keyframes floaty {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    @keyframes timerShine {
      from { transform: translateX(-60%); }
      to { transform: translateX(160%); }
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 992px) {
      .content-grid {
        grid-template-columns: 1fr;
      }

      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }

      .top-stats {
        justify-content: flex-start;
      }
    }

    @media (max-width: 768px) {
      .play-page {
        padding: 12px;
      }

      .panel-inner,
      .result-area,
      .side-card,
      .result-card,
      .question-card,
      .timer-wrap {
        padding-left: 18px;
        padding-right: 18px;
      }

      .options-grid {
        grid-template-columns: 1fr;
      }

      .question-banner {
        flex-direction: column;
        align-items: flex-start;
      }

      .timer-top {
        flex-direction: column;
        align-items: flex-start;
      }

      .result-title {
        font-size: 1.6rem;
      }
    }
  </style>
</head>
<body>
  <div class="play-page">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="game-shell">
      <header class="topbar fade-in">
        <div class="brand">
          <div class="brand-mark">
            <i class="bi bi-controller"></i>
          </div>
          <div>
            <h1 class="brand-title">เกมตอบคำถามสหกรณ์</h1>
            <p class="brand-subtitle">ตอบให้ไว เก็บคะแนนให้สูง แล้วไปต่อให้ถึงรอบจบ</p>
          </div>
        </div>

        <div class="top-stats">
          <div class="stat-pill"><i class="bi bi-star-fill"></i> คะแนน <span id="score">0</span></div>
          <div class="stat-pill"><i class="bi bi-list-ol"></i> ข้อ <span id="questionNum">1</span></div>
        </div>
      </header>

      <div class="content-grid">
        <section class="panel fade-in">
          <div id="playerIntro" class="player-intro panel-inner hidden">
            <div class="player-card">
              <div class="player-icon">
                <i class="bi bi-person-vcard-fill"></i>
              </div>
              <h2 class="player-title">ข้อมูลผู้เล่น</h2>
              <p class="player-text">กรอกชื่อและเบอร์โทรศัพท์ก่อนเริ่มเกม ระบบจะใช้ข้อมูลนี้สำหรับบันทึกคะแนนและติดต่อผู้ชนะ</p>

              <form id="playerInfoForm" class="player-form">
                <div class="player-field">
                  <label for="playerName">ชื่อผู้เล่น</label>
                  <input
                    type="text"
                    id="playerName"
                    name="playerName"
                    placeholder="ใส่ชื่อของคุณ"
                    autocomplete="name"
                    required
                  >
                </div>

                <div class="player-field">
                  <label for="phoneNumber">เบอร์โทรศัพท์</label>
                  <input
                    type="tel"
                    id="phoneNumber"
                    name="phoneNumber"
                    placeholder="08xxxxxxxx"
                    inputmode="tel"
                    autocomplete="tel"
                    pattern="[0-9]{9,10}"
                    required
                  >
                </div>

                <button type="submit" class="btn btn-emerald">
                  <i class="bi bi-play-fill"></i> บันทึกและเริ่มตอบคำถาม
                </button>
              </form>

              <div id="playerInfoMessage" class="player-message" aria-live="polite"></div>
            </div>
          </div>

          <div id="loading" class="loading-panel panel-inner hidden">
            <div>
              <div class="loading-visual">
                <i class="bi bi-hourglass-split"></i>
              </div>
              <h2 class="loading-title">กำลังเตรียมคำถาม</h2>
              <p class="loading-text">ระบบกำลังโหลดคำถามสำหรับรอบนี้ โปรดรอสักครู่ แล้วจะพาคุณเข้าสู่เกมทันที</p>
            </div>
          </div>

          <div id="gameArea" class="panel-inner hidden">
            <div class="question-banner">
              <div class="question-progress">
                <i class="bi bi-flag-fill"></i>
                <span>คำถาม <span id="progressCurrent">1</span> จาก <span id="progressTotal">-</span></span>
              </div>
              <div class="question-tag" id="questionTag">
                <i class="bi bi-lightning-charge-fill"></i>
                <span>เตรียมพร้อม</span>
              </div>
            </div>

            <div class="timer-wrap">
              <div class="timer-top">
                <div class="timer-text timer-title"><i class="bi bi-stopwatch-fill"></i> เวลาที่เหลือ</div>
                <div class="timer-text timer-count"><i class="bi bi-hourglass-split"></i><span id="timerText">10</span> วินาที</div>
              </div>
              <div class="timer-bar-shell">
                <div id="timerBar" class="timer-bar"></div>
              </div>
            </div>

            <div class="question-card">
              <div class="question-label">
                <i class="bi bi-question-circle-fill"></i>
                <span>คำถาม</span>
              </div>
              <h2 id="questionText" class="question-text"></h2>
            </div>

            <div class="options-grid">
              <button class="option-btn" data-answer="A" id="btnA" type="button">
                <span class="option-label">ก</span>
                <span class="option-text" id="textA"></span>
              </button>
              <button class="option-btn" data-answer="B" id="btnB" type="button">
                <span class="option-label">ข</span>
                <span class="option-text" id="textB"></span>
              </button>
              <button class="option-btn" data-answer="C" id="btnC" type="button">
                <span class="option-label">ค</span>
                <span class="option-text" id="textC"></span>
              </button>
              <button class="option-btn" data-answer="D" id="btnD" type="button">
                <span class="option-label">ง</span>
                <span class="option-text" id="textD"></span>
              </button>
            </div>
          </div>

          <div id="resultArea" class="result-area hidden">
            <div class="result-card">
              <div class="result-emoji">
                <i class="bi bi-emoji-sunglasses-fill"></i>
              </div>
              <h2 id="resultTitle" class="result-title"></h2>
              <p id="resultMessage" class="result-message"></p>
              <div class="result-actions">
                <a href="/coopgame/game/finish?attemptId=<%= attemptId %>" class="btn btn-emerald">
                  <i class="bi bi-clipboard2-check-fill"></i> ดูผลลัพธ์ท้ายเกม
                </a>
                <a href="/coopgame/game/start" class="btn btn-outline-emerald">
                  <i class="bi bi-arrow-counterclockwise"></i> เล่นใหม่
                </a>
              </div>
            </div>
          </div>
        </section>

        <aside class="side-stack">
          <div class="side-card fade-in">
            <h3 class="side-title"><i class="bi bi-award-fill"></i> เคล็ดลับการเล่น</h3>
            <ul class="hint-list">
              <li><i class="bi bi-lightning-fill"></i> ตอบให้เร็วเพื่อรักษาเวลารวมให้น้อยที่สุด</li>
              <li><i class="bi bi-badge-ad-fill"></i> คำถามเรียงระดับจากง่ายไปยาก เล่นให้ต่อเนื่อง</li>
              <li><i class="bi bi-shield-check"></i> เลือกคำตอบแล้วระบบจะตรวจให้อัตโนมัติ</li>
            </ul>
          </div>

          <div class="side-card fade-in">
            <h3 class="side-title"><i class="bi bi-graph-up-arrow"></i> สถานะเกม</h3>
            <div class="d-grid gap-2">
              <div class="question-tag"><i class="bi bi-trophy-fill"></i> คะแนนสะสม <span id="scoreSide" class="ms-auto">0</span></div>
              <div class="question-tag"><i class="bi bi-list-check"></i> ข้อปัจจุบัน <span id="questionNumSide" class="ms-auto">1</span></div>
              <div class="question-tag"><i class="bi bi-stopwatch"></i> เวลาตอบ <span id="timerTextSide" class="ms-auto">10</span> วินาที</div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <script>
    const attemptId = <%= attemptId %>;
    const isAdminPlay = <%= isAdminPlay ? 'true' : 'false' %>;
    const initialPlayerName = <%- JSON.stringify(playerName || '') %>;
    const initialPhoneNumber = <%- JSON.stringify(phoneNumber || '') %>;
    let hasPlayerInfo = isAdminPlay || Boolean(initialPlayerName && initialPhoneNumber);
    let currentQuestion = null;
    let score = 0;
    let questionStartTime = 0;
    let timerInterval = null;
    let timeLeft = 0;
    let isAnswering = false;

    const playerIntro = document.getElementById('playerIntro');
    const loadingPanel = document.getElementById('loading');
    const playerInfoForm = document.getElementById('playerInfoForm');
    const playerInfoMessage = document.getElementById('playerInfoMessage');
    const playerNameInput = document.getElementById('playerName');
    const phoneNumberInput = document.getElementById('phoneNumber');

    playerNameInput.value = initialPlayerName;
    phoneNumberInput.value = initialPhoneNumber;

    if (hasPlayerInfo) {
      if (isAdminPlay) {
        document.getElementById('gameArea').insertAdjacentHTML(
          'beforebegin',
          '<div class="panel-inner" style="padding-top:0"><div class="question-tag" style="margin-bottom:14px"><i class="bi bi-shield-check"></i> โหมดทดสอบผู้ดูแล: ไม่ต้องกรอกชื่อหรือเบอร์ และไม่ถูกนำไปจัดอันดับ</div></div>'
        );
      }
      showLoadingPanel();
      loadQuestion();
    } else {
      showPlayerIntro();
    }

    function showPlayerIntro(message = '') {
      if (isAdminPlay) {
        showLoadingPanel();
        loadQuestion();
        return;
      }
      playerIntro.classList.remove('hidden');
      loadingPanel.classList.add('hidden');
      document.getElementById('gameArea').classList.add('hidden');
      playerInfoMessage.textContent = message;
      setTimeout(() => playerNameInput.focus(), 50);
    }

    function showLoadingPanel() {
      playerIntro.classList.add('hidden');
      loadingPanel.classList.remove('hidden');
    }

    playerInfoForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const playerName = playerNameInput.value.trim();
      const phoneNumber = phoneNumberInput.value.replace(/[^\d]/g, '');
      const submitBtn = playerInfoForm.querySelector('button[type="submit"]');

      if (!playerName) {
        playerInfoMessage.textContent = 'กรุณากรอกชื่อผู้เล่น';
        return;
      }

      if (!/^\d{9,10}$/.test(phoneNumber)) {
        playerInfoMessage.textContent = 'กรุณากรอกเบอร์โทรศัพท์ 9-10 หลัก';
        return;
      }

      phoneNumberInput.value = phoneNumber;
      submitBtn.disabled = true;
      playerInfoMessage.textContent = 'กำลังบันทึกข้อมูลผู้เล่น...';

      try {
        const response = await fetch('/coopgame/game/api/player-info', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ attemptId, playerName, phoneNumber })
        });
        const result = await response.json();

        if (result.success) {
          hasPlayerInfo = true;
          playerInfoMessage.textContent = '';
          showLoadingPanel();
          loadQuestion();
        } else {
          const errorText = (result.errors && result.errors[0] && result.errors[0].msg)
            || result.message
            || 'ไม่สามารถบันทึกข้อมูลผู้เล่นได้';
          playerInfoMessage.textContent = errorText;
        }
      } catch (error) {
        console.error('Error saving player info:', error);
        playerInfoMessage.textContent = 'เกิดข้อผิดพลาด กรุณาลองใหม่';
      } finally {
        submitBtn.disabled = false;
      }
    });

    async function loadQuestion() {
      try {
        const response = await fetch(`/coopgame/game/api/question?attemptId=${attemptId}`);
        const result = await response.json();

        if (result.success && result.data && result.data.question) {
          displayQuestion(result.data.question);
        } else {
          if (result.errorCode === 'PLAYER_INFO_REQUIRED') {
            hasPlayerInfo = false;
            showPlayerIntro(result.message || 'กรุณากรอกชื่อและเบอร์โทรศัพท์ก่อนเริ่มเกม');
            return;
          }
          window.location.href = `/coopgame/game/finish?attemptId=${attemptId}`;
        }
      } catch (error) {
        console.error('Error loading question:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
        window.location.href = '/coopgame/game/start';
      }
    }

    function getDifficultyText(difficulty) {
      const texts = { easy: 'ง่าย', medium: 'ปานกลาง', hard: 'ยาก' };
      return texts[difficulty] || 'ระดับคำถาม';
    }

    function updateSharedStats() {
      const scoreEl = document.getElementById('score');
      const scoreSideEl = document.getElementById('scoreSide');
      const questionNumEl = document.getElementById('questionNum');
      const questionNumSideEl = document.getElementById('questionNumSide');
      const timerTextSideEl = document.getElementById('timerTextSide');

      if (scoreEl) scoreEl.textContent = score;
      if (scoreSideEl) scoreSideEl.textContent = score;
      if (questionNumEl && currentQuestion) questionNumEl.textContent = currentQuestion.questionNumber || 1;
      if (questionNumSideEl && currentQuestion) questionNumSideEl.textContent = currentQuestion.questionNumber || 1;
      if (timerTextSideEl) timerTextSideEl.textContent = timeLeft || 0;
    }

    function displayQuestion(question) {
      currentQuestion = question;
      isAnswering = false;

      document.getElementById('loading').classList.add('hidden');
      document.getElementById('gameArea').classList.remove('hidden');
      document.getElementById('resultArea').classList.add('hidden');

      document.getElementById('questionText').textContent = question.text;
      document.getElementById('textA').textContent = question.options.A;
      document.getElementById('textB').textContent = question.options.B;
      document.getElementById('textC').textContent = question.options.C;
      document.getElementById('textD').textContent = question.options.D;
      document.getElementById('progressCurrent').textContent = question.questionNumber;
      document.getElementById('progressTotal').textContent = question.totalQuestions || '-';

      const questionTag = document.getElementById('questionTag');
      if (questionTag) {
        questionTag.innerHTML = `<i class="bi bi-lightning-charge-fill"></i><span>${getDifficultyText(question.difficulty)}</span>`;
      }

      timeLeft = question.timeLimit;
      document.getElementById('timerText').textContent = timeLeft;
      document.getElementById('timerTextSide').textContent = timeLeft;
      document.getElementById('timerBar').style.width = '100%';
      document.getElementById('timerBar').className = 'timer-bar';
      const timerWrap = document.querySelector('.timer-wrap');
      if (timerWrap) {
        timerWrap.classList.remove('timer-warning', 'timer-critical');
      }

      startTimer(question.timeLimit);

      document.querySelectorAll('.option-btn').forEach(btn => {
        btn.disabled = false;
        btn.classList.remove('correct', 'wrong', 'disabled', 'selected');
      });

      questionStartTime = Date.now();
      isAnswering = true;
      updateSharedStats();
    }

    function startTimer(seconds) {
      if (timerInterval) clearInterval(timerInterval);

      timerInterval = setInterval(() => {
        timeLeft--;
        document.getElementById('timerText').textContent = timeLeft;
        document.getElementById('timerTextSide').textContent = timeLeft;

        const percentage = (timeLeft / seconds) * 100;
        document.getElementById('timerBar').style.width = percentage + '%';
        const timerWrap = document.querySelector('.timer-wrap');
        if (timerWrap) {
          timerWrap.classList.toggle('timer-warning', timeLeft <= 5 && timeLeft > 3);
          timerWrap.classList.toggle('timer-critical', timeLeft <= 3);
        }

        if (timeLeft <= 3) {
          document.getElementById('timerBar').classList.add('timer-critical');
        } else if (timeLeft <= 5) {
          document.getElementById('timerBar').classList.add('timer-warning');
        }

        if (timeLeft <= 0) {
          clearInterval(timerInterval);
          handleTimeout();
        }
      }, 1000);
    }

    function handleTimeout() {
      if (!isAnswering) return;
      isAnswering = false;
      submitAnswer(null, currentQuestion.timeLimit);
    }

    function handleAnswer(answer) {
      if (!isAnswering) return;
      isAnswering = false;

      clearInterval(timerInterval);
      const responseTime = Math.round((Date.now() - questionStartTime) / 1000);

      submitAnswer(answer, responseTime);
    }

    async function submitAnswer(answer, responseTime) {
      document.querySelectorAll('.option-btn').forEach(btn => {
        btn.disabled = true;
        btn.classList.add('disabled');
      });

      try {
        const response = await fetch('/coopgame/game/api/answer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            attemptId: attemptId,
            questionId: currentQuestion.id,
            answer: answer,
            responseTime: responseTime
          })
        });

        const result = await response.json();

        if (!result.success || (result.data && result.data.gameOver)) {
          showGameOver(result.data ? result.data : { isCorrect: false });
        } else if (result.success && result.data) {
          if (result.data.isCorrect) {
            score++;
            updateSharedStats();
          }
          setTimeout(() => loadQuestion(), 900);
        } else {
          alert(result.message);
          window.location.href = '/coopgame/game/start';
        }
      } catch (error) {
        console.error('Error submitting answer:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
        window.location.href = '/coopgame/game/start';
      }
    }

    function showGameOver(result) {
      document.getElementById('gameArea').classList.add('hidden');
      document.getElementById('resultArea').classList.remove('hidden');

      const title = document.getElementById('resultTitle');
      const message = document.getElementById('resultMessage');
      const emoji = document.querySelector('#resultArea .result-emoji i');

      if (result.reason === 'timeout') {
        title.textContent = 'หมดเวลาแล้ว';
        message.textContent = `คุณตอบถูก ${result.finalScore} ข้อ อย่าเพิ่งท้อ ลองใหม่เพื่อทำคะแนนให้สูงขึ้น`;
        if (emoji) emoji.className = 'bi bi-hourglass-split';
      } else if (!result.isCorrect) {
        title.textContent = 'ตอบผิด';
        message.textContent = `คุณตอบถูก ${result.finalScore} ข้อ แต่ยังเล่นใหม่เพื่อไต่คะแนนได้อีก`;
        if (emoji) emoji.className = 'bi bi-x-circle-fill';
      } else {
        title.textContent = 'ผ่านทุกข้อ';
        message.textContent = `คุณตอบถูก ${result.finalScore} ข้อ ใช้เวลารวม ${result.totalTime} วินาที`;
        if (emoji) emoji.className = 'bi bi-trophy-fill';
      }
    }

    document.querySelectorAll('.option-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!isAnswering) return;

        document.querySelectorAll('.option-btn').forEach(item => item.classList.remove('selected'));
        btn.classList.add('selected');
        const answer = btn.dataset.answer;
        handleAnswer(answer);
      });
    });
  </script>
</body>
</html>
