<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - เกมตอบคำถามสหกรณ์</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/coopgame/css/styles.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700;800&display=swap');

    :root {
      --bg-1: #03133c;
      --bg-2: #062b83;
      --bg-3: #0496e4;
      --card: rgba(255, 255, 255, 0.96);
      --card-soft: rgba(255, 255, 255, 0.84);
      --border: rgba(114, 233, 255, 0.32);
      --green-900: #031542;
      --green-700: #075bd8;
      --green-500: #0fb7ff;
      --green-300: #72e9ff;
      --gold-500: #ffd23c;
      --gold-600: #ffae16;
      --success: #20c66b;
      --text: #08183f;
      --muted: #5d6d93;
      --shadow: 0 24px 70px rgba(2, 16, 58, 0.28);
      --glow: 0 0 28px rgba(114, 233, 255, 0.42);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: 'Sarabun', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--text);
      background:
        linear-gradient(115deg, rgba(255, 210, 60, 0.12) 0 2px, transparent 2px 92px),
        linear-gradient(245deg, rgba(114, 233, 255, 0.14) 0 2px, transparent 2px 110px),
        radial-gradient(circle at 50% 22%, rgba(15, 183, 255, 0.42), transparent 34%),
        radial-gradient(circle at 74% 78%, rgba(32, 198, 107, 0.18), transparent 28%),
        linear-gradient(135deg, var(--bg-1) 0%, var(--bg-2) 44%, var(--bg-3) 100%);
      overflow-x: hidden;
    }

    .play-page {
      position: relative;
      min-height: 100vh;
      padding: 18px;
      isolation: isolate;
    }

    .play-page::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        linear-gradient(120deg, transparent 0 48%, rgba(255, 255, 255, 0.18) 49%, transparent 51% 100%),
        linear-gradient(58deg, transparent 0 57%, rgba(255, 210, 60, 0.22) 58%, transparent 60% 100%),
        repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.04) 0 1px, transparent 1px 84px);
      opacity: 0.7;
    }

    .orb {
      position: fixed;
      width: 58px;
      height: 170px;
      pointer-events: none;
      z-index: 0;
      opacity: 0.72;
      background: linear-gradient(180deg, #fff, var(--green-300), transparent);
      clip-path: polygon(42% 0, 76% 0, 56% 35%, 94% 35%, 26% 100%, 43% 52%, 12% 52%);
      filter: drop-shadow(0 0 14px rgba(114, 233, 255, 0.9));
    }

    .orb-1 {
      top: 24px;
      left: 4%;
      transform: rotate(-18deg) scale(0.84);
    }

    .orb-2 {
      right: 6%;
      top: 11%;
      transform: rotate(18deg);
    }

    .orb-3 {
      left: 12%;
      bottom: 7%;
      transform: rotate(12deg) scale(0.72);
    }

    .game-shell {
      position: relative;
      z-index: 1;
      max-width: 1280px;
      margin: 0 auto;
      display: grid;
      gap: 18px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      padding: 18px 22px;
      border-radius: 8px;
      background:
        radial-gradient(circle at 18% 0%, rgba(255, 210, 60, 0.18), transparent 28%),
        linear-gradient(135deg, rgba(3, 21, 66, 0.92), rgba(6, 43, 131, 0.86));
      border: 1px solid rgba(114, 233, 255, 0.34);
      backdrop-filter: blur(18px);
      box-shadow: var(--shadow), inset 0 0 28px rgba(114, 233, 255, 0.12);
      color: #fff;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .brand-mark {
      width: 54px;
      height: 54px;
      display: grid;
      place-items: center;
      border-radius: 8px;
      background: linear-gradient(135deg, #fff47a, var(--gold-500) 50%, var(--gold-600));
      color: #062265;
      font-size: 1.4rem;
      box-shadow: 0 14px 26px rgba(255, 174, 22, 0.22);
    }

    .brand-title {
      margin: 0;
      font-size: 1.2rem;
      font-weight: 800;
      line-height: 1.2;
    }

    .brand-subtitle {
      margin: 4px 0 0;
      color: rgba(255,255,255,0.78);
      font-size: 0.95rem;
    }

    .top-stats {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 10px;
    }

    .stat-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
      border: 1px solid rgba(114, 233, 255, 0.36);
      font-weight: 700;
      color: #fff;
      backdrop-filter: blur(12px);
    }

    .stat-pill i {
      color: var(--gold-500);
    }

    .content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.62fr);
      gap: 18px;
      align-items: start;
    }

    .panel {
      border-radius: 8px;
      background: var(--card);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      backdrop-filter: blur(16px);
      overflow: hidden;
    }

    .panel-inner {
      padding: 24px;
    }

    .loading-panel {
      min-height: 500px;
      display: grid;
      place-items: center;
      text-align: center;
    }

    .loading-visual {
      width: 96px;
      height: 96px;
      display: grid;
      place-items: center;
      border-radius: 8px;
      margin: 0 auto 18px;
      background: linear-gradient(135deg, #fff47a, var(--gold-500));
      color: #062265;
      font-size: 2.2rem;
      animation: floaty 2.8s ease-in-out infinite;
    }

    .loading-title {
      font-size: 1.45rem;
      font-weight: 800;
      margin: 0 0 8px;
      color: var(--green-900);
    }

    .loading-text {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }

    .player-intro {
      min-height: 500px;
      display: grid;
      place-items: center;
    }

    .player-card {
      width: min(520px, 100%);
      padding: 28px;
      border-radius: 8px;
      background: linear-gradient(180deg, rgba(255,255,255,0.99), rgba(242, 248, 255, 0.98));
      border: 2px solid rgba(255, 210, 60, 0.48);
      box-shadow: 0 20px 44px rgba(2, 16, 58, 0.1);
    }

    .player-icon {
      width: 76px;
      height: 76px;
      display: grid;
      place-items: center;
      margin: 0 0 18px;
      border-radius: 8px;
      background: linear-gradient(135deg, var(--green-700), var(--green-500));
      color: #fff;
      font-size: 2rem;
    }

    .player-title {
      margin: 0 0 8px;
      color: var(--green-900);
      font-size: 1.55rem;
      font-weight: 800;
    }

    .player-text {
      margin: 0 0 18px;
      color: var(--muted);
      line-height: 1.7;
    }

    .player-form {
      display: grid;
      gap: 14px;
    }

    .player-field label {
      display: block;
      margin-bottom: 8px;
      color: var(--green-900);
      font-weight: 800;
    }

    .player-field input {
      width: 100%;
      min-height: 52px;
      border-radius: 8px;
      border: 2px solid rgba(15, 183, 255, 0.18);
      background: #fff;
      padding: 12px 14px;
      font-size: 1rem;
      font-family: inherit;
      transition: border-color 0.18s ease, box-shadow 0.18s ease;
    }

    .player-field input:focus {
      outline: none;
      border-color: rgba(255, 210, 60, 0.8);
      box-shadow: 0 0 0 4px rgba(15, 183, 255, 0.12);
    }

    .player-message {
      min-height: 24px;
      color: #a41f2c;
      font-weight: 700;
      line-height: 1.5;
    }

    .question-banner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 18px;
      min-height: 124px;
      padding: 16px 150px 16px 18px;
      border-radius: 8px;
      background:
        linear-gradient(135deg, rgba(231, 246, 255, 0.98), rgba(255, 247, 196, 0.96));
      border: 1px solid rgba(15, 183, 255, 0.22);
    }

    .question-progress {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 800;
      color: var(--green-900);
    }

    .question-progress i {
      color: var(--green-700);
    }

    .question-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.76);
      color: var(--green-700);
      font-weight: 700;
      box-shadow: 0 8px 20px rgba(21, 67, 33, 0.06);
    }

    .timer-wrap {
      position: absolute;
      top: 8px;
      right: 34px;
      z-index: 8;
      width: 122px;
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
      box-shadow: none;
      color: #fff;
      overflow: visible;
    }

    .timer-wrap::before,
    .timer-wrap::after {
      display: none;
    }

    .robot-timer {
      position: relative;
      z-index: 1;
      display: grid;
      justify-items: center;
      gap: 14px;
    }

    .timer-robot {
      position: relative;
      width: 114px;
      margin: 0 auto;
      filter: drop-shadow(0 18px 22px rgba(2, 16, 58, 0.26));
    }

    .timer-robot img {
      display: block;
      width: 100%;
      height: auto;
      user-select: none;
      -webkit-user-drag: none;
    }

    .timer-display {
      position: absolute;
      left: 50%;
      top: 56.5%;
      width: 49%;
      min-height: 42px;
      display: grid;
      place-items: center;
      gap: 2px;
      padding: 5px 6px;
      border-radius: 8px;
      transform: translate(-50%, -50%);
      color: #062265;
      text-align: center;
      background: rgba(215, 255, 227, 0.94);
      border: 0;
      box-shadow: 0 10px 18px rgba(2, 16, 58, 0.12);
      backdrop-filter: blur(6px);
      overflow: hidden;
    }

    .timer-display::before {
      display: none;
    }

    .timer-label {
      display: none;
      align-items: center;
      gap: 6px;
      color: #176b4b;
      font-size: 0.72rem;
      font-weight: 800;
      line-height: 1;
      white-space: nowrap;
    }

    .timer-label i {
      color: #176b4b;
    }

    .timer-count {
      display: inline-flex;
      align-items: baseline;
      justify-content: center;
      gap: 6px;
      width: 100%;
      color: #062265;
      white-space: nowrap;
    }

    #timerText {
      display: inline-grid;
      place-items: center;
      min-width: 0;
      width: 100%;
      color: #062265;
      font-size: clamp(1.42rem, 2vw, 1.7rem);
      font-weight: 800;
      line-height: 0.95;
      text-shadow: 0 2px 0 rgba(255,255,255,0.72);
    }

    .timer-unit {
      display: none;
      color: #176b4b;
      font-size: 0.82rem;
      font-weight: 800;
    }

    .timer-wrap.timer-warning .timer-robot {
      filter:
        drop-shadow(0 18px 22px rgba(2, 16, 58, 0.24))
        saturate(1.08)
        brightness(0.98);
      animation: timerWarningZoom 0.9s ease-in-out infinite;
      transform-origin: center;
    }

    .timer-wrap.timer-warning .timer-display {
      background: rgba(255, 238, 170, 0.96);
      box-shadow:
        0 0 0 3px rgba(255, 184, 0, 0.16),
        0 10px 18px rgba(138, 76, 0, 0.16);
    }

    .timer-wrap.timer-warning .timer-label,
    .timer-wrap.timer-warning .timer-label i,
    .timer-wrap.timer-warning #timerText,
    .timer-wrap.timer-warning .timer-unit {
      color: #8a4c00;
      text-shadow: 0 2px 0 rgba(255,255,255,0.5);
    }

    .timer-wrap.timer-critical .timer-robot {
      filter:
        drop-shadow(0 18px 22px rgba(98, 21, 38, 0.28))
        saturate(1.1)
        brightness(0.96);
      animation: timerPulse 0.85s ease-in-out infinite;
    }

    .timer-wrap.timer-critical .timer-display {
      background: rgba(255, 199, 206, 0.98);
      box-shadow:
        0 0 0 3px rgba(255, 87, 112, 0.18),
        0 10px 18px rgba(98, 21, 38, 0.18);
    }

    .timer-wrap.timer-critical .timer-label,
    .timer-wrap.timer-critical .timer-label i,
    .timer-wrap.timer-critical #timerText,
    .timer-wrap.timer-critical .timer-unit {
      color: #8f1530;
      text-shadow: 0 2px 0 rgba(255,255,255,0.6);
    }

    .question-card {
      padding: 22px;
      border-radius: 8px;
      background: linear-gradient(180deg, rgba(255,255,255,0.99), rgba(242, 248, 255, 0.98));
      border: 2px solid rgba(255, 210, 60, 0.42);
      box-shadow: 0 16px 34px rgba(2, 16, 58, 0.08);
      margin-bottom: 18px;
    }

    #gameArea {
      position: relative;
    }

    .question-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 210, 60, 0.18);
      color: var(--green-700);
      font-weight: 800;
      font-size: 0.95rem;
    }

    .question-text {
      margin: 0;
      font-size: clamp(1.35rem, 2vw, 1.75rem);
      line-height: 1.7;
      color: var(--green-900);
      font-weight: 800;
    }

    .options-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .option-btn {
      display: flex;
      align-items: center;
      gap: 14px;
      min-height: 92px;
      padding: 16px 18px;
      border: 2px solid rgba(15, 183, 255, 0.16);
      border-radius: 8px;
      background: linear-gradient(180deg, rgba(255,255,255,0.99), rgba(242, 248, 255, 0.98));
      box-shadow: 0 12px 24px rgba(2, 16, 58, 0.06);
      text-align: left;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background 0.18s ease;
      color: var(--text);
    }

    .option-btn:hover:not(:disabled) {
      transform: translateY(-2px);
      border-color: rgba(255, 210, 60, 0.72);
      box-shadow: 0 18px 34px rgba(2, 16, 58, 0.12);
    }

    .option-btn:disabled {
      cursor: not-allowed;
      opacity: 0.7;
    }

    .option-btn.selected {
      border-color: rgba(255, 210, 60, 0.9);
      box-shadow: 0 18px 30px rgba(255, 174, 22, 0.18);
      transform: translateY(-1px);
    }

    .option-btn.correct {
      background: linear-gradient(180deg, rgba(231, 255, 240, 0.99), rgba(210, 248, 222, 0.98));
      border-color: rgba(32, 198, 107, 0.58);
    }

    .option-btn.wrong {
      background: linear-gradient(180deg, rgba(255, 240, 240, 0.98), rgba(255, 228, 228, 0.98));
      border-color: rgba(255, 88, 88, 0.4);
    }

    .option-btn.disabled {
      opacity: 0.68;
    }

    .option-label {
      width: 48px;
      height: 48px;
      flex-shrink: 0;
      display: grid;
      place-items: center;
      border-radius: 8px;
      background: linear-gradient(135deg, #fff47a, var(--gold-500) 50%, var(--gold-600));
      color: #062265;
      font-weight: 800;
      font-size: 1.1rem;
      box-shadow: 0 10px 20px rgba(255, 174, 22, 0.22);
    }

    .option-text {
      flex: 1;
      font-size: 1.05rem;
      font-weight: 700;
      line-height: 1.6;
      color: var(--green-900);
    }

    .side-stack {
      display: grid;
      gap: 18px;
    }

    .side-card {
      padding: 22px;
      border-radius: 8px;
      background: rgba(255,255,255,0.94);
      border: 1px solid rgba(114, 233, 255, 0.3);
      box-shadow: 0 18px 40px rgba(2, 16, 58, 0.1);
    }

    .prize-card {
      padding: 18px 18px 20px;
      background:
        radial-gradient(circle at 20% 12%, rgba(255,255,255,0.72), transparent 26%),
        linear-gradient(180deg, rgba(255, 253, 238, 0.98), rgba(231, 246, 255, 0.96));
      overflow: hidden;
      border: 2px solid rgba(255, 210, 60, 0.48);
    }

    .prize-visual {
      position: relative;
      display: grid;
      place-items: center;
      min-height: 210px;
      margin: -2px 0 8px;
    }

    .prize-visual::before {
      content: '';
      position: absolute;
      width: min(230px, 82%);
      aspect-ratio: 1;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 214, 92, 0.34), rgba(114, 233, 255, 0.2) 48%, transparent 70%);
      filter: blur(2px);
    }

    .prize-visual img {
      position: relative;
      z-index: 1;
      width: min(250px, 100%);
      height: auto;
      display: block;
      filter: drop-shadow(0 18px 26px rgba(2, 16, 58, 0.24));
    }

    .prize-copy {
      display: grid;
      gap: 8px;
      text-align: center;
    }

    .prize-kicker {
      justify-self: center;
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(255, 193, 7, 0.18);
      color: #8a5a00;
      font-weight: 800;
      font-size: 0.88rem;
    }

    .prize-copy h3 {
      margin: 0;
      color: var(--green-900);
      font-size: 1.16rem;
      font-weight: 800;
      line-height: 1.35;
    }

    .prize-copy p {
      margin: 0;
      color: var(--muted);
      font-weight: 700;
      line-height: 1.55;
    }

    .side-title {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 0 0 14px;
      color: var(--green-900);
      font-size: 1.05rem;
      font-weight: 800;
    }

    .side-title i {
      color: var(--green-700);
    }

    .hint-list {
      display: grid;
      gap: 12px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .hint-list li {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      padding: 12px 14px;
      border-radius: 8px;
      background: linear-gradient(135deg, rgba(15, 183, 255, 0.08), rgba(255, 210, 60, 0.14));
      color: var(--green-900);
      line-height: 1.6;
      font-weight: 600;
    }

    .hint-list i {
      color: var(--green-700);
      margin-top: 2px;
    }

    .result-area {
      padding: 24px;
    }

    .result-card {
      padding: 28px;
      border-radius: 8px;
      background:
        radial-gradient(circle at top right, rgba(255,255,255,0.18), transparent 28%),
        linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248, 252, 249, 0.98));
      border: 1px solid rgba(95, 196, 118, 0.18);
      box-shadow: 0 24px 50px rgba(8, 24, 14, 0.08);
      text-align: center;
    }

    .result-emoji {
      width: 88px;
      height: 88px;
      margin: 0 auto 16px;
      border-radius: 8px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, rgba(53, 181, 89, 0.14), rgba(127, 208, 141, 0.22));
      color: var(--green-700);
      font-size: 2.3rem;
    }

    .result-title {
      margin: 0 0 10px;
      font-size: 2rem;
      font-weight: 800;
      color: var(--green-900);
    }

    .result-message {
      margin: 0 0 22px;
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.75;
    }

    .result-actions {
      display: grid;
      gap: 10px;
      margin-top: 18px;
    }

    .btn-emerald {
      border: none;
      border-radius: 8px;
      padding: 14px 18px;
      font-weight: 800;
      color: #062265;
      background: linear-gradient(135deg, #fff47a 0%, var(--gold-500) 55%, var(--gold-600) 100%);
      box-shadow: 0 14px 28px rgba(255, 174, 22, 0.24);
    }

    .btn-emerald:hover {
      color: #062265;
    }

    .btn-outline-emerald {
      border-radius: 8px;
      border: 1px solid rgba(7, 91, 216, 0.34);
      color: var(--green-700);
      background: #fff;
      font-weight: 800;
      padding: 14px 18px;
    }

    .btn-outline-emerald:hover {
      background: rgba(53, 181, 89, 0.08);
      color: var(--green-900);
    }

    .hidden {
      display: none !important;
    }

    .answer-feedback {
      position: fixed;
      inset: 0;
      z-index: 30;
      display: grid;
      place-items: center;
      padding: 18px;
      background: rgba(3, 21, 66, 0.56);
      backdrop-filter: blur(8px);
    }

    .answer-feedback-card {
      position: relative;
      width: min(420px, 100%);
      padding: 30px 24px;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.52);
      background:
        radial-gradient(circle at top, rgba(255, 210, 60, 0.22), transparent 42%),
        linear-gradient(180deg, rgba(255,255,255,0.99), rgba(242, 248, 255, 0.98));
      box-shadow: 0 30px 80px rgba(2, 16, 58, 0.36);
      text-align: center;
      animation: feedbackPop 0.28s ease-out;
      overflow: hidden;
    }

    .answer-celebration {
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0;
    }

    .answer-feedback.is-correct .answer-celebration {
      opacity: 1;
    }

    .celebration-spark {
      position: absolute;
      display: grid;
      place-items: center;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: rgba(255, 214, 92, 0.22);
      color: #f59e0b;
      font-size: 1.08rem;
      animation: sparklePop 1.35s ease-in-out infinite;
    }

    .celebration-spark:nth-child(1) {
      top: 22px;
      left: 42px;
    }

    .celebration-spark:nth-child(2) {
      top: 32px;
      right: 44px;
      animation-delay: 0.18s;
    }

    .celebration-spark:nth-child(3) {
      right: 74px;
      bottom: 30px;
      animation-delay: 0.34s;
    }

    .celebration-spark:nth-child(4) {
      left: 74px;
      bottom: 34px;
      animation-delay: 0.5s;
    }

    .answer-feedback-icon {
      position: relative;
      z-index: 1;
      width: 88px;
      height: 88px;
      display: grid;
      place-items: center;
      margin: 0 auto 16px;
      border-radius: 8px;
      color: #fff;
      font-size: 2.4rem;
      box-shadow: 0 18px 36px rgba(8, 24, 14, 0.18);
    }

    .answer-feedback.is-correct .answer-feedback-icon {
      background: linear-gradient(135deg, #16a34a, #20c66b);
    }

    .answer-feedback.is-wrong .answer-feedback-icon {
      background: linear-gradient(135deg, #be123c, #fb7185);
    }

    .answer-feedback.is-timeout .answer-feedback-icon {
      background: linear-gradient(135deg, #b45309, #fbbf24);
    }

    .answer-feedback-title {
      position: relative;
      z-index: 1;
      margin: 0 0 8px;
      color: var(--green-900);
      font-size: 1.75rem;
      font-weight: 800;
      line-height: 1.3;
    }

    .answer-feedback-message {
      position: relative;
      z-index: 1;
      margin: 0;
      color: var(--muted);
      font-size: 1.05rem;
      font-weight: 700;
      line-height: 1.6;
    }

    .answer-feedback-button {
      position: relative;
      z-index: 1;
      min-width: 130px;
      margin-top: 18px;
      border: none;
      border-radius: 8px;
      padding: 12px 22px;
      background: linear-gradient(135deg, #fff47a 0%, var(--gold-500) 58%, var(--gold-600) 100%);
      color: #062265;
      font-weight: 800;
      box-shadow: 0 14px 28px rgba(255, 174, 22, 0.24);
    }

    .answer-feedback-button:focus {
      outline: none;
      box-shadow:
        0 14px 28px rgba(29, 110, 52, 0.22),
        0 0 0 4px rgba(53, 181, 89, 0.18);
    }

    .top-rank-popup {
      position: fixed;
      inset: 0;
      z-index: 42;
      display: grid;
      place-items: center;
      padding: 18px;
      background: rgba(3, 21, 66, 0.66);
      backdrop-filter: blur(10px);
    }

    .top-rank-card {
      position: relative;
      width: min(520px, 100%);
      padding: 34px 26px 28px;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.56);
      background:
        radial-gradient(circle at 20% 6%, rgba(255, 235, 153, 0.58), transparent 32%),
        radial-gradient(circle at 82% 12%, rgba(114, 233, 255, 0.42), transparent 28%),
        linear-gradient(180deg, rgba(255,255,255,0.99), rgba(242, 248, 255, 0.99));
      box-shadow: 0 34px 90px rgba(2, 16, 58, 0.4);
      text-align: center;
      overflow: hidden;
      animation: feedbackPop 0.32s ease-out;
    }

    .top-rank-icon {
      width: 112px;
      height: 112px;
      display: grid;
      place-items: center;
      margin: 0 auto 16px;
      border-radius: 8px;
      color: #062265;
      background: linear-gradient(135deg, #fff47a 0%, var(--gold-500) 45%, var(--gold-600) 100%);
      box-shadow: 0 18px 42px rgba(183, 121, 31, 0.26);
      font-size: 3rem;
    }

    .top-rank-title {
      margin: 0 0 8px;
      color: var(--green-900);
      font-size: clamp(1.85rem, 6vw, 2.65rem);
      font-weight: 800;
      line-height: 1.22;
    }

    .top-rank-number {
      margin: 8px 0;
      font-size: clamp(3.6rem, 14vw, 5.8rem);
      line-height: 1;
      font-weight: 800;
      background: linear-gradient(135deg, var(--gold-600), var(--green-700));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .top-rank-message {
      margin: 0 auto 20px;
      max-width: 390px;
      color: var(--muted);
      font-size: 1.08rem;
      font-weight: 700;
      line-height: 1.7;
    }

    .top-rank-ok {
      min-width: 150px;
      border: none;
      border-radius: 8px;
      padding: 14px 24px;
      color: #062265;
      font-weight: 800;
      background: linear-gradient(135deg, #fff47a 0%, var(--gold-500) 58%, var(--gold-600) 100%);
      box-shadow: 0 14px 28px rgba(255, 174, 22, 0.24);
    }

    .fade-in {
      animation: fadeIn 0.45s ease-out;
    }

    .spin-icon {
      animation: spin 1s linear infinite;
    }

    @keyframes floaty {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    @keyframes timerPulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.025); }
    }

    @keyframes timerWarningZoom {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.12); }
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes feedbackPop {
      from { opacity: 0; transform: translateY(12px) scale(0.96); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    @keyframes sparklePop {
      0%, 100% { transform: translateY(0) scale(0.86) rotate(0deg); opacity: 0.55; }
      50% { transform: translateY(-8px) scale(1.12) rotate(12deg); opacity: 1; }
    }

    @media (max-width: 992px) {
      .content-grid {
        grid-template-columns: 1fr;
      }

      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }

      .top-stats {
        justify-content: flex-start;
      }

      .prize-card {
        display: grid;
        grid-template-columns: minmax(130px, 0.8fr) minmax(0, 1fr);
        align-items: center;
        gap: 12px;
      }

      .prize-visual {
        min-height: 150px;
        margin: 0;
      }

      .prize-visual img {
        width: min(180px, 100%);
      }

      .prize-copy {
        text-align: left;
      }

      .prize-kicker {
        justify-self: start;
      }
    }

    @media (max-width: 768px) {
      .play-page {
        padding: 12px;
      }

      .panel-inner,
      .result-area,
      .side-card,
      .result-card,
      .question-card {
        padding-left: 18px;
        padding-right: 18px;
      }

      .options-grid {
        grid-template-columns: 1fr;
      }

      .question-banner {
        flex-direction: column;
        align-items: flex-start;
      }

      .timer-display {
        min-height: 48px;
      }

      .timer-robot {
        width: min(100%, 220px);
      }

      .result-title {
        font-size: 1.6rem;
      }

      .answer-feedback-card {
        padding: 26px 20px;
        border-radius: 8px;
      }

      .answer-feedback-title {
        font-size: 1.45rem;
      }

      .top-rank-card {
        padding: 30px 20px 24px;
        border-radius: 8px;
      }

      .prize-card {
        grid-template-columns: 1fr;
      }

      .prize-copy {
        text-align: center;
      }

      .prize-kicker {
        justify-self: center;
      }
    }

    @media (max-width: 640px) {
      body {
        background:
          radial-gradient(circle at 50% 0%, rgba(15, 183, 255, 0.3), transparent 36%),
          linear-gradient(135deg, var(--bg-1) 0%, var(--bg-2) 58%, var(--bg-3) 100%);
      }

      .play-page {
        padding: 8px;
      }

      .play-page::before,
      .orb,
      .side-stack,
      .brand-subtitle {
        display: none;
      }

      .game-shell,
      .content-grid {
        gap: 10px;
      }

      .topbar {
        flex-direction: row;
        align-items: center;
        padding: 10px;
        gap: 10px;
        border-radius: 8px;
      }

      .brand {
        gap: 10px;
      }

      .brand-mark {
        width: 42px;
        height: 42px;
        font-size: 1.12rem;
      }

      .brand-title {
        font-size: 1.02rem;
      }

      .top-stats {
        width: auto;
        display: grid;
        grid-template-columns: repeat(2, auto);
        gap: 8px;
        margin-left: auto;
      }

      .stat-pill {
        justify-content: center;
        min-height: 38px;
        padding: 7px 9px;
        font-size: 0.88rem;
        white-space: nowrap;
      }

      .panel {
        border-radius: 8px;
      }

      .panel-inner {
        padding: 10px;
      }

      .question-banner {
        flex-direction: row;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
        min-height: 52px;
        padding: 8px 10px;
        padding-right: 112px;
      }

      .question-progress,
      .question-tag {
        font-size: 0.9rem;
      }

      .question-tag {
        padding: 7px 9px;
        white-space: nowrap;
      }

      .timer-wrap {
        top: 4px;
        right: 10px;
        width: 104px;
      }

      .timer-display {
        min-height: 30px;
        padding: 3px 4px;
        border-radius: 6px;
      }

      .timer-robot {
        width: 96px;
      }

      .timer-label {
        display: none;
      }

      #timerText {
        min-width: 24px;
        font-size: 1.32rem;
      }

      .question-card {
        margin-bottom: 8px;
        padding: 10px 12px;
        padding-right: 12px;
        border-width: 2px;
      }

      .question-label {
        margin-bottom: 6px;
        padding: 6px 9px;
        font-size: 0.84rem;
      }

      .question-text {
        font-size: 1.14rem;
        line-height: 1.5;
      }

      .options-grid {
        gap: 6px;
      }

      .option-btn {
        min-height: 58px;
        gap: 9px;
        padding: 8px 10px;
        border-width: 2px;
      }

      .option-label {
        width: 36px;
        height: 36px;
        font-size: 0.94rem;
      }

      .option-text {
        font-size: 0.94rem;
        line-height: 1.36;
      }

      .player-intro,
      .loading-panel {
        min-height: calc(100dvh - 120px);
      }

      .player-card {
        padding: 18px;
      }

      .player-icon {
        width: 58px;
        height: 58px;
        margin-bottom: 12px;
        font-size: 1.55rem;
      }
    }

    @media (max-width: 380px) {
      .brand-title {
        display: none;
      }

      .topbar {
        padding: 8px;
      }

      .timer-display {
        min-height: 28px;
        gap: 2px;
      }

      .timer-robot {
        width: 84px;
      }

      #timerText {
        min-width: 22px;
        font-size: 1.16rem;
      }

      .question-text {
        font-size: 1.06rem;
      }

      .option-btn {
        min-height: 54px;
      }
    }
  </style>
</head>
<body>
  <div class="play-page">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="game-shell">
      <header class="topbar fade-in">
        <div class="brand">
          <div class="brand-mark">
            <i class="bi bi-controller"></i>
          </div>
          <div>
            <h1 class="brand-title">เกมตอบคำถามสหกรณ์</h1>
            <p class="brand-subtitle">ตอบให้ไว เก็บคะแนนให้สูง แล้วไปต่อให้ถึงรอบจบ</p>
          </div>
        </div>

        <div class="top-stats">
          <div class="stat-pill"><i class="bi bi-star-fill"></i> คะแนน <span id="score">0</span></div>
          <div class="stat-pill"><i class="bi bi-list-ol"></i> ข้อ <span id="questionNum">1</span></div>
        </div>
      </header>

      <div class="content-grid">
        <section class="panel fade-in">
          <div id="playerIntro" class="player-intro panel-inner hidden">
            <div class="player-card">
              <div class="player-icon">
                <i class="bi bi-person-vcard-fill"></i>
              </div>
              <h2 class="player-title">ข้อมูลผู้เล่น</h2>
              <p class="player-text">กรอกชื่อและเบอร์โทรศัพท์ก่อนเริ่มเกม ระบบจะใช้ข้อมูลนี้สำหรับบันทึกคะแนนและติดต่อผู้ชนะ</p>

              <form id="playerInfoForm" class="player-form">
                <div class="player-field">
                  <label for="playerName">ชื่อผู้เล่น</label>
                  <input
                    type="text"
                    id="playerName"
                    name="playerName"
                    placeholder="ใส่ชื่อของคุณ"
                    autocomplete="name"
                    required
                  >
                </div>

                <div class="player-field">
                  <label for="phoneNumber">เบอร์โทรศัพท์</label>
                  <input
                    type="tel"
                    id="phoneNumber"
                    name="phoneNumber"
                    placeholder="08xxxxxxxx"
                    inputmode="tel"
                    autocomplete="tel"
                    pattern="[0-9]{9,10}"
                    required
                  >
                </div>

                <button type="submit" class="btn btn-emerald">
                  <i class="bi bi-play-fill"></i> บันทึกและเริ่มตอบคำถาม
                </button>
              </form>

              <div id="playerInfoMessage" class="player-message" aria-live="polite"></div>
            </div>
          </div>

          <div id="loading" class="loading-panel panel-inner hidden">
            <div>
              <div class="loading-visual">
                <i class="bi bi-hourglass-split"></i>
              </div>
              <h2 class="loading-title">กำลังเตรียมคำถาม</h2>
              <p class="loading-text">ระบบกำลังโหลดคำถามสำหรับรอบนี้ โปรดรอสักครู่ แล้วจะพาคุณเข้าสู่เกมทันที</p>
            </div>
          </div>

          <div id="gameArea" class="panel-inner hidden">
            <div class="question-banner">
              <div class="question-progress">
                <i class="bi bi-flag-fill"></i>
                <span>คำถาม <span id="progressCurrent">1</span></span>
              </div>
            </div>

            <div class="timer-wrap" aria-label="เวลาที่เหลือ">
              <div class="robot-timer">
                <div class="timer-robot" aria-hidden="true">
                  <img src="/coopgame/assets/illustrations/robot-timer.png" alt="">
                  <div class="timer-display">
                    <div class="timer-label"><i class="bi bi-stopwatch-fill"></i> เวลาที่เหลือ</div>
                    <div class="timer-count"><span id="timerText">10</span><span class="timer-unit">วินาที</span></div>
                  </div>
                </div>
              </div>
            </div>

            <div class="question-card">
              <div class="question-label">
                <i class="bi bi-question-circle-fill"></i>
                <span>คำถาม</span>
              </div>
              <h2 id="questionText" class="question-text"></h2>
            </div>

            <div class="options-grid">
              <button class="option-btn" data-answer="A" id="btnA" type="button">
                <span class="option-label">ก</span>
                <span class="option-text" id="textA"></span>
              </button>
              <button class="option-btn" data-answer="B" id="btnB" type="button">
                <span class="option-label">ข</span>
                <span class="option-text" id="textB"></span>
              </button>
              <button class="option-btn" data-answer="C" id="btnC" type="button">
                <span class="option-label">ค</span>
                <span class="option-text" id="textC"></span>
              </button>
              <button class="option-btn" data-answer="D" id="btnD" type="button">
                <span class="option-label">ง</span>
                <span class="option-text" id="textD"></span>
              </button>
            </div>
          </div>

          <div id="resultArea" class="result-area hidden">
            <div class="result-card">
              <div class="result-emoji">
                <i class="bi bi-emoji-sunglasses-fill"></i>
              </div>
              <h2 id="resultTitle" class="result-title"></h2>
              <p id="resultMessage" class="result-message"></p>
              <div class="result-actions">
                <a href="/coopgame/game/finish?attemptId=<%= attemptId %>" class="btn btn-emerald" id="finishResultLink">
                  <i class="bi bi-clipboard2-check-fill"></i> ดูผลลัพธ์ท้ายเกม
                </a>
                <a href="/coopgame/game/start" class="btn btn-outline-emerald" id="playAgainLink">
                  <i class="bi bi-arrow-counterclockwise"></i> เล่นใหม่
                </a>
              </div>
            </div>
          </div>
        </section>

        <aside class="side-stack">
          <div class="side-card prize-card fade-in">
            <div class="prize-visual" aria-hidden="true">
              <img src="/coopgame/assets/rewards/prize-pile.png" alt="" loading="eager">
            </div>
            <div class="prize-copy">
              <div class="prize-kicker"><i class="bi bi-gift-fill"></i> ชิงรางวัล</div>
              <h3>ตอบให้ครบ ลุ้นรับของรางวัล</h3>
              <p>สะสมคะแนนให้ดีที่สุด แล้วไปดูผลท้ายเกม</p>
            </div>
          </div>

          <div class="side-card fade-in">
            <h3 class="side-title"><i class="bi bi-award-fill"></i> เคล็ดลับการเล่น</h3>
            <ul class="hint-list">
              <li><i class="bi bi-lightning-fill"></i> ตอบให้เร็วเพื่อรักษาเวลารวมให้น้อยที่สุด</li>
              <li><i class="bi bi-badge-ad-fill"></i> คำถามเรียงระดับจากง่ายไปยาก เล่นให้ต่อเนื่อง</li>
              <li><i class="bi bi-shield-check"></i> เลือกคำตอบแล้วระบบจะตรวจให้อัตโนมัติ</li>
            </ul>
          </div>

          <div class="side-card fade-in">
            <h3 class="side-title"><i class="bi bi-graph-up-arrow"></i> สถานะเกม</h3>
            <div class="d-grid gap-2">
              <div class="question-tag"><i class="bi bi-trophy-fill"></i> คะแนนสะสม <span id="scoreSide" class="ms-auto">0</span></div>
              <div class="question-tag"><i class="bi bi-list-check"></i> ข้อปัจจุบัน <span id="questionNumSide" class="ms-auto">1</span></div>
              <div class="question-tag"><i class="bi bi-stopwatch"></i> เวลาตอบ <span id="timerTextSide" class="ms-auto">10</span> วินาที</div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <div id="answerFeedback" class="answer-feedback hidden" role="status" aria-live="polite">
    <div class="answer-feedback-card">
      <div class="answer-celebration" aria-hidden="true">
        <span class="celebration-spark"><i class="bi bi-star-fill"></i></span>
        <span class="celebration-spark"><i class="bi bi-stars"></i></span>
        <span class="celebration-spark"><i class="bi bi-star-fill"></i></span>
        <span class="celebration-spark"><i class="bi bi-stars"></i></span>
      </div>
      <div class="answer-feedback-icon">
        <i id="answerFeedbackIcon" class="bi bi-check-lg"></i>
      </div>
      <h2 id="answerFeedbackTitle" class="answer-feedback-title"></h2>
      <p id="answerFeedbackMessage" class="answer-feedback-message"></p>
      <button id="answerFeedbackButton" class="answer-feedback-button hidden" type="button">OK</button>
    </div>
  </div>

  <div id="topRankPopup" class="top-rank-popup hidden" role="dialog" aria-modal="true" aria-labelledby="topRankTitle">
    <div class="top-rank-card">
      <div class="top-rank-icon">
        <i class="bi bi-trophy-fill"></i>
      </div>
      <h2 id="topRankTitle" class="top-rank-title">ยินดีด้วย!</h2>
      <div id="topRankNumber" class="top-rank-number">#1</div>
      <p id="topRankMessage" class="top-rank-message"></p>
      <button id="topRankOkBtn" class="top-rank-ok" type="button">OK</button>
    </div>
  </div>

  <script>
    const attemptId = <%= attemptId %>;
    const isAdminPlay = <%= isAdminPlay ? 'true' : 'false' %>;
    const gameEndRedirectUrl = isAdminPlay ? '/coopgame/admin' : '/coopgame/game/start';
    const initialPlayerName = <%- JSON.stringify(playerName || '') %>;
    const initialPhoneNumber = <%- JSON.stringify(phoneNumber || '') %>;
    let hasPlayerInfo = isAdminPlay || Boolean(initialPlayerName && initialPhoneNumber);
    let currentQuestion = null;
    let score = 0;
    let questionStartTime = 0;
    let timerInterval = null;
    let timeLeft = 0;
    let isAnswering = false;
    let gameCompleted = false;

    const correctFeedbackMessages = [
      { title: 'เยี่ยมมาก', message: 'ตอบถูกต้อง ไปต่อข้อถัดไปกันเลย' },
      { title: 'ถูกต้องครับ', message: 'จังหวะดีมาก รักษาฟอร์มนี้ไว้' },
      { title: 'เก่งมาก', message: 'คะแนนขยับแล้ว ลุยต่ออีกนิด' },
      { title: 'สุดยอด', message: 'คำตอบนี้ถูกต้องแบบไม่ต้องสงสัยเลย' },
      { title: 'ดีมาก', message: 'ตอบถูกต้องแล้ว ไปต่อกันเลย' },
      { title: 'เยี่ยม', message: 'คุณทำได้ดีมาก ยอดเยี่ยม!' },
      { title: 'ถูกต้อง', message: 'คำตอบนี้ถูกต้องแล้ว ไปต่อกันเลย' },
      { title: 'สุดยอด', message: 'คุณตอบถูกต้องได้อย่างยอดเยี่ยม!' },
      { title: 'ดีมาก', message: 'คำตอบนี้ถูกต้องแล้ว ไปต่อกันเลย' },
      { title: 'เยี่ยมมาก', message: 'คุณทำได้ดีมาก ยอดเยี่ยม!' },
      { title: 'สุดยอด', message: 'คุณตอบถูกต้องได้อย่างยอดเยี่ยม!' },
      { title: 'ดีมาก', message: 'คำตอบนี้ถูกต้องแล้ว ลุยต่อกันเลย' },
      { title: 'เยี่ยม', message: 'ว้าว คุณทำได้ เก่งมาก!' },
      { title: 'ถูกต้อง', message: 'คุณตอบถูกอีกแล้ว เจ๋งอ่ะ' },
      { title: 'สุดยอด', message: 'แน่มาก ตอบถูกอีกแล้ว!' },
      { title: 'สุดยอด', message: 'จะเก่งอะไรปานนี้' },
      { title: 'ว้าว ว้าว', message: 'เก่งสุดๆ' },
      { title: 'เยี่ยม', message: 'คุณคือคนคุณภาพ' }
    ];
    const wrongFeedbackMessages = [
      { title: 'เสียใจด้วยครับ', message: 'รอบนี้ยังไม่ใช่คำตอบที่ถูก ลองทดสอบอีกครั้งนะ' },
      { title: 'เอาใหม่นะ', message: 'คราวหน้ามีโอกาสทำได้ดีกว่านี้ สู้ ๆ' },
      { title: 'เกือบแล้ว', message: 'อย่าเพิ่งท้อ กลับมาเล่นใหม่แล้วลุยอีกครั้ง' },
      { title: 'ไม่ถูกต้อง', message: 'คำตอบนี้ไม่ถูกต้อง ลองทดสอบอีกครั้งนะ' },
      { title: 'เสียใจด้วย', message: 'รอบนี้ยังไม่ใช่คำตอบที่ถูก ลองทดสอบอีกครั้งนะ' },
      { title: 'เอาใหม่นะ', message: 'คราวหน้ามีโอกาสทำได้ดีกว่านี้ สู้ ๆ' },
      { title: 'เกือบแล้ว', message: 'อย่าเพิ่งท้อ กลับมาเล่นใหม่แล้วลุยอีกครั้ง' },
      { title: 'ไม่ถูกต้อง', message: 'คำตอบนี้ไม่ถูกต้อง ลองทดสอบอีกครั้งนะ' },
      { title: 'เสียใจด้วย', message: 'รอบนี้ยังไม่ใช่คำตอบที่ถูก ลองทดสอบอีกครั้งนะ' },
      { title: 'เอาใหม่นะ', message: 'คราวหน้ามีโอกาสทำได้ดีกว่านี้ สู้ ๆ' },
      { title: 'เกือบแล้ว', message: 'อย่าเพิ่งท้อ กลับมาเล่นใหม่แล้วลุยอีกครั้ง' }
    ];
    const timeoutFeedbackMessages = [
      { title: 'หมดเวลาแล้ว', message: 'ไม่เป็นไรนะ รอบหน้าลองตอบให้ไวขึ้นอีกนิด' },
      { title: 'เวลาไม่พอครับ', message: 'พักหายใจนิดหนึ่ง แล้วกลับมาสู้ใหม่ได้เลย' },
      { title: 'หมดเวลา', message: 'ไม่เป็นไรนะ รอบหน้าเอาใหม่' },
      { title: 'เวลาไม่พอ', message: 'ว้า เสียดายจังเลยเนาะ' },
      { title: 'หมดเวลาแล้ว', message: 'ไม่เป็นไรนะ รอบหน้าวางแผนให้ดีขึ้น' },
      { title: 'เวลาไม่พอครับ', message: 'เสียดายสุดๆ ใกล้มากแล้ว' },
      { title: 'หมดเวลา', message: 'ไม่เป็นไรนะ รอบหน้าเอาใหม่' },
      { title : 'เวลาไม่พอ', message: 'ถึงเวลาหมดแล้ว แต่อย่าพึ่งท้อ ลองใหม่อีกครั้ง' },
      { title: 'หมดเวลาแล้ว', message: 'เอาใหม่ ตอบให้ไวขึ้นอีกนิดนะ' },
      { title: 'เวลาไม่พอครับ', message: 'เสียดายสุดๆ ช้าไปนิดเดียวเอง' },
      
   
  
      
    ];

    const playerIntro = document.getElementById('playerIntro');
    const loadingPanel = document.getElementById('loading');
    const playerInfoForm = document.getElementById('playerInfoForm');
    const playerInfoMessage = document.getElementById('playerInfoMessage');
    const playerNameInput = document.getElementById('playerName');
    const phoneNumberInput = document.getElementById('phoneNumber');

    playerNameInput.value = initialPlayerName;
    phoneNumberInput.value = initialPhoneNumber;

    function replaceToGameEndUrl(url = gameEndRedirectUrl) {
      window.location.replace(url);
    }

    window.addEventListener('pageshow', (event) => {
      if (event.persisted && gameCompleted) {
        replaceToGameEndUrl();
      }
    });

    document.getElementById('finishResultLink')?.addEventListener('click', (event) => {
      event.preventDefault();
      gameCompleted = true;
      replaceToGameEndUrl(event.currentTarget.href);
    });

    document.getElementById('playAgainLink')?.addEventListener('click', (event) => {
      event.preventDefault();
      gameCompleted = true;
      replaceToGameEndUrl('/coopgame/game/start');
    });

    if (hasPlayerInfo) {
      if (isAdminPlay) {
        document.getElementById('gameArea').insertAdjacentHTML(
          'beforebegin',
          '<div class="panel-inner" style="padding-top:0"><div class="question-tag" style="margin-bottom:14px"><i class="bi bi-shield-check"></i> โหมดทดสอบผู้ดูแล: ไม่ต้องกรอกชื่อหรือเบอร์ และไม่ถูกนำไปจัดอันดับ</div></div>'
        );
      }
      showLoadingPanel();
      loadQuestion();
    } else {
      showPlayerIntro();
    }

    function showPlayerIntro(message = '') {
      if (isAdminPlay) {
        showLoadingPanel();
        loadQuestion();
        return;
      }
      playerIntro.classList.remove('hidden');
      loadingPanel.classList.add('hidden');
      document.getElementById('gameArea').classList.add('hidden');
      playerInfoMessage.textContent = message;
      setTimeout(() => playerNameInput.focus(), 50);
    }

    function showLoadingPanel() {
      playerIntro.classList.add('hidden');
      loadingPanel.classList.remove('hidden');
    }

    playerInfoForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const playerName = playerNameInput.value.trim();
      const phoneNumber = phoneNumberInput.value.replace(/[^\d]/g, '');
      const submitBtn = playerInfoForm.querySelector('button[type="submit"]');

      if (!playerName) {
        playerInfoMessage.textContent = 'กรุณากรอกชื่อผู้เล่น';
        return;
      }

      if (!/^\d{9,10}$/.test(phoneNumber)) {
        playerInfoMessage.textContent = 'กรุณากรอกเบอร์โทรศัพท์ 9-10 หลัก';
        return;
      }

      phoneNumberInput.value = phoneNumber;
      submitBtn.disabled = true;
      playerInfoMessage.textContent = 'กำลังบันทึกข้อมูลผู้เล่น...';

      try {
        const response = await fetch('/coopgame/game/api/player-info', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ attemptId, playerName, phoneNumber })
        });
        const result = await response.json();

        if (result.success) {
          hasPlayerInfo = true;
          playerInfoMessage.textContent = '';
          showLoadingPanel();
          loadQuestion();
        } else {
          const errorText = (result.errors && result.errors[0] && result.errors[0].msg)
            || result.message
            || 'ไม่สามารถบันทึกข้อมูลผู้เล่นได้';
          playerInfoMessage.textContent = errorText;
        }
      } catch (error) {
        console.error('Error saving player info:', error);
        playerInfoMessage.textContent = 'เกิดข้อผิดพลาด กรุณาลองใหม่';
      } finally {
        submitBtn.disabled = false;
      }
    });

    async function loadQuestion() {
      try {
        const response = await fetch(`/coopgame/game/api/question?attemptId=${attemptId}`);
        const result = await response.json();

        if (result.success && result.data && result.data.question) {
          displayQuestion(result.data.question);
        } else {
          if (result.errorCode === 'PLAYER_INFO_REQUIRED') {
            hasPlayerInfo = false;
            showPlayerIntro(result.message || 'กรุณากรอกชื่อและเบอร์โทรศัพท์ก่อนเริ่มเกม');
            return;
          }
          gameCompleted = true;
          replaceToGameEndUrl(`/coopgame/game/finish?attemptId=${attemptId}`);
        }
      } catch (error) {
        console.error('Error loading question:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
        replaceToGameEndUrl('/coopgame/game/start');
      }
    }

    function updateSharedStats() {
      const scoreEl = document.getElementById('score');
      const scoreSideEl = document.getElementById('scoreSide');
      const questionNumEl = document.getElementById('questionNum');
      const questionNumSideEl = document.getElementById('questionNumSide');
      const timerTextSideEl = document.getElementById('timerTextSide');

      if (scoreEl) scoreEl.textContent = score;
      if (scoreSideEl) scoreSideEl.textContent = score;
      if (questionNumEl && currentQuestion) questionNumEl.textContent = currentQuestion.questionNumber || 1;
      if (questionNumSideEl && currentQuestion) questionNumSideEl.textContent = currentQuestion.questionNumber || 1;
      if (timerTextSideEl) timerTextSideEl.textContent = timeLeft || 0;
    }

    function getRandomItem(items) {
      return items[Math.floor(Math.random() * items.length)];
    }

    function showAnswerFeedback(type, options = {}) {
      const duration = options.duration || 2100;
      const actionLabel = options.actionLabel || '';
      const feedback = document.getElementById('answerFeedback');
      const title = document.getElementById('answerFeedbackTitle');
      const message = document.getElementById('answerFeedbackMessage');
      const icon = document.getElementById('answerFeedbackIcon');
      const button = document.getElementById('answerFeedbackButton');
      const feedbackMap = {
        correct: {
          className: 'is-correct',
          iconClass: 'bi bi-check-lg',
          text: getRandomItem(correctFeedbackMessages)
        },
        wrong: {
          className: 'is-wrong',
          iconClass: 'bi bi-heartbreak-fill',
          text: getRandomItem(wrongFeedbackMessages)
        },
        timeout: {
          className: 'is-timeout',
          iconClass: 'bi bi-hourglass-split',
          text: getRandomItem(timeoutFeedbackMessages)
        }
      };
      const config = feedbackMap[type] || feedbackMap.wrong;

      feedback.className = `answer-feedback ${config.className}`;
      icon.className = config.iconClass;
      title.textContent = config.text.title;
      message.textContent = config.text.message;
      button.textContent = actionLabel || 'OK';
      button.classList.toggle('hidden', !actionLabel);
      button.onclick = null;

      return new Promise(resolve => {
        if (actionLabel) {
          button.onclick = () => {
            feedback.classList.add('hidden');
            button.classList.add('hidden');
            button.onclick = null;
            resolve();
          };
          setTimeout(() => button.focus(), 50);
          return;
        }

        window.setTimeout(() => {
          feedback.classList.add('hidden');
          resolve();
        }, duration);
      });
    }

    function isTopThreeRank(rankValue) {
      const rankNumber = Number(rankValue);
      return !isAdminPlay && Number.isInteger(rankNumber) && rankNumber >= 1 && rankNumber <= 3;
    }

    function showTopRankPopup(rankValue) {
      const rankNumber = Number(rankValue);
      const popup = document.getElementById('topRankPopup');
      const rankNumberEl = document.getElementById('topRankNumber');
      const messageEl = document.getElementById('topRankMessage');
      const okBtn = document.getElementById('topRankOkBtn');

      rankNumberEl.textContent = `#${rankNumber}`;
      messageEl.textContent = `ตอนนี้คุณมีคะแนนอยู่ในอันดับ ${rankNumber} ของกระดานผู้นำ เก่งมากครับ!`;
      popup.classList.remove('hidden');

      return new Promise(resolve => {
        okBtn.onclick = () => {
          popup.classList.add('hidden');
          okBtn.onclick = null;
          resolve();
        };
        setTimeout(() => okBtn.focus(), 50);
      });
    }

    function displayQuestion(question) {
      currentQuestion = question;
      isAnswering = false;

      document.getElementById('loading').classList.add('hidden');
      document.getElementById('gameArea').classList.remove('hidden');
      document.getElementById('resultArea').classList.add('hidden');

      document.getElementById('questionText').textContent = question.text;
      document.getElementById('textA').textContent = question.options.A;
      document.getElementById('textB').textContent = question.options.B;
      document.getElementById('textC').textContent = question.options.C;
      document.getElementById('textD').textContent = question.options.D;
      document.getElementById('progressCurrent').textContent = question.questionNumber;

      timeLeft = question.timeLimit;
      document.getElementById('timerText').textContent = timeLeft;
      document.getElementById('timerTextSide').textContent = timeLeft;
      const timerWrap = document.querySelector('.timer-wrap');
      if (timerWrap) {
        timerWrap.classList.remove('timer-warning', 'timer-critical');
      }

      startTimer(question.timeLimit);

      document.querySelectorAll('.option-btn').forEach(btn => {
        btn.disabled = false;
        btn.classList.remove('correct', 'wrong', 'disabled', 'selected');
      });

      questionStartTime = Date.now();
      isAnswering = true;
      updateSharedStats();
    }

    function startTimer(seconds) {
      if (timerInterval) clearInterval(timerInterval);

      timerInterval = setInterval(() => {
        timeLeft--;
        document.getElementById('timerText').textContent = timeLeft;
        document.getElementById('timerTextSide').textContent = timeLeft;

        const timerWrap = document.querySelector('.timer-wrap');
        if (timerWrap) {
          timerWrap.classList.toggle('timer-warning', timeLeft <= 5 && timeLeft > 3);
          timerWrap.classList.toggle('timer-critical', timeLeft <= 3);
        }

        if (timeLeft <= 0) {
          clearInterval(timerInterval);
          handleTimeout();
        }
      }, 1000);
    }

    function handleTimeout() {
      if (!isAnswering) return;
      isAnswering = false;
      submitAnswer(null, currentQuestion.timeLimit);
    }

    function handleAnswer(answer) {
      if (!isAnswering) return;
      isAnswering = false;

      clearInterval(timerInterval);
      const responseTime = Math.round((Date.now() - questionStartTime) / 1000);

      submitAnswer(answer, responseTime);
    }

    async function submitAnswer(answer, responseTime) {
      document.querySelectorAll('.option-btn').forEach(btn => {
        btn.disabled = true;
        btn.classList.add('disabled');
      });

      try {
        const response = await fetch('/coopgame/game/api/answer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            attemptId: attemptId,
            questionId: currentQuestion.id,
            answer: answer,
            responseTime: responseTime
          })
        });

        const result = await response.json();

        if (!result.success) {
          alert(result.errors?.[0]?.msg || result.message || 'เกิดข้อผิดพลาด กรุณาลองใหม่');
          replaceToGameEndUrl();
        } else if (result.data && result.data.gameOver) {
          gameCompleted = true;
          const resultData = result.data;
          const feedbackType = resultData.reason === 'timeout'
            ? 'timeout'
            : resultData.isCorrect ? 'correct' : 'wrong';
          if (isAdminPlay) {
            await showAnswerFeedback(feedbackType, { actionLabel: 'OK' });
            replaceToGameEndUrl();
            return;
          }

          if (!resultData.isCorrect || resultData.reason === 'timeout') {
            await showAnswerFeedback(feedbackType, { actionLabel: 'OK' });
            if (isTopThreeRank(resultData.rank)) {
              await showTopRankPopup(resultData.rank);
            }
            replaceToGameEndUrl();
            return;
          }

          await showAnswerFeedback(feedbackType);
          if (isTopThreeRank(resultData.rank)) {
            await showTopRankPopup(resultData.rank);
            replaceToGameEndUrl();
            return;
          }
          showGameOver(resultData);
        } else if (result.success && result.data) {
          if (result.data.isCorrect) {
            score++;
            updateSharedStats();
            await showAnswerFeedback('correct');
          }
          loadQuestion();
        } else {
          alert(result.message);
          replaceToGameEndUrl();
        }
      } catch (error) {
        console.error('Error submitting answer:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
        replaceToGameEndUrl();
      }
    }

    function showGameOver(result) {
      document.getElementById('gameArea').classList.add('hidden');
      document.getElementById('resultArea').classList.remove('hidden');

      const title = document.getElementById('resultTitle');
      const message = document.getElementById('resultMessage');
      const emoji = document.querySelector('#resultArea .result-emoji i');

      if (result.reason === 'timeout') {
        title.textContent = 'หมดเวลาแล้ว';
        message.textContent = `คุณตอบถูก ${result.finalScore} ข้อ อย่าเพิ่งท้อ ลองใหม่เพื่อทำคะแนนให้สูงขึ้น`;
        if (emoji) emoji.className = 'bi bi-hourglass-split';
      } else if (!result.isCorrect) {
        title.textContent = 'ตอบผิด';
        message.textContent = `คุณตอบถูก ${result.finalScore} ข้อ แต่ยังเล่นใหม่เพื่อไต่คะแนนได้อีก`;
        if (emoji) emoji.className = 'bi bi-x-circle-fill';
      } else {
        title.textContent = 'ผ่านทุกข้อ';
        message.textContent = `คุณตอบถูก ${result.finalScore} ข้อ ใช้เวลารวม ${result.totalTime} วินาที`;
        if (emoji) emoji.className = 'bi bi-trophy-fill';
      }
    }

    document.querySelectorAll('.option-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!isAnswering) return;

        document.querySelectorAll('.option-btn').forEach(item => item.classList.remove('selected'));
        btn.classList.add('selected');
        const answer = btn.dataset.answer;
        handleAnswer(answer);
      });
    });
  </script>
</body>
</html>
