<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - เกมตอบคำถามสหกรณ์</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/coopgame/css/styles.css">
  <link rel="stylesheet" href="/coopgame/css/start.css">
</head>
<body>
  <div class="start-page">
    <div class="start-orb start-orb-1"></div>
    <div class="start-orb start-orb-2"></div>

    <main class="start-main container-fluid px-3 px-lg-4 py-4 py-lg-5">
      <div class="start-layout">
        <section class="hero-panel">
          <div class="hero-badge">
            <i class="bi bi-stars"></i>
            <span>เกมตอบคำถามสหกรณ์</span>
          </div>

          <h1 class="hero-title">
            <span class="hero-title-line">พร้อมเริ่มแล้ว</span>
          </h1>

          <p class="hero-description">
            ใส่รหัสเกมเพื่อเข้าร่วมการแข่งขัน ตอบให้ไว เก็บคะแนนให้สูง และพาอันดับของคุณพุ่งขึ้นไปบนกระดานผู้นำ
          </p>

          <div class="hero-stats">
            <div class="hero-stat">
              <i class="bi bi-trophy-fill"></i>
              <div>
                <strong>แข่งขันจริง</strong>
                <span>ลุ้นคะแนนสูงสุด</span>
              </div>
            </div>
            <div class="hero-stat">
              <i class="bi bi-stopwatch-fill"></i>
              <div>
                <strong>จับเวลา</strong>
                <span>ทุกข้อมีเวลาจำกัด</span>
              </div>
            </div>
            <div class="hero-stat">
              <i class="bi bi-collection-play-fill"></i>
              <div>
                <strong>4 ตัวเลือก</strong>
                <span>ก ข ค ง ให้เลือกตอบ</span>
              </div>
            </div>
          </div>

          <div class="hero-features">
            <div class="feature-chip"><i class="bi bi-lightning-charge-fill"></i> เล่นไว</div>
            <div class="feature-chip"><i class="bi bi-award-fill"></i> ได้คะแนน</div>
            <div class="feature-chip"><i class="bi bi-people-fill"></i> แข่งกับเพื่อน</div>
            <div class="feature-chip"><i class="bi bi-graph-up-arrow"></i> ดูอันดับได้</div>
          </div>

          <div class="rules-grid">
            <article class="rule-card">
              <div class="rule-icon"><i class="bi bi-key-fill"></i></div>
              <h3>กรอกรหัสเกม</h3>
              <p>ใช้รหัส 6 ตัวอักษรที่ได้รับจากผู้ดูแลระบบ</p>
            </article>
            <article class="rule-card">
              <div class="rule-icon"><i class="bi bi-brightness-high-fill"></i></div>
              <h3>ตอบให้ทันเวลา</h3>
              <p>แต่ละระดับมีเวลาต่างกัน ตอบเร็วช่วยรักษาคะแนน</p>
            </article>
            <article class="rule-card">
              <div class="rule-icon"><i class="bi bi-emoji-sunglasses-fill"></i></div>
              <h3>สนุกและท้าทาย</h3>
              <p>คำถามเรียงจากง่ายไปยาก ให้เล่นลื่นและค่อย ๆ ไต่ระดับ</p>
            </article>
          </div>

          <div class="leader-preview">
            <div class="leader-preview-head">
              <div>
                <h3><i class="bi bi-trophy-fill"></i> กระดานผู้นำล่าสุด</h3>
                <p>ดู 3 อันดับแรกก่อนเริ่มเล่น</p>
              </div>
              <a href="/coopgame/game/leaderboard" class="leader-preview-link">
                ดูทั้งหมด <i class="bi bi-arrow-right"></i>
              </a>
            </div>
            <div id="leaderboardPreview" class="leader-preview-list">
              <div class="leader-preview-loading">
                <i class="bi bi-arrow-repeat spin-icon"></i>
                <span>กำลังโหลดข้อมูลอันดับ...</span>
              </div>
            </div>
          </div>

          <footer class="start-footer">
            <span><i class="bi bi-c-circle"></i> 2026 naimet</span>
          </footer>
        </section>

        <section class="start-card" aria-labelledby="startTitle">
          <div class="start-card-header">
            <div class="start-card-icon">
              <i class="bi bi-controller"></i>
            </div>
            <div>
              <h2 id="startTitle">เริ่มเกม</h2>
              <p>กรอกรหัสเพื่อเข้าสู่รอบแข่งขัน</p>
            </div>
          </div>

          <% if (typeof query !== 'undefined' && query.system) { %>
            <div class="system-banner">
              <i class="bi bi-broadcast-pin"></i>
              <span>คุณมาเริ่มจากระบบ: <strong><%= query.system %></strong></span>
            </div>
          <% } %>

          <form id="codeForm" class="code-form" aria-describedby="codeHelp">
            <label for="code" class="form-label">
              <i class="bi bi-key-fill"></i> รหัสเกม
            </label>
            <div class="code-field">
              <span class="code-prefix"><i class="bi bi-shield-lock-fill"></i></span>
              <input
                type="text"
                id="code"
                name="code"
                class="form-control code-input"
                maxlength="6"
                placeholder="ABC123"
                inputmode="search"
                autocomplete="off"
                aria-labelledby="codeHelp"
                required
              />
            </div>
            <div id="codeHelp" class="form-text">
              รหัสเป็นตัวอักษร/ตัวเลข 6 ตัว พิมพ์เล็กหรือใหญ่ได้ ระบบจะปรับให้อัตโนมัติ
            </div>

            <button type="submit" class="btn start-btn w-100">
              <i class="bi bi-play-fill"></i> เริ่มเล่นเกม
            </button>
          </form>

          <div id="message" class="message-slot" aria-live="polite"></div>

          <div class="start-note">
            <i class="bi bi-info-circle-fill"></i>
            <span>ถ้ายังไม่มีรหัส กรุณาติดต่อผู้ดูแลระบบก่อนเริ่มเล่น</span>
          </div>
        </section>
      </div>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const codeForm = document.getElementById('codeForm');
    const codeInput = document.getElementById('code');
    const messageDiv = document.getElementById('message');

    function showMessage(type, icon, text) {
      messageDiv.innerHTML = `
        <div class="alert alert-${type} d-flex align-items-center start-alert" role="alert">
          <i class="bi ${icon} me-2"></i>
          <div>${text}</div>
        </div>
      `;
    }

    codeForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const code = codeInput.value.trim().toUpperCase();
      if (!code) {
        showMessage('danger', 'bi-exclamation-triangle-fill', 'กรุณากรอกรหัสเกม');
        return;
      }

      codeInput.value = code;
      codeForm.querySelector('button[type="submit"]').disabled = true;
      showMessage('info', 'bi-arrow-repeat spin-icon', 'กำลังตรวจสอบรหัส...');

      try {
        const response = await fetch('/coopgame/game/verify-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code })
        });

        const result = await response.json();

        if (result.success) {
          showMessage('success', 'bi-check-circle-fill', 'ตรวจสอบรหัสสำเร็จ กำลังพาเข้าสู่เกม...');
          setTimeout(() => {
            window.location.href = `/coopgame/game/play?attemptId=${result.data.attemptId}`;
          }, 650);
        } else {
          showMessage('danger', 'bi-x-circle-fill', result.message || 'รหัสไม่ถูกต้อง');
        }
      } catch (error) {
        console.error('Error verifying code:', error);
        showMessage('danger', 'bi-exclamation-octagon-fill', 'เกิดข้อผิดพลาด กรุณาลองใหม่');
      } finally {
        codeForm.querySelector('button[type="submit"]').disabled = false;
      }
    });

    codeInput.addEventListener('input', function () {
      this.value = this.value.toUpperCase();
    });

    codeInput.focus();

    async function loadLeaderboardPreview() {
      const preview = document.getElementById('leaderboardPreview');

      try {
        const response = await fetch('/coopgame/game/api/leaderboard?limit=3');
        const result = await response.json();

        if (!result.success || !Array.isArray(result.data) || result.data.length === 0) {
          preview.innerHTML = `
            <div class="leader-preview-empty">
              <i class="bi bi-emoji-smile"></i>
              <span>ยังไม่มีข้อมูลอันดับ</span>
            </div>
          `;
          return;
        }

        preview.innerHTML = result.data.map((entry) => `
          <div class="leader-preview-item ${entry.rank <= 3 ? 'top-' + entry.rank : ''}">
            <div class="leader-rank">${entry.rank}</div>
            <div class="leader-meta">
              <div class="leader-name">${escapeHtml(entry.playerName || 'ไม่ระบุชื่อ')}</div>
              <div class="leader-sub">
                <span><i class="bi bi-star-fill"></i> ${entry.score || 0} ข้อ</span>
                <span><i class="bi bi-stopwatch"></i> ${entry.totalTime || 0} วินาที</span>
              </div>
            </div>
          </div>
        `).join('');
      } catch (error) {
        console.error('Error loading leaderboard preview:', error);
        preview.innerHTML = `
          <div class="leader-preview-empty">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>ไม่สามารถโหลดกระดานผู้นำได้</span>
          </div>
        `;
      }
    }

    function escapeHtml(text) {
      return String(text)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    loadLeaderboardPreview();
  </script>
</body>
</html>
