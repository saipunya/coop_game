<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - เกมตอบคำถามสหกรณ์</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/coopgame/css/styles.css">
  <link rel="stylesheet" href="/coopgame/css/start.css">
</head>
<body>
  <% const isGameOpen = typeof gameEnabled === 'undefined' || gameEnabled !== false; %>
  <div class="start-shell">
    <a href="/coopgame/admin/login" class="admin-float-link" aria-label="เข้าสู่ระบบผู้ดูแล">
      <i data-lucide="shield-check"></i>
      <span>Admin</span>
    </a>

    <main class="game-lobby">
      <section class="hero-card">
        <div class="hero-copy">
          <div class="hero-badge">
            <span class="coop-mark">สหกรณ์เข้มแข็ง</span>
            <span>ตอบไว ได้คะแนน</span>
          </div>
          <h1>เกมตอบไว<br><span>ไต่แรงขึ้นอันดับสหกรณ์</span></h1>
          <p>สนุกกับการตอบคำถาม สะสมคะแนน แข่งกับเวลา และลุ้นขึ้นตารางอันดับไปด้วยกัน</p>

          <div class="hero-actions">
            <a href="#startCard" class="hero-link primary">
              <i data-lucide="zap"></i>
              <span>เริ่มเลย</span>
            </a>
            <a href="/coopgame/game/leaderboard" class="hero-link">
              <i data-lucide="trophy"></i>
              <span>ดูอันดับ</span>
            </a>
            <a href="/coopgame/admin/login" class="hero-link">
              <i data-lucide="shield-check"></i>
              <span>เข้าสู่ระบบแอดมิน</span>
            </a>
          </div>

          <div class="feature-rail" aria-label="จุดเด่นเกม">
            <div class="feature-pill blue">
              <i data-lucide="timer"></i>
              <strong>ตอบเร็ว</strong>
              <span>ลุ้นทุกข้อ</span>
            </div>
            <div class="feature-pill green">
              <i data-lucide="trending-up"></i>
              <strong>เก็บแต้ม</strong>
              <span>ไต่อันดับ</span>
            </div>
            <div class="feature-pill violet">
              <i data-lucide="book-open-check"></i>
              <strong>ได้ความรู้</strong>
              <span>เรื่องสหกรณ์</span>
            </div>
          </div>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <div class="lightning lightning-one"></div>
          <div class="lightning lightning-two"></div>
          <div class="phone-mock">
            <div class="phone-top">
              <span><i data-lucide="zap"></i> 12.58</span>
              <strong>คะแนน 1,250</strong>
            </div>
            <div class="question-mini">
              <small>คำถามข้อที่ 5/10</small>
              <h2>สหกรณ์คืออะไร?</h2>
              <div>A องค์กรธุรกิจ</div>
              <div>B องค์กรของรัฐบาล</div>
              <div class="correct">C องค์กรที่สมาชิกเป็นเจ้าของ <i data-lucide="check"></i></div>
              <div>D บริษัทเอกชน</div>
            </div>
            <div class="phone-score">ตอบถูกต้อง! +100 คะแนน</div>
          </div>
          <div class="trophy-panel">
            <div class="leader-title"><i data-lucide="trophy"></i> ตารางคะแนน</div>
            <div class="leader-row"><span>1</span><strong>คุณดาวเด่น</strong><em>2,560</em></div>
            <div class="leader-row"><span>2</span><strong>คุณกล้าเก่ง</strong><em>2,100</em></div>
            <div class="leader-row active"><span>3</span><strong>คุณร่วมใจ</strong><em>1,250</em></div>
            <img src="/coopgame/assets/rewards/prize-pile.png" alt="">
          </div>
          <div class="score-chip chip-one"><i data-lucide="sparkles"></i> Rank up</div>
          <div class="score-chip chip-two"><i data-lucide="star"></i> Bonus</div>
        </div>
      </section>

      <section class="lobby-grid">
        <div class="main-stack">
          <section class="mobile-prize-banner" aria-label="เล่นเกมลุ้นรางวัล">
            <div class="mobile-prize-copy">
              <span>เกมตอบคำถามสหกรณ์</span>
              <strong>ใส่รหัสแล้วลุ้นอันดับ</strong>
            </div>
            <img src="/coopgame/assets/rewards/prize-pile.png" alt="รางวัลสำหรับผู้เล่นเกม">
          </section>

          <article id="startCard" class="game-card start-card" aria-labelledby="startTitle">
            <div class="card-heading">
              <span class="card-icon"><i data-lucide="key-round"></i></span>
              <div>
                <h2 id="startTitle">ใส่รหัสเพื่อเข้าเกม</h2>
                <p>รหัส 6 ตัวอักษร/ตัวเลขจากผู้ดูแลระบบ</p>
              </div>
            </div>

            <% if (typeof query !== 'undefined' && query.system) { %>
              <div class="system-banner">
                <i data-lucide="message-circle"></i>
                <span>เริ่มจากระบบ: <strong><%= query.system %></strong></span>
              </div>
            <% } %>

            <% if (!isGameOpen) { %>
              <div class="system-banner closed">
                <i data-lucide="power"></i>
                <span>ระบบเกมปิดอยู่ชั่วคราว กรุณาติดต่อผู้ดูแลระบบ</span>
              </div>
            <% } %>

            <form id="codeForm" class="code-form" aria-describedby="codeHelp">
              <label for="code" class="field-label">รหัสเกม</label>
              <div class="code-field">
                <span class="code-prefix"><i data-lucide="shield-check"></i></span>
                <input
                  type="text"
                  id="code"
                  name="code"
                  class="form-control code-input"
                  maxlength="6"
                  placeholder="ABC123"
                  inputmode="search"
                  autocomplete="off"
                  aria-labelledby="codeHelp"
                  <%= !isGameOpen ? 'disabled' : '' %>
                  required
                />
              </div>
              <div id="codeHelp" class="field-help">
                พิมพ์เล็กหรือใหญ่ได้ ระบบจะปรับให้อัตโนมัติ
              </div>

              <button type="submit" class="start-btn" <%= !isGameOpen ? 'disabled' : '' %>>
                <i data-lucide="play"></i>
                <span><%= isGameOpen ? 'เริ่มเล่นเกม' : 'ระบบเกมปิดอยู่' %></span>
              </button>
            </form>

            <div id="message" class="message-slot" aria-live="polite"></div>
          </article>

          <section class="mission-grid" aria-label="ภาพรวมเกม">
            <article class="mission-card">
              <i data-lucide="users"></i>
              <span>ผู้เล่นล่าสุด</span>
              <strong id="statPlayers">-</strong>
            </article>
            <article class="mission-card">
              <i data-lucide="clipboard-list"></i>
              <span>สถานะคำถาม</span>
              <strong id="statQuestions">-</strong>
            </article>
            <article class="mission-card">
              <i data-lucide="badge-check"></i>
              <span>รอบสำเร็จ</span>
              <strong id="statCompleted">-</strong>
            </article>
          </section>
        </div>

        <aside class="side-stack">
          <article class="game-card rules-card">
            <div class="card-heading compact">
              <span class="card-icon soft"><i data-lucide="gamepad-2"></i></span>
              <div>
                <h2>กติกาเร็ว ๆ</h2>
                <p>เตรียมตัวก่อนเริ่มรอบ</p>
              </div>
            </div>
            <div class="rules-list">
              <div><i data-lucide="qr-code"></i><span>สแกน QR หรือกรอกรหัสเกม</span></div>
              <div><i data-lucide="timer"></i><span>แต่ละข้อมีเวลาจำกัด</span></div>
              <div><i data-lucide="party-popper"></i><span>ตอบถูกลุ้นคะแนนและอันดับ</span></div>
            </div>
          </article>

          <article class="game-card scoreboard-card">
            <div class="recent-head">
              <div>
                <h2>อันดับผู้เล่นล่าสุด</h2>
                <p>อันดับผู้เล่นที่บันทึกผลแล้ว</p>
              </div>
              <a href="/coopgame/game/leaderboard">ทั้งหมด</a>
            </div>
            <div id="leaderboardPreview" class="activity-list">
              <div class="activity-loading">
                <i data-lucide="loader-circle"></i>
                <span>กำลังโหลดอันดับ...</span>
              </div>
            </div>
          </article>
        </aside>
      </section>

      <footer class="start-footer">
        <span>Illustrations by Storyset by Freepik</span>
        <span>© 2026 naimet</span>
      </footer>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script>
    const codeForm = document.getElementById('codeForm');
    const codeInput = document.getElementById('code');
    const messageDiv = document.getElementById('message');
    const gameEnabled = <%= isGameOpen ? 'true' : 'false' %>;

    function renderIcons() {
      if (window.lucide) {
        window.lucide.createIcons({
          attrs: {
            'stroke-width': 2,
            'aria-hidden': 'true'
          }
        });
      }
    }

    function showMessage(type, icon, text) {
      messageDiv.innerHTML = `
        <div class="start-alert ${type}" role="alert">
          <i data-lucide="${icon}"></i>
          <span>${text}</span>
        </div>
      `;
      renderIcons();
    }

    codeForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!gameEnabled) {
        showMessage('error', 'power', 'ระบบเกมปิดอยู่ชั่วคราว กรุณาติดต่อผู้ดูแลระบบ');
        return;
      }

      const code = codeInput.value.trim().toUpperCase();
      if (!code) {
        showMessage('error', 'circle-alert', 'กรุณากรอกรหัสเกม');
        return;
      }

      codeInput.value = code;
      codeForm.querySelector('button[type="submit"]').disabled = true;
      showMessage('info', 'loader-circle', 'กำลังตรวจสอบรหัส...');

      try {
        const response = await fetch('/coopgame/game/verify-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code })
        });

        const result = await response.json();

        if (result.success) {
          showMessage('success', 'circle-check', 'ตรวจสอบรหัสสำเร็จ กำลังพาเข้าสู่เกม...');
          setTimeout(() => {
            window.location.href = `/coopgame/game/play?attemptId=${result.data.attemptId}`;
          }, 650);
        } else {
          showMessage('error', 'circle-x', result.message || 'รหัสไม่ถูกต้อง');
        }
      } catch (error) {
        console.error('Error verifying code:', error);
        showMessage('error', 'triangle-alert', 'เกิดข้อผิดพลาด กรุณาลองใหม่');
      } finally {
        codeForm.querySelector('button[type="submit"]').disabled = false;
      }
    });

    codeInput.addEventListener('input', function () {
      this.value = this.value.toUpperCase();
    });

    function updateStatsFromLeaderboard(entries) {
      const visibleEntries = Array.isArray(entries) ? entries.length : 0;
      document.getElementById('statPlayers').textContent = visibleEntries;
      document.getElementById('statCompleted').textContent = visibleEntries;
      document.getElementById('statQuestions').textContent = 'พร้อม';
    }

    async function loadLeaderboardPreview() {
      const preview = document.getElementById('leaderboardPreview');

      try {
        const response = await fetch('/coopgame/game/api/leaderboard?limit=4');
        const result = await response.json();
        const entries = Array.isArray(result.data) ? result.data : [];
        updateStatsFromLeaderboard(entries);

        if (!result.success || entries.length === 0) {
          preview.innerHTML = `
            <div class="empty-state">
              <img src="/coopgame/assets/illustrations/team-work-amico.svg" alt="">
              <strong>ยังไม่มีอันดับ</strong>
              <span>เริ่มรอบแรกเพื่อขึ้น Scoreboard</span>
            </div>
          `;
          renderIcons();
          return;
        }

        preview.innerHTML = entries.map((entry) => `
          <div class="activity-item">
            <div class="activity-rank">${entry.rank}</div>
            <div class="activity-meta">
              <strong>${escapeHtml(entry.playerName || 'ไม่ระบุชื่อ')}</strong>
              <span>${entry.score || 0} ข้อ · ${entry.totalTime || 0} วินาที</span>
            </div>
            <i data-lucide="trophy"></i>
          </div>
        `).join('');
        renderIcons();
      } catch (error) {
        console.error('Error loading leaderboard preview:', error);
        preview.innerHTML = `
          <div class="empty-state">
            <img src="/coopgame/assets/illustrations/team-work-amico.svg" alt="">
            <strong>โหลดอันดับไม่ได้</strong>
            <span>ลองรีเฟรชหน้าอีกครั้ง</span>
          </div>
        `;
      }
    }

    function escapeHtml(text) {
      return String(text)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    renderIcons();
    if (gameEnabled) {
      codeInput.focus();
    }
    updateStatsFromLeaderboard([]);
    loadLeaderboardPreview();
  </script>
</body>
</html>
