<body>
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-6">
        <div class="card game-card p-4 mb-4 fade-in">
          <div class="card-body text-center">
            <div class="mb-4">
              <i class="bi bi-controller display-1 text-success icon-bounce"></i>
            </div>
            <h1 class="game-title mb-3">
              <i class="bi bi-trophy-fill" style="color: #43a047;"></i>
              เกมตอบคำถามสหกรณ์
            </h1>
            <p class="lead text-muted mb-4">กรอกรหัสเพื่อเริ่มเล่นเกม</p>
            
            <form id="codeForm">
              <div class="mb-4">
                <label for="code" class="form-label fw-bold" style="color: #2e7d32;">
                  <i class="bi bi-key-fill"></i> รหัสเกม
                </label>
                <input 
                  type="text" 
                  id="code" 
                  name="code" 
                  class="form-control code-input"
                  maxlength="6" 
                  placeholder="ABC123"
                  autocomplete="off"
                  required
                  style="text-transform: uppercase;"
                >
                <div class="form-text mt-2">
                  <i class="bi bi-info-circle"></i> รหัส 6 ตัวอักษร (ตัวพิมพ์ใหญ่)
                </div>
              </div>
              
              <button type="submit" class="btn btn-start text-white">
                <i class="bi bi-play-fill"></i> เริ่มเกม
              </button>
            </form>

            <div id="message" class="mt-3"></div>
            <div class="divider"></div>
          </div>
        </div>

        <div class="card rules-card fade-in">
          <div class="card-header text-center">
            <i class="bi bi-clipboard2-check"></i> กติกาการเล่น
          </div>
          <div class="card-body">
            <ul class="list-unstyled rules-list mb-0">
              <li><i class="bi bi-check-circle me-2" style="color: #43a047;"></i> ตอบคำถามทีละข้อ</li>
              <li><i class="bi bi-x-circle me-2" style="color: #e53935;"></i> ตอบผิดหรือหมดเวลา = เกมจบทันที</li>
              <li><i class="bi bi-clock me-2" style="color: #fb8c00;"></i> คำถามง่าย 10 วินาที | ปานกลาง 15 วินาที | ยาก 20 วินาที</li>
              <li><i class="bi bi-award me-2" style="color: #43a047;"></i> ผู้ที่ตอบถูกมากที่สุดชนะ</li>
              <li><i class="bi bi-stopwatch me-2" style="color: #0288d1;"></i> ถ้าคะแนนเท่ากัน ใช้เวลารวมน้อยกว่าชนะ</li>
            </ul>
          </div>
        </div>

        <footer class="text-center mt-4 text-white">
          <p><i class="bi bi-c-circle"></i> 2026 naimet</p>
        </footer>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('codeForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const code = document.getElementById('code').value.toUpperCase();
      const messageDiv = document.getElementById('message');
      
      messageDiv.innerHTML = `
        <div class="alert d-flex align-items-center" style="background: #e8f5e9; color: #2e7d32; border: 1px solid #c8e6c9;" role="alert">
          <div class="spinner-border spinner-border-sm me-2" role="status" style="color: #43a047;"></div>
          <div>กำลังตรวจสอบ...</div>
        </div>
      `;
      
      try {
        const response = await fetch('/coopgame/game/verify-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code })
        });
        
        const result = await response.json();
        
        if (result.success) {
          messageDiv.innerHTML = `
            <div class="alert d-flex align-items-center" style="background: #e8f5e9; color: #1b5e20; border: 1px solid #a5d6a7;" role="alert">
              <i class="bi bi-check-circle-fill me-2" style="color: #43a047;"></i>
              <div>รหัสถูกต้อง! กำลังนำทาง...</div>
            </div>
          `;
          setTimeout(() => {
            window.location.href = `/coopgame/game/play?attemptId=${result.data.attemptId}`;
          }, 500);
        } else {
          messageDiv.innerHTML = `
            <div class="alert d-flex align-items-center" style="background: #ffebee; color: #c62828; border: 1px solid #ffcdd2;" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2" style="color: #e53935;"></i>
              <div>${result.message}</div>
            </div>
          `;
        }
      } catch (error) {
        messageDiv.innerHTML = `
          <div class="alert d-flex align-items-center" style="background: #ffebee; color: #c62828; border: 1px solid #ffcdd2;" role="alert">
            <i class="bi bi-exclamation-octagon-fill me-2" style="color: #e53935;"></i>
            <div>เกิดข้อผิดพลาด กรุณาลองใหม่</div>
          </div>
        `;
      }
    });

    // Auto uppercase input
    document.getElementById('code').addEventListener('input', function(e) {
      this.value = this.value.toUpperCase();
    });
  </script>
</body>
</html>
