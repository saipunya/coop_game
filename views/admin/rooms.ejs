<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700;800&display=swap');
    body { min-height:100vh; font-family:'Sarabun', sans-serif; background:#eef7ee; color:#1b3d1f; }
    .admin-container { max-width:1200px; margin:0 auto; padding:24px; }
    .admin-header, .card { background:#fff; border:1px solid #cfe8d1; border-radius:8px; box-shadow:0 12px 30px rgba(39,95,45,.08); }
    .admin-header { display:flex; justify-content:space-between; gap:16px; align-items:center; padding:18px 22px; margin-bottom:20px; }
    h1, h2 { margin:0; font-weight:800; color:#235c2a; }
    .card { padding:20px; margin-bottom:20px; }
    .grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px; }
    .table th { color:#235c2a; }
    .play-link { font-family:monospace; font-size:.92rem; }
    .room-actions { min-width:230px; }
  </style>
</head>
<body>
  <div class="admin-container">
    <header class="admin-header">
      <h1><i class="bi bi-door-open me-2"></i>จัดการห้อง</h1>
      <div class="d-flex gap-2 flex-wrap">
        <a href="/coopgame/admin/" class="btn btn-outline-success"><i class="bi bi-speedometer2"></i> แดชบอร์ด</a>
        <a href="/coopgame/admin/questions" class="btn btn-outline-success"><i class="bi bi-card-checklist"></i> คำถาม</a>
        <a href="/coopgame/admin/logout" class="btn btn-outline-danger"><i class="bi bi-box-arrow-right"></i> ออกจากระบบ</a>
      </div>
    </header>

    <section class="card">
      <h2 class="h4 mb-3">สร้าง/แก้ไขห้อง</h2>
      <form id="roomForm" class="grid">
        <input type="hidden" id="roomId">
        <div>
          <label class="form-label" for="roomName">ชื่อห้อง</label>
          <input id="roomName" class="form-control" required>
        </div>
        <div>
          <label class="form-label" for="roomSlug">Slug</label>
          <input id="roomSlug" class="form-control" placeholder="coop-kjs" required>
        </div>
        <div>
          <label class="form-label" for="roomStatus">สถานะ</label>
          <select id="roomStatus" class="form-select">
            <option value="active">active</option>
            <option value="inactive">inactive</option>
          </select>
        </div>
        <div class="d-flex align-items-end gap-2">
          <button class="btn btn-success" type="submit">บันทึกห้อง</button>
          <button class="btn btn-outline-secondary" type="button" onclick="resetRoomForm()">ล้างฟอร์ม</button>
        </div>
      </form>
    </section>

    <section class="card">
      <h2 class="h4 mb-3">รายการห้อง</h2>
      <div class="table-responsive">
        <table class="table align-middle">
          <thead><tr><th>ID</th><th>ชื่อ</th><th>Slug</th><th>สถานะ</th><th>ลิงก์เล่น</th><th>จัดการ</th></tr></thead>
          <tbody id="roomsList"></tbody>
        </table>
      </div>
    </section>

    <section class="card">
      <h2 class="h4 mb-3">สร้าง/แก้ไขแอดมินห้อง</h2>
      <form id="adminUserForm" class="grid">
        <input type="hidden" id="adminUserId">
        <div>
          <label class="form-label" for="username">Username</label>
          <input id="username" class="form-control" required>
        </div>
        <div>
          <label class="form-label" for="password">Password</label>
          <input id="password" type="password" class="form-control" placeholder="เว้นว่างเมื่อแก้ไขแล้วไม่เปลี่ยนรหัส">
        </div>
        <div>
          <label class="form-label" for="role">Role</label>
          <select id="role" class="form-select">
            <option value="room_admin">room_admin</option>
            <option value="super_admin">super_admin</option>
          </select>
        </div>
        <div>
          <label class="form-label" for="adminRoomId">ห้อง</label>
          <select id="adminRoomId" class="form-select"></select>
        </div>
        <div>
          <label class="form-label" for="isActive">สถานะ</label>
          <select id="isActive" class="form-select">
            <option value="true">active</option>
            <option value="false">inactive</option>
          </select>
        </div>
        <div class="d-flex align-items-end gap-2">
          <button class="btn btn-success" type="submit">บันทึกผู้ใช้</button>
          <button class="btn btn-outline-secondary" type="button" onclick="resetAdminForm()">ล้างฟอร์ม</button>
        </div>
      </form>
    </section>

    <section class="card">
      <h2 class="h4 mb-3">บัญชีแอดมิน</h2>
      <div class="table-responsive">
        <table class="table align-middle">
          <thead><tr><th>ID</th><th>Username</th><th>Role</th><th>ห้อง</th><th>สถานะ</th><th></th></tr></thead>
          <tbody id="adminUsersList"></tbody>
        </table>
      </div>
    </section>
  </div>

  <script>
    let rooms = [];
    let adminUsers = [];

    function escapeHtml(text) {
      return String(text || '').replace(/[&<>"']/g, char => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      }[char]));
    }

    function playLink(room) {
      return `${window.location.origin}/coopgame/r/${room.slug}`;
    }

    async function loadRooms() {
      const response = await fetch('/coopgame/admin/api/rooms');
      const result = await response.json();
      rooms = result.success ? result.data : [];
      document.getElementById('roomsList').innerHTML = rooms.map(room => `
        <tr>
          <td>${room.id}</td>
          <td>${escapeHtml(room.name)}</td>
          <td>${escapeHtml(room.slug)}</td>
          <td>${room.status}</td>
          <td class="play-link"><a href="/coopgame/r/${room.slug}" target="_blank">${playLink(room)}</a></td>
          <td class="room-actions">
            <div class="d-flex gap-2 flex-wrap">
              <button class="btn btn-sm btn-outline-success" onclick="editRoom(${room.id})">
                <i class="bi bi-pencil-square"></i> แก้ไข
              </button>
              <button class="btn btn-sm btn-outline-danger" onclick="clearRoomCodes(${room.id}, this)">
                <i class="bi bi-key"></i> เคลียร์รหัส
              </button>
              <button class="btn btn-sm btn-outline-warning" onclick="clearRoomStats(${room.id}, this)">
                <i class="bi bi-bar-chart"></i> เคลียร์สถิติ
              </button>
            </div>
          </td>
        </tr>
      `).join('');
      document.getElementById('adminRoomId').innerHTML = rooms
        .filter(room => room.status === 'active')
        .map(room => `<option value="${room.id}">${escapeHtml(room.name)}</option>`)
        .join('');
    }

    async function loadAdminUsers() {
      const response = await fetch('/coopgame/admin/api/admin-users');
      const result = await response.json();
      adminUsers = result.success ? result.data : [];
      document.getElementById('adminUsersList').innerHTML = adminUsers.map(user => `
        <tr>
          <td>${user.id}</td>
          <td>${escapeHtml(user.username)}</td>
          <td>${user.role}</td>
          <td>${escapeHtml(user.room_name || '-')}</td>
          <td>${user.is_active ? 'active' : 'inactive'}</td>
          <td><button class="btn btn-sm btn-outline-success" onclick="editAdminUser(${user.id})">แก้ไข</button></td>
        </tr>
      `).join('');
    }

    function resetRoomForm() {
      document.getElementById('roomForm').reset();
      document.getElementById('roomId').value = '';
    }

    function editRoom(id) {
      const room = rooms.find(item => item.id === id);
      if (!room) return;
      document.getElementById('roomId').value = room.id;
      document.getElementById('roomName').value = room.name;
      document.getElementById('roomSlug').value = room.slug;
      document.getElementById('roomStatus').value = room.status;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function resetAdminForm() {
      document.getElementById('adminUserForm').reset();
      document.getElementById('adminUserId').value = '';
    }

    function editAdminUser(id) {
      const user = adminUsers.find(item => item.id === id);
      if (!user) return;
      document.getElementById('adminUserId').value = user.id;
      document.getElementById('username').value = user.username;
      document.getElementById('password').value = '';
      document.getElementById('role').value = user.role;
      document.getElementById('adminRoomId').value = user.room_id || '';
      document.getElementById('isActive').value = user.is_active ? 'true' : 'false';
    }

    function findRoom(id) {
      return rooms.find(item => item.id === id);
    }

    function roomLabel(room, id) {
      return room ? `${room.name} (${room.slug})` : `ID ${id}`;
    }

    async function postRoomAction(url, roomId, button) {
      const originalHtml = button ? button.innerHTML : '';
      if (button) {
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>กำลังลบ';
      }

      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ roomId })
        });
        return await response.json();
      } finally {
        if (button) {
          button.disabled = false;
          button.innerHTML = originalHtml;
        }
      }
    }

    async function clearRoomCodes(id, button) {
      const room = findRoom(id);
      if (!room) return;
      const label = roomLabel(room, id);
      if (!confirm(`ต้องการเคลียร์รหัสทั้งหมดของห้อง "${label}" หรือไม่?\n\nประวัติเกมที่ผูกกับรหัสของห้องนี้จะถูกลบตามไปด้วย`)) return;

      const typed = prompt(`พิมพ์ CLEAR เพื่อยืนยันการเคลียร์รหัสของห้อง "${label}"`);
      if (typed !== 'CLEAR') return;

      try {
        const result = await postRoomAction('/coopgame/admin/api/codes/clear', id, button);
        if (!result.success) return alert(result.message || 'เคลียร์รหัสไม่สำเร็จ');

        const deletedCodes = result.data?.count || 0;
        const deletedAttempts = result.data?.attempts || 0;
        alert(`เคลียร์รหัสของห้อง "${label}" สำเร็จ\nลบรหัส ${deletedCodes} รายการ\nลบประวัติเกม ${deletedAttempts} รายการ`);
      } catch (error) {
        console.error('Error clearing room codes:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    }

    async function clearRoomStats(id, button) {
      const room = findRoom(id);
      if (!room) return;
      const label = roomLabel(room, id);
      if (!confirm(`ต้องการเคลียร์สถิติของห้อง "${label}" หรือไม่?\n\nประวัติการเล่น คะแนน และ leaderboard ของห้องนี้จะถูกลบถาวร`)) return;

      const typed = prompt(`พิมพ์ DELETE เพื่อยืนยันการเคลียร์สถิติของห้อง "${label}"`);
      if (typed !== 'DELETE') return;

      try {
        const result = await postRoomAction('/coopgame/admin/api/history/clear', id, button);
        if (!result.success) return alert(result.message || 'เคลียร์สถิติไม่สำเร็จ');

        const deletedAttempts = result.data?.count || 0;
        alert(`เคลียร์สถิติของห้อง "${label}" สำเร็จ\nลบประวัติเกม ${deletedAttempts} รายการ`);
      } catch (error) {
        console.error('Error clearing room stats:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    }

    document.getElementById('roomForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const id = document.getElementById('roomId').value;
      const payload = {
        name: document.getElementById('roomName').value,
        slug: document.getElementById('roomSlug').value,
        status: document.getElementById('roomStatus').value
      };
      const response = await fetch(id ? `/coopgame/admin/api/rooms/${id}` : '/coopgame/admin/api/rooms', {
        method: id ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const result = await response.json();
      if (!result.success) return alert(result.message || 'บันทึกห้องไม่สำเร็จ');
      resetRoomForm();
      await loadRooms();
      alert('บันทึกห้องสำเร็จ');
    });

    document.getElementById('adminUserForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const id = document.getElementById('adminUserId').value;
      const payload = {
        username: document.getElementById('username').value,
        password: document.getElementById('password').value,
        role: document.getElementById('role').value,
        roomId: document.getElementById('adminRoomId').value,
        isActive: document.getElementById('isActive').value === 'true'
      };
      const response = await fetch(id ? `/coopgame/admin/api/admin-users/${id}` : '/coopgame/admin/api/admin-users', {
        method: id ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const result = await response.json();
      if (!result.success) return alert(result.message || 'บันทึกผู้ใช้ไม่สำเร็จ');
      resetAdminForm();
      await loadAdminUsers();
      alert('บันทึกผู้ใช้สำเร็จ');
    });

    loadRooms().then(loadAdminUsers);
  </script>
</body>
</html>
