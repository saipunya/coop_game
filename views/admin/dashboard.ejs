<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700;800&display=swap');
    
    body {
      background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 50%, #a5d6a7 100%);
      min-height: 100vh;
      font-family: 'Sarabun', -apple-system, BlinkMacSystemFont, sans-serif;
    }
    .admin-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 20px;
    }
    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      padding: 20px 30px;
      background: rgba(255, 255, 255, 0.95);
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(46, 125, 50, 0.1);
      backdrop-filter: blur(10px);
    }
    .admin-header h1 {
      background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-weight: 800;
      font-size: 2rem;
      margin: 0;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }
    .stat-card {
      background: rgba(255, 255, 255, 0.95);
      padding: 25px;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(46, 125, 50, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(200, 230, 201, 0.5);
      transition: transform 0.3s ease;
    }
    .stat-card:hover {
      transform: translateY(-5px);
    }
    .stat-card h3 {
      color: #2e7d32;
      font-size: 14px;
      margin-bottom: 10px;
      font-weight: 600;
    }
    .stat-card .number {
      font-size: 36px;
      font-weight: bold;
      background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .stat-card .sub-text {
      color: #66bb6a;
      font-size: 12px;
      margin-top: 5px;
    }
    .content-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 20px;
    }
    .card {
      background: rgba(255, 255, 255, 0.95);
      padding: 25px;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(46, 125, 50, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(200, 230, 201, 0.5);
    }
    .card h2 {
      margin-bottom: 20px;
      color: #1b5e20;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 700;
    }
    .card h2 .date-filter {
      font-size: 14px;
      font-weight: normal;
    }
    .card h2 select {
      padding: 8px 12px;
      border: 2px solid #a5d6a7;
      border-radius: 10px;
      font-size: 14px;
      background: #f1f8e9;
      color: #2e7d32;
    }
    .table {
      color: #2e7d32;
    }
    .table thead th {
      background: linear-gradient(135deg, #e8f5e9 0%, #f1f8e9 100%);
      border-bottom: 2px solid #c8e6c9;
      color: #1b5e20;
      font-weight: 700;
      padding: 12px;
    }
    .table tbody td {
      padding: 12px;
      border-bottom: 1px solid #e8f5e9;
    }
    .table tbody tr:hover {
      background: rgba(200, 230, 201, 0.3);
    }
    .rank-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
      color: white;
      font-weight: bold;
      font-size: 14px;
    }
    .rank-1 { background: linear-gradient(135deg, #FFD700 0%, #FFA000 100%); }
    .rank-2 { background: linear-gradient(135deg, #9E9E9E 0%, #BDBDBD 100%); }
    .rank-3 { background: linear-gradient(135deg, #8D6E63 0%, #A1887F 100%); }
    .score-badge {
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
    }
    .score-high { background: #e8f5e9; color: #1b5e20; border: 1px solid #a5d6a7; }
    .score-medium { background: #fff8e1; color: #f57f17; border: 1px solid #ffe082; }
    .score-low { background: #ffebee; color: #c62828; border: 1px solid #ef9a9a; }
    .btn-group {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .refresh-btn {
      padding: 6px 16px;
      font-size: 13px;
      border-radius: 10px;
    }
    .daily-stats {
      margin-top: 20px;
    }
    .daily-stats h3 {
      margin-bottom: 15px;
      color: #1b5e20;
      font-weight: 700;
    }
    .daily-stat-item {
      display: flex;
      justify-content: space-between;
      padding: 12px 16px;
      border-bottom: 1px solid #e8f5e9;
      transition: all 0.3s ease;
      border-radius: 8px;
    }
    .daily-stat-item:hover {
      background: rgba(200, 230, 201, 0.3);
      padding-left: 20px;
    }
    .daily-stat-item:last-child {
      border-bottom: none;
    }
    .daily-stat-item .date {
      color: #2e7d32;
      font-weight: 500;
    }
    .daily-stat-item .value {
      font-weight: bold;
      color: #43a047;
    }
    .empty-state {
      text-align: center;
      padding: 40px;
      color: #66bb6a;
    }
    .loading {
      text-align: center;
      padding: 40px;
      color: #43a047;
    }
    .fade-in {
      animation: fadeIn 0.6s ease-out;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media (max-width: 1024px) {
      .content-grid {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 768px) {
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .admin-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
      }
      .btn-group {
        width: 100%;
      }
      .btn-group .btn {
        flex: 1 1 160px;
      }
    }
    @media (max-width: 480px) {
      .admin-container {
        padding: 12px;
      }
      .stats-grid {
        grid-template-columns: 1fr;
      }
      .admin-header {
        padding: 16px;
      }
      .admin-header h1 {
        font-size: 1.5rem;
      }
      .admin-header .btn-group {
        flex-direction: column;
      }
      .admin-header .btn-group .btn {
        width: 100%;
      }
      .card {
        padding: 16px;
      }
      .card h2 {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
      }
      .card h2 .date-filter {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .card h2 .date-filter select,
      .card h2 .date-filter .refresh-btn {
        width: 100%;
      }
      .table {
        display: block;
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
      .table th,
      .table td {
        white-space: nowrap;
      }
      .daily-stat-item {
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <header class="admin-header fade-in">
      <h1><i class="bi bi-speedometer2 me-2"></i>Dashboard Admin</h1>
      <div class="btn-group">
        <a href="/coopgame/admin/questions" class="btn btn-outline-success">
          <i class="bi bi-card-checklist"></i> จัดการคำถาม
        </a>
        <a href="/coopgame/admin/codes" class="btn btn-outline-success">
          <i class="bi bi-ticket-perforated"></i> จัดการรหัส
        </a>
        <a href="/coopgame/game/start" class="btn" style="background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); color: white; border: none;">
          <i class="bi bi-controller"></i> เล่นเกม
        </a>
        <span style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
          <span style="font-weight:600; color:#2e7d32;"><i class="bi bi-person-circle"></i> <%= adminUser.username %></span>
          <a href="/coopgame/admin/logout" class="btn btn-outline-success">
            <i class="bi bi-box-arrow-right"></i> ออกจากระบบ
          </a>
        </span>
      </div>
    </header>

    <!-- Stats Overview -->
    <div class="stats-grid fade-in">
      <div class="stat-card">
        <h3><i class="bi bi-people-fill me-2"></i>ผู้เล่นทั้งหมด</h3>
        <div class="number" id="totalPlayers">-</div>
        <div class="sub-text"><i class="bi bi-person"></i> คน</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-controller me-2"></i>เกมที่เล่นเสร็จ</h3>
        <div class="number" id="completedGames">-</div>
        <div class="sub-text"><i class="bi bi-trophy"></i> เกม</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-star-fill me-2"></i>คะแนนเฉลี่ย</h3>
        <div class="number" id="avgScore">-</div>
        <div class="sub-text"><i class="bi bi-clipboard-check"></i> จาก 9 คำถาม</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-clock-fill me-2"></i>เวลาเฉลี่ย</h3>
        <div class="number" id="avgTime">-</div>
        <div class="sub-text"><i class="bi bi-stopwatch"></i> วินาที/เกม</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-ticket-perforated me-2"></i>รหัสที่ใช้ไป</h3>
        <div class="number" id="usedCodes">-</div>
        <div class="sub-text"><i class="bi bi-check-circle"></i> รหัส</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-card-text me-2"></i>คำถามทั้งหมด</h3>
        <div class="number" id="totalQuestions">-</div>
        <div class="sub-text"><i class="bi bi-list-ol"></i> คำถาม</div>
      </div>
    </div>

    <div class="content-grid fade-in">
      <!-- Leaderboard -->
      <div class="card">
        <h2>
          <i class="bi bi-trophy-fill me-2" style="color: #fdd835;"></i>อันดับผู้เล่น
          <div class="date-filter">
            <select id="leaderboardFilter">
              <option value="all">ทั้งหมด</option>
              <option value="today">วันนี้</option>
              <option value="week">สัปดาห์นี้</option>
              <option value="month">เดือนนี้</option>
            </select>
            <button class="btn btn-sm refresh-btn" style="border: 2px solid #a5d6a7; color: #2e7d32; border-radius: 10px;" onclick="loadLeaderboard()">
              <i class="bi bi-arrow-clockwise"></i>
            </button>
          </div>
        </h2>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th style="width: 50px;">#</th>
                <th>ชื่อ</th>
                <th>คะแนน</th>
                <th style="width: 80px;">เวลา</th>
                <th style="width: 120px;">วันที่</th>
              </tr>
            </thead>
            <tbody id="leaderboardBody">
              <tr><td colspan="5" class="loading">กำลังโหลด...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Daily Stats -->
      <div class="card">
        <h2>
          <i class="bi bi-calendar-check me-2" style="color: #43a047;"></i>สถิติรายวัน
          <button class="btn btn-sm refresh-btn" style="border: 2px solid #a5d6a7; color: #2e7d32; border-radius: 10px;" onclick="loadDailyStats()">
            <i class="bi bi-arrow-clockwise"></i>
          </button>
        </h2>
        <div id="dailyStats" class="daily-stats">
          <div class="loading">กำลังโหลด...</div>
        </div>
      </div>
    </div>

    <!-- Recent Games -->
    <div class="card fade-in" style="margin-top: 20px;">
      <h2>
        <i class="bi bi-controller me-2" style="color: #43a047;"></i>เกมล่าสุด
        <button class="btn btn-sm refresh-btn" style="border: 2px solid #a5d6a7; color: #2e7d32; border-radius: 10px;" onclick="loadRecentGames()">
          <i class="bi bi-arrow-clockwise"></i>
        </button>
      </h2>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th style="width: 80px;">#</th>
              <th>ชื่อ</th>
              <th>คะแนน</th>
              <th style="width: 100px;">เวลา</th>
              <th style="width: 200px;">วันที่</th>
              <th style="width: 120px;">สถานะ</th>
            </tr>
          </thead>
          <tbody id="recentGamesBody">
            <tr><td colspan="6" class="loading">กำลังโหลด...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Load all data on page load
    document.addEventListener('DOMContentLoaded', () => {
      loadStats();
      loadLeaderboard();
      loadDailyStats();
      loadRecentGames();
    });

    // Load overall statistics
    async function loadStats() {
      try {
        const response = await fetch('/coopgame/admin/api/stats');
        const result = await response.json();
        
        if (result.success && result.data) {
          const stats = result.data;
          document.getElementById('totalPlayers').textContent = stats.players || 0;
          document.getElementById('completedGames').textContent = stats.completedGames || 0;
          document.getElementById('avgScore').textContent = (stats.averageScore || 0).toFixed(1);
          document.getElementById('avgTime').textContent = (stats.averageTime || 0).toFixed(0);
          
          if (stats.codes) {
            document.getElementById('usedCodes').textContent = stats.codes.used || 0;
          }
          if (stats.questions) {
            document.getElementById('totalQuestions').textContent = stats.questions.total || 0;
          }
        }
      } catch (error) {
        console.error('Error loading stats:', error);
      }
    }

    // Load leaderboard
    async function loadLeaderboard() {
      const filter = document.getElementById('leaderboardFilter').value;
      const tbody = document.getElementById('leaderboardBody');
      
      try {
        const response = await fetch(`/coopgame/game/api/leaderboard?limit=20`);
        const result = await response.json();
        
        console.log('[DEBUG] Admin leaderboard result:', result);
        
        if (result.success && result.data && result.data.length > 0) {
          let players = result.data;
          
          // Filter by date
          const now = new Date();
          if (filter === 'today') {
            const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
            players = players.filter(p => {
              const dateField = p.started_at || p.createdAt || p.finishedAt;
              return dateField && new Date(dateField) >= today;
            });
          } else if (filter === 'week') {
            const weekAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
            players = players.filter(p => {
              const dateField = p.started_at || p.createdAt || p.finishedAt;
              return dateField && new Date(dateField) >= weekAgo;
            });
          } else if (filter === 'month') {
            const monthAgo = new Date(now.getFullYear(), now.getMonth() - 1, now.getDate());
            players = players.filter(p => {
              const dateField = p.started_at || p.createdAt || p.finishedAt;
              return dateField && new Date(dateField) >= monthAgo;
            });
          }

          tbody.innerHTML = players.map((p, index) => {
            console.log('[DEBUG] Player data:', p);
            const rankClass = index < 3 ? `rank-${index + 1}` : '';
            const scoreClass = p.score >= 7 ? 'score-high' : p.score >= 4 ? 'score-medium' : 'score-low';
            
            // Try different date fields
            const dateField = p.started_at || p.createdAt || p.finishedAt;
            console.log('[DEBUG] Date field:', dateField);
            const date = dateField ? new Date(dateField).toLocaleDateString('th-TH', {
              day: '2-digit',
              month: 'short',
              year: '2-digit'
            }) : '-';
            
            return `
              <tr>
                <td><span class="rank-badge ${rankClass}">${index + 1}</span></td>
                <td><strong>${escapeHtml(p.playerName)}</strong></td>
                <td><span class="score-badge ${scoreClass}">${p.score}/9</span></td>
                <td>${p.totalTime} วินาที</td>
                <td>${date}</td>
              </tr>
            `;
          }).join('');
        } else {
          tbody.innerHTML = '<tr><td colspan="5" class="empty-state">ยังไม่มีข้อมูล</td></tr>';
        }
      } catch (error) {
        console.error('Error loading leaderboard:', error);
        tbody.innerHTML = '<tr><td colspan="5" class="empty-state">เกิดข้อผิดพลาด</td></tr>';
      }
    }

    // Load daily statistics
    async function loadDailyStats() {
      const container = document.getElementById('dailyStats');
      
      try {
        const response = await fetch('/coopgame/admin/api/stats');
        const result = await response.json();
        
        if (result.success && result.data) {
          const stats = result.data;
          container.innerHTML = `
            <div class="daily-stat-item">
              <span class="date">ผู้เล่นทั้งหมด</span>
              <span class="value">${stats.players || 0} คน</span>
            </div>
            <div class="daily-stat-item">
              <span class="date">เกมเสร็จสมบูรณ์</span>
              <span class="value">${stats.completedGames || 0} เกม</span>
            </div>
            <div class="daily-stat-item">
              <span class="date">คะแนนเฉลี่ย</span>
              <span class="value">${(stats.averageScore || 0).toFixed(1)}/9</span>
            </div>
            <div class="daily-stat-item">
              <span class="date">เวลาเฉลี่ย</span>
              <span class="value">${(stats.averageTime || 0).toFixed(0)} วินาที</span>
            </div>
            <div class="daily-stat-item">
              <span class="date">รหัสที่ใช้ไป</span>
              <span class="value">${stats.codes ? stats.codes.used : 0} รหัส</span>
            </div>
            <div class="daily-stat-item">
              <span class="date">คำถามทั้งหมด</span>
              <span class="value">${stats.questions ? stats.questions.total : 0} คำถาม</span>
            </div>
          `;
        }
      } catch (error) {
        console.error('Error loading daily stats:', error);
        container.innerHTML = '<div class="empty-state">เกิดข้อผิดพลาด</div>';
      }
    }

    // Load recent games
    async function loadRecentGames() {
      const tbody = document.getElementById('recentGamesBody');
      
      try {
        const response = await fetch('/coopgame/game/api/leaderboard?limit=10');
        const result = await response.json();
        
        console.log('[DEBUG] Admin recent games result:', result);
        
        if (result.success && result.data && result.data.length > 0) {
          tbody.innerHTML = result.data.map((p, index) => {
            console.log('[DEBUG] Recent game data:', p);
            const dateField = p.started_at || p.createdAt || p.finishedAt;
            const date = dateField ? new Date(dateField).toLocaleDateString('th-TH', {
              day: '2-digit',
              month: 'short',
              year: '2-digit',
              hour: '2-digit',
              minute: '2-digit'
            }) : '-';
            const statusBadge = p.score >= 7 
              ? '<span class="score-badge score-high">ดีมาก</span>'
              : p.score >= 4 
                ? '<span class="score-badge score-medium">ปานกลาง</span>'
                : '<span class="score-badge score-low">ต้องพัฒนา</span>';
            
            return `
              <tr>
                <td>${index + 1}</td>
                <td><strong>${escapeHtml(p.playerName)}</strong></td>
                <td>${p.score}/9</td>
                <td>${p.totalTime} วินาที</td>
                <td>${date}</td>
                <td>${statusBadge}</td>
              </tr>
            `;
          }).join('');
        } else {
          tbody.innerHTML = '<tr><td colspan="6" class="empty-state">ยังไม่มีข้อมูล</td></tr>';
        }
      } catch (error) {
        console.error('Error loading recent games:', error);
        tbody.innerHTML = '<tr><td colspan="6" class="empty-state">เกิดข้อผิดพลาด</td></tr>';
      }
    }

    // Helper function
    function escapeHtml(text) {
      if (!text) return '-';
      return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // Auto refresh every 30 seconds
    setInterval(() => {
      loadStats();
      loadLeaderboard();
      loadDailyStats();
      loadRecentGames();
    }, 30000);

    // Filter change handler
    document.getElementById('leaderboardFilter').addEventListener('change', loadLeaderboard);
  </script>
</body>
</html>
