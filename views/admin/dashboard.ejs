<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700;800&display=swap');

    :root {
      --green-900: #1b5e20;
      --green-700: #2e7d32;
      --green-500: #43a047;
      --green-300: #81c784;
      --bg-1: #eef8ec;
      --bg-2: #d7ecd6;
      --bg-3: #b8dfb9;
      --card: rgba(255, 255, 255, 0.96);
    }

    body {
      min-height: 100vh;
      font-family: 'Sarabun', -apple-system, BlinkMacSystemFont, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(67, 160, 71, 0.18), transparent 30%),
        radial-gradient(circle at top right, rgba(129, 199, 132, 0.18), transparent 24%),
        linear-gradient(135deg, var(--bg-1) 0%, var(--bg-2) 48%, var(--bg-3) 100%);
      color: var(--green-900);
    }

    .admin-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 20px;
    }

    .admin-header,
    .stat-card,
    .card-panel {
      background: var(--card);
      border: 1px solid rgba(129, 199, 132, 0.35);
      box-shadow: 0 16px 45px rgba(46, 125, 50, 0.08);
      backdrop-filter: blur(10px);
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
      padding: 20px 24px;
      border-radius: 22px;
    }

    .admin-header h1 {
      margin: 0;
      font-size: 1.9rem;
      font-weight: 800;
      background: linear-gradient(135deg, var(--green-700) 0%, var(--green-500) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .btn-group {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 18px;
      margin-bottom: 24px;
    }

    .stat-card {
      padding: 20px;
      border-radius: 20px;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .stat-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 50px rgba(46, 125, 50, 0.12);
    }

    .stat-card h3 {
      margin: 0 0 10px;
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--green-700);
    }

    .stat-number {
      font-size: 2.4rem;
      line-height: 1;
      font-weight: 800;
      margin: 0;
      background: linear-gradient(135deg, var(--green-700) 0%, var(--green-500) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .stat-sub {
      margin-top: 6px;
      color: #5f9f63;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .content-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 20px;
    }

    .card-panel {
      border-radius: 22px;
      padding: 22px;
    }

    .card-panel h2 {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin: 0 0 18px;
      color: var(--green-900);
      font-size: 1.25rem;
      font-weight: 800;
    }

    .date-filter {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .date-filter select {
      min-width: 150px;
      padding: 8px 12px;
      border: 2px solid #b2dfb4;
      border-radius: 12px;
      background: #f7fbf4;
      color: var(--green-700);
      font-weight: 600;
    }

    .refresh-btn {
      border: 2px solid #b2dfb4;
      border-radius: 12px;
      color: var(--green-700);
      background: #f7fbf4;
      padding: 6px 12px;
    }

    .table {
      color: var(--green-700);
    }

    .table thead th {
      background: linear-gradient(135deg, #edf7ec 0%, #f8fcf6 100%);
      color: var(--green-900);
      font-weight: 800;
      border-bottom: 2px solid #d8ead8;
      padding: 12px;
    }

    .table tbody td {
      padding: 12px;
      border-bottom: 1px solid #edf4ed;
      vertical-align: middle;
    }

    .table tbody tr:hover {
      background: rgba(200, 230, 201, 0.25);
    }

    .rank-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border-radius: 999px;
      font-weight: 800;
      color: white;
      background: linear-gradient(135deg, var(--green-500) 0%, #66bb6a 100%);
    }

    .rank-1 { background: linear-gradient(135deg, #ffd54f 0%, #ffb300 100%); }
    .rank-2 { background: linear-gradient(135deg, #b0bec5 0%, #90a4ae 100%); }
    .rank-3 { background: linear-gradient(135deg, #a1887f 0%, #8d6e63 100%); }

    .score-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 12px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.9rem;
    }

    .score-high {
      background: #e8f5e9;
      color: #1b5e20;
      border: 1px solid #a5d6a7;
    }

    .score-medium {
      background: #fff8e1;
      color: #f57f17;
      border: 1px solid #ffe082;
    }

    .score-low {
      background: #ffebee;
      color: #c62828;
      border: 1px solid #ef9a9a;
    }

    .daily-stats {
      display: grid;
      gap: 10px;
    }

    .daily-stat-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 14px;
      background: #f8fcf7;
      border: 1px solid #e0eddc;
    }

    .daily-stat-item .label {
      color: var(--green-700);
      font-weight: 700;
    }

    .daily-stat-item .value {
      color: var(--green-500);
      font-weight: 800;
      white-space: nowrap;
    }

    .empty-state,
    .loading {
      text-align: center;
      padding: 34px 16px;
      color: #63a668;
      font-weight: 700;
    }

    .fade-in {
      animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 1024px) {
      .content-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .admin-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .btn-group {
        width: 100%;
      }

      .btn-group .btn {
        flex: 1 1 160px;
      }

      .stat-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .card-panel h2 {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 480px) {
      .admin-container {
        padding: 12px;
      }

      .stat-grid {
        grid-template-columns: 1fr;
      }

      .admin-header {
        padding: 16px;
      }

      .admin-header h1 {
        font-size: 1.45rem;
      }

      .btn-group {
        flex-direction: column;
      }

      .btn-group .btn {
        width: 100%;
      }

      .card-panel {
        padding: 16px;
      }

      .date-filter {
        width: 100%;
      }

      .date-filter select,
      .refresh-btn {
        width: 100%;
      }

      .table {
        display: block;
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      .table th,
      .table td {
        white-space: nowrap;
      }

      .daily-stat-item {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <header class="admin-header fade-in">
      <h1><i class="bi bi-speedometer2 me-2"></i>แดชบอร์ดผู้ดูแล</h1>
      <div class="btn-group">
        <a href="/coopgame/admin/questions" class="btn btn-outline-success">
          <i class="bi bi-card-checklist"></i> จัดการคำถาม
        </a>
        <a href="/coopgame/admin/codes" class="btn btn-outline-success">
          <i class="bi bi-ticket-perforated"></i> จัดการรหัส
        </a>
        <% if (adminUser.role === 'super_admin') { %>
          <a href="/coopgame/admin/rooms" class="btn btn-outline-success">
            <i class="bi bi-door-open"></i> จัดการห้อง/ผู้ใช้
          </a>
        <% } %>
        <button type="button" class="btn btn-outline-danger" onclick="clearAdminData()">
          <i class="bi bi-trash3"></i> เคลียร์โค้ด
        </button>
        <button type="button" class="btn btn-danger" onclick="clearPlayerHistory()">
          <i class="bi bi-archive-x"></i> เคลียร์สถิติ
        </button>
        <button type="button" class="btn" style="background: linear-gradient(135deg, #1b5e20 0%, #43a047 100%); color: white; border: none;" onclick="startAdminGame(this)">
          <i class="bi bi-controller"></i> เล่นแบบผู้ดูแล
        </button>
        <a id="publicPlayLink" href="<%= adminUser.roomSlug ? `/coopgame/r/${adminUser.roomSlug}` : '/coopgame/game/start' %>" class="btn" style="background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); color: white; border: none;">
          <i class="bi bi-controller"></i> เล่นเกม
        </a>
        <span style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
          <span style="font-weight:600; color:#2e7d32;"><i class="bi bi-person-circle"></i> <%= adminUser.username %></span>
          <a href="/coopgame/admin/logout" class="btn btn-outline-success">
            <i class="bi bi-box-arrow-right"></i> ออกจากระบบ
          </a>
        </span>
      </div>
    </header>

    <% if (adminUser.role === 'super_admin') { %>
      <section class="admin-header fade-in" style="align-items:flex-end;">
        <div style="flex:1; min-width:240px;">
          <label for="dashboardRoomSelect" style="font-weight:700; color:#2e7d32; margin-bottom:8px; display:block;">
            <i class="bi bi-door-open me-1"></i> เลือกห้องสำหรับแดชบอร์ด
          </label>
          <select id="dashboardRoomSelect" class="form-select" style="border:2px solid #a5d6a7; border-radius:12px; padding:10px 16px;">
            <option value="">กำลังโหลดห้อง...</option>
          </select>
        </div>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a id="roomLeaderboardLink" href="/coopgame/game/leaderboard" class="btn btn-outline-success">
            <i class="bi bi-trophy"></i> Leaderboard ห้องนี้
          </a>
          <a id="roomPublicLink" href="/coopgame/game/start" class="btn btn-outline-success">
            <i class="bi bi-link-45deg"></i> ลิงก์เล่นห้องนี้
          </a>
        </div>
      </section>
    <% } %>

    <div class="stat-grid fade-in">
      <div class="stat-card">
        <h3><i class="bi bi-people-fill me-2"></i>ผู้เล่นทั้งหมด</h3>
        <div class="stat-number" id="totalPlayers">-</div>
        <div class="stat-sub"><i class="bi bi-person"></i> คน</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-controller me-2"></i>เกมที่เล่นเสร็จ</h3>
        <div class="stat-number" id="completedGames">-</div>
        <div class="stat-sub"><i class="bi bi-trophy"></i> เกม</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-star-fill me-2"></i>คะแนนเฉลี่ย</h3>
        <div class="stat-number" id="avgScore">-</div>
        <div class="stat-sub"><i class="bi bi-clipboard-check"></i> จากคำถามทั้งหมด</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-clock-fill me-2"></i>เวลาเฉลี่ย</h3>
        <div class="stat-number" id="avgTime">-</div>
        <div class="stat-sub"><i class="bi bi-stopwatch"></i> วินาที/เกม</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-ticket-perforated me-2"></i>รหัสที่ใช้งานแล้ว</h3>
        <div class="stat-number" id="usedCodes">-</div>
        <div class="stat-sub"><i class="bi bi-check-circle"></i> รหัส</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-card-text me-2"></i>จำนวนคำถามทั้งหมด</h3>
        <div class="stat-number" id="totalQuestions">-</div>
        <div class="stat-sub"><i class="bi bi-list-ol"></i> คำถาม</div>
      </div>
    </div>

    <div class="content-grid fade-in">
      <section class="card-panel">
        <h2>
          <span><i class="bi bi-trophy-fill me-2" style="color:#fdd835;"></i>อันดับผู้เล่น</span>
          <span class="date-filter">
            <select id="leaderboardFilter">
              <option value="all">ทั้งหมด</option>
              <option value="today">วันนี้</option>
              <option value="week">สัปดาห์นี้</option>
              <option value="month">เดือนนี้</option>
            </select>
            <button class="btn btn-sm refresh-btn" type="button" onclick="loadLeaderboard()">
              <i class="bi bi-arrow-clockwise"></i>
            </button>
          </span>
        </h2>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th style="width: 60px;">#</th>
                <th>ชื่อ</th>
                <th>คะแนน</th>
                <th style="width: 100px;">เวลา</th>
                <th style="width: 140px;">วันที่</th>
              </tr>
            </thead>
            <tbody id="leaderboardBody">
              <tr><td colspan="5" class="loading">กำลังโหลด...</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="card-panel">
        <h2>
          <span><i class="bi bi-calendar-check me-2" style="color:#43a047;"></i>สถิติรายวัน</span>
          <button class="btn btn-sm refresh-btn" type="button" onclick="loadDailyStats()">
            <i class="bi bi-arrow-clockwise"></i>
          </button>
        </h2>
        <div id="dailyStats" class="daily-stats">
          <div class="loading">กำลังโหลด...</div>
        </div>
      </section>
    </div>

    <section class="card-panel fade-in" style="margin-top: 20px;">
      <h2>
        <span><i class="bi bi-controller me-2" style="color:#43a047;"></i>เกมล่าสุด</span>
        <button class="btn btn-sm refresh-btn" type="button" onclick="loadRecentGames()">
          <i class="bi bi-arrow-clockwise"></i>
        </button>
      </h2>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th style="width: 60px;">#</th>
              <th>ชื่อ</th>
              <th>คะแนน</th>
              <th style="width: 110px;">เวลา</th>
              <th style="width: 180px;">วันที่</th>
              <th style="width: 130px;">สถานะ</th>
            </tr>
          </thead>
          <tbody id="recentGamesBody">
            <tr><td colspan="6" class="loading">กำลังโหลด...</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let dashboardTotalQuestions = 9;
    const adminRole = '<%= adminUser.role %>';
    const fixedRoomId = <%= adminUser.roomId || 'null' %>;
    const fixedRoomSlug = '<%= adminUser.roomSlug || '' %>';
    let dashboardRooms = [];

    document.addEventListener('DOMContentLoaded', () => {
      initializeDashboardRoom().then(() => {
        loadStats();
        loadLeaderboard();
        loadDailyStats();
        loadRecentGames();
      });
    });

    async function initializeDashboardRoom() {
      if (adminRole !== 'super_admin') {
        updateRoomLinks();
        return;
      }

      const roomSelect = document.getElementById('dashboardRoomSelect');
      try {
        const response = await fetch('/coopgame/admin/api/rooms');
        const result = await response.json();
        dashboardRooms = result.success && Array.isArray(result.data)
          ? result.data.filter(room => room.status === 'active')
          : [];

        roomSelect.innerHTML = dashboardRooms.map(room => (
          `<option value="${room.id}" data-slug="${escapeHtml(room.slug)}">${escapeHtml(room.name)} (${escapeHtml(room.slug)})</option>`
        )).join('');

        if (!dashboardRooms.length) {
          roomSelect.innerHTML = '<option value="">ยังไม่มีห้อง</option>';
        }

        roomSelect.addEventListener('change', () => {
          updateRoomLinks();
          loadStats();
          loadLeaderboard();
          loadDailyStats();
          loadRecentGames();
        });
      } catch (error) {
        console.error('Error loading dashboard rooms:', error);
        roomSelect.innerHTML = '<option value="">โหลดห้องไม่ได้</option>';
      }

      updateRoomLinks();
    }

    function getSelectedRoom() {
      if (adminRole !== 'super_admin') {
        return fixedRoomId && fixedRoomSlug
          ? { id: fixedRoomId, slug: fixedRoomSlug }
          : null;
      }

      const roomSelect = document.getElementById('dashboardRoomSelect');
      const roomId = roomSelect && roomSelect.value ? parseInt(roomSelect.value, 10) : null;
      return dashboardRooms.find(room => room.id === roomId) || null;
    }

    function getSelectedRoomId() {
      return getSelectedRoom()?.id || null;
    }

    function getSelectedRoomSlug() {
      return getSelectedRoom()?.slug || '';
    }

    function withRoomParam(url) {
      const roomId = getSelectedRoomId();
      if (!roomId) return url;
      return `${url}${url.includes('?') ? '&' : '?'}roomId=${roomId}`;
    }

    function getLeaderboardApiUrl(limit) {
      const slug = getSelectedRoomSlug();
      const baseUrl = slug
        ? `/coopgame/r/${slug}/api/leaderboard`
        : '/coopgame/game/api/leaderboard';
      return `${baseUrl}?limit=${limit}`;
    }

    function updateRoomLinks() {
      const slug = getSelectedRoomSlug();
      const playUrl = slug ? `/coopgame/r/${slug}` : '/coopgame/game/start';
      const leaderboardUrl = slug ? `/coopgame/r/${slug}/leaderboard` : '/coopgame/game/leaderboard';

      const publicPlayLink = document.getElementById('publicPlayLink');
      if (publicPlayLink) publicPlayLink.href = playUrl;

      const roomPublicLink = document.getElementById('roomPublicLink');
      if (roomPublicLink) roomPublicLink.href = playUrl;

      const roomLeaderboardLink = document.getElementById('roomLeaderboardLink');
      if (roomLeaderboardLink) roomLeaderboardLink.href = leaderboardUrl;
    }

    async function loadStats() {
      try {
        const response = await fetch(withRoomParam('/coopgame/admin/api/stats'));
        const result = await response.json();

        if (result.success && result.data) {
          const stats = result.data;
          dashboardTotalQuestions = parseInt(stats.gameSettings?.totalQuestions, 10) || 9;
          document.getElementById('totalPlayers').textContent = stats.players || 0;
          document.getElementById('completedGames').textContent = stats.completedGames || 0;
          document.getElementById('avgScore').textContent = (stats.averageScore || 0).toFixed(1);
          document.getElementById('avgTime').textContent = (stats.averageTime || 0).toFixed(0);

          document.getElementById('usedCodes').textContent = stats.codes?.used || 0;
          document.getElementById('totalQuestions').textContent = stats.questions?.total || 0;
        }
      } catch (error) {
        console.error('Error loading stats:', error);
      }
    }

    async function loadLeaderboard() {
      const filter = document.getElementById('leaderboardFilter').value;
      const tbody = document.getElementById('leaderboardBody');

      try {
        const response = await fetch(getLeaderboardApiUrl(20));
        const result = await response.json();

        if (result.success && result.data && result.data.length > 0) {
          const now = new Date();
          const filtered = result.data.filter((row) => {
            const dateValue = row.started_at || row.createdAt || row.finishedAt;
            if (!dateValue || filter === 'all') return true;

            const d = new Date(dateValue);
            if (filter === 'today') {
              const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
              return d >= today;
            }
            if (filter === 'week') {
              const weekAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
              return d >= weekAgo;
            }
            if (filter === 'month') {
              const monthAgo = new Date(now.getFullYear(), now.getMonth() - 1, now.getDate());
              return d >= monthAgo;
            }
            return true;
          });

          tbody.innerHTML = filtered.map((player, index) => {
            const rankClass = index < 3 ? `rank-${index + 1}` : '';
            const scoreClass = player.score >= 7 ? 'score-high' : player.score >= 4 ? 'score-medium' : 'score-low';
            const dateValue = player.started_at || player.createdAt || player.finishedAt;
            const dateText = dateValue
              ? new Date(dateValue).toLocaleDateString('th-TH', {
                  day: '2-digit',
                  month: 'short',
                  year: '2-digit'
                })
              : '-';

            return `
              <tr>
                <td><span class="rank-badge ${rankClass}">${index + 1}</span></td>
                <td><strong>${escapeHtml(player.playerName || '-')}</strong></td>
                <td><span class="score-badge ${scoreClass}">${player.score || 0}/${dashboardTotalQuestions}</span></td>
                <td>${player.totalTime || 0} วินาที</td>
                <td>${dateText}</td>
              </tr>
            `;
          }).join('');
        } else {
          tbody.innerHTML = '<tr><td colspan="5" class="empty-state">ยังไม่มีข้อมูล</td></tr>';
        }
      } catch (error) {
        console.error('Error loading leaderboard:', error);
        tbody.innerHTML = '<tr><td colspan="5" class="empty-state">เกิดข้อผิดพลาด</td></tr>';
      }
    }

    async function loadDailyStats() {
      const container = document.getElementById('dailyStats');

      try {
        const response = await fetch(withRoomParam('/coopgame/admin/api/stats'));
        const result = await response.json();

        if (result.success && result.data) {
          const stats = result.data;
          container.innerHTML = `
            <div class="daily-stat-item">
              <span class="label">ผู้เล่นทั้งหมด</span>
              <span class="value">${stats.players || 0} คน</span>
            </div>
            <div class="daily-stat-item">
              <span class="label">เกมที่เล่นเสร็จ</span>
              <span class="value">${stats.completedGames || 0} เกม</span>
            </div>
            <div class="daily-stat-item">
              <span class="label">คะแนนเฉลี่ย</span>
              <span class="value">${(stats.averageScore || 0).toFixed(1)} / ${dashboardTotalQuestions}</span>
            </div>
            <div class="daily-stat-item">
              <span class="label">เวลาเฉลี่ย</span>
              <span class="value">${(stats.averageTime || 0).toFixed(0)} วินาที</span>
            </div>
            <div class="daily-stat-item">
              <span class="label">รหัสที่ใช้งานแล้ว</span>
              <span class="value">${stats.codes?.used || 0} รหัส</span>
            </div>
            <div class="daily-stat-item">
              <span class="label">จำนวนคำถาม</span>
              <span class="value">${stats.questions?.total || 0} ข้อ</span>
            </div>
          `;
        } else {
          container.innerHTML = '<div class="empty-state">ยังไม่มีข้อมูล</div>';
        }
      } catch (error) {
        console.error('Error loading daily stats:', error);
        container.innerHTML = '<div class="empty-state">เกิดข้อผิดพลาด</div>';
      }
    }

    async function loadRecentGames() {
      const tbody = document.getElementById('recentGamesBody');

      try {
        const response = await fetch(getLeaderboardApiUrl(10));
        const result = await response.json();

        if (result.success && result.data && result.data.length > 0) {
          tbody.innerHTML = result.data.map((player, index) => {
            const dateValue = player.started_at || player.createdAt || player.finishedAt;
            const dateText = dateValue
              ? new Date(dateValue).toLocaleDateString('th-TH', {
                  day: '2-digit',
                  month: 'short',
                  year: '2-digit',
                  hour: '2-digit',
                  minute: '2-digit'
                })
              : '-';

            const statusBadge = player.score >= 7
              ? '<span class="score-badge score-high">ดีมาก</span>'
              : player.score >= 4
                ? '<span class="score-badge score-medium">ปานกลาง</span>'
                : '<span class="score-badge score-low">ต้องพัฒนา</span>';

            return `
              <tr>
                <td>${index + 1}</td>
                <td><strong>${escapeHtml(player.playerName || '-')}</strong></td>
                <td>${player.score || 0}/${dashboardTotalQuestions}</td>
                <td>${player.totalTime || 0} วินาที</td>
                <td>${dateText}</td>
                <td>${statusBadge}</td>
              </tr>
            `;
          }).join('');
        } else {
          tbody.innerHTML = '<tr><td colspan="6" class="empty-state">ยังไม่มีข้อมูล</td></tr>';
        }
      } catch (error) {
        console.error('Error loading recent games:', error);
        tbody.innerHTML = '<tr><td colspan="6" class="empty-state">เกิดข้อผิดพลาด</td></tr>';
      }
    }

    async function clearAdminData() {
      const confirmed = confirm('คุณต้องการเคลียร์โค้ดที่ลบได้หรือไม่?\n\nการทำงานนี้จะลบเฉพาะโค้ดที่ยังไม่ได้ใช้งานและโค้ดที่หมดอายุ');
      if (!confirmed) return;

      try {
        const response = await fetch(withRoomParam('/coopgame/admin/api/codes/clear'), {
          method: 'POST'
        });
        const result = await response.json();

        if (result.success) {
          const deletedCount = result.data?.count || 0;
          alert(`เคลียร์โค้ดสำเร็จ ${deletedCount} รายการ`);
          await loadStats();
          await loadLeaderboard();
          await loadDailyStats();
          await loadRecentGames();
        } else {
          alert('❌ ' + result.message);
        }
      } catch (error) {
        console.error('Error clearing codes:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    }

    async function clearPlayerHistory() {
      const confirmed = confirm('คุณต้องการเคลียร์สถิติและประวัติผู้เล่นทั้งหมดหรือไม่?\n\nการทำงานนี้จะลบประวัติการเล่น คะแนน และ leaderboard ทั้งหมด');
      if (!confirmed) return;

      const typed = prompt('พิมพ์ DELETE เพื่อยืนยันการลบประวัติผู้เล่นทั้งหมด');
      if (typed !== 'DELETE') return;

      try {
        const response = await fetch(withRoomParam('/coopgame/admin/api/history/clear'), {
          method: 'POST'
        });
        const result = await response.json();

        if (result.success) {
          const deletedCount = result.data?.count || 0;
          alert(`เคลียร์สถิติสำเร็จ ${deletedCount} รายการ`);
          await loadStats();
          await loadLeaderboard();
          await loadDailyStats();
          await loadRecentGames();
        } else {
          alert('❌ ' + result.message);
        }
      } catch (error) {
        console.error('Error clearing player history:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    }

    async function startAdminGame(button) {
      const confirmed = confirm('เริ่มเกมแบบผู้ดูแลโดยไม่ใช้รหัสใช่ไหม?');
      if (!confirmed) return;

      if (button) button.disabled = true;

      try {
        const response = await fetch('/coopgame/game/api/admin/start', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ roomId: getSelectedRoomId() })
        });

        if (response.status === 401) {
          window.location.href = '/coopgame/admin/login';
          return;
        }

        const result = await response.json();

        if (result.success && result.data?.attemptId) {
          const slug = getSelectedRoomSlug();
          window.location.href = slug
            ? `/coopgame/r/${slug}/play?attemptId=${result.data.attemptId}`
            : `/coopgame/game/play?attemptId=${result.data.attemptId}`;
          return;
        }

        alert('❌ ' + (result.message || 'ไม่สามารถเริ่มเกมได้'));
      } catch (error) {
        console.error('Error starting admin game:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      } finally {
        if (button) button.disabled = false;
      }
    }

    function escapeHtml(text) {
      if (!text) return '-';
      return String(text)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    setInterval(() => {
      loadStats();
      loadLeaderboard();
      loadDailyStats();
      loadRecentGames();
    }, 30000);

    document.getElementById('leaderboardFilter').addEventListener('change', loadLeaderboard);
  </script>
</body>
</html>
