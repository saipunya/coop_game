<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>จัดการรหัส - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700;800&display=swap');
    
    body {
      background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 50%, #a5d6a7 100%);
      min-height: 100vh;
      font-family: 'Sarabun', -apple-system, BlinkMacSystemFont, sans-serif;
    }
    .admin-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 20px;
    }
    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      padding: 20px 30px;
      background: rgba(255, 255, 255, 0.95);
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(46, 125, 50, 0.1);
      backdrop-filter: blur(10px);
    }
    .admin-header h1 {
      background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-weight: 800;
      font-size: 2rem;
      margin: 0;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }
    .stat-card {
      background: rgba(255, 255, 255, 0.95);
      padding: 20px;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(46, 125, 50, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(200, 230, 201, 0.5);
      transition: transform 0.3s ease;
    }
    .stat-card:hover {
      transform: translateY(-5px);
    }
    .stat-card h3 {
      color: #2e7d32;
      font-size: 14px;
      margin-bottom: 10px;
      font-weight: 600;
    }
    .stat-card .number {
      font-size: 32px;
      font-weight: bold;
      background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .card {
      background: rgba(255, 255, 255, 0.95);
      padding: 25px;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(46, 125, 50, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(200, 230, 201, 0.5);
      margin-bottom: 20px;
    }
    .card h2 {
      margin-bottom: 20px;
      color: #1b5e20;
      font-weight: 700;
    }
    .generate-form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 20px;
    }
    .form-control, .form-select {
      border: 2px solid #a5d6a7;
      border-radius: 12px;
      padding: 10px 16px;
      transition: all 0.3s ease;
    }
    .form-control:focus, .form-select:focus {
      border-color: #43a047;
      box-shadow: 0 0 0 4px rgba(67, 160, 71, 0.1);
      background: white;
    }
    .form-label {
      font-weight: 600;
      color: #2e7d32;
    }
    .btn-group {
      display: flex;
      gap: 10px;
      margin-top: 20px;
      flex-wrap: wrap;
    }
    .table {
      color: #2e7d32;
    }
    .table thead th {
      background: linear-gradient(135deg, #e8f5e9 0%, #f1f8e9 100%);
      border-bottom: 2px solid #c8e6c9;
      color: #1b5e20;
      font-weight: 700;
      padding: 12px;
    }
    .table tbody td {
      padding: 12px;
      border-bottom: 1px solid #e8f5e9;
    }
    .table tbody tr:hover {
      background: rgba(200, 230, 201, 0.3);
    }
    .status-badge {
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
    }
    .status-unused { background: #e8f5e9; color: #1b5e20; border: 1px solid #a5d6a7; }
    .status-in_progress { background: #fff8e1; color: #f57f17; border: 1px solid #ffe082; }
    .status-used { background: #e3f2fd; color: #1565c0; border: 1px solid #90caf9; }
    .status-expired { background: #ffebee; color: #c62828; border: 1px solid #ef9a9a; }
    .code-text {
      font-family: monospace;
      font-size: 16px;
      font-weight: bold;
      letter-spacing: 2px;
      color: #2e7d32;
    }
    .filter-group {
      display: flex;
      gap: 15px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .search-box {
      margin-bottom: 20px;
    }
    .generated-codes {
      background: #f1f8e9;
      padding: 20px;
      border-radius: 16px;
      margin-top: 20px;
      display: none;
      border: 2px solid #c8e6c9;
    }
    .generated-codes.show {
      display: block;
    }
    .generated-codes h3 {
      margin-bottom: 15px;
      color: #1b5e20;
    }
    .codes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 10px;
    }
    .code-item {
      background: white;
      padding: 10px;
      border-radius: 10px;
      text-align: center;
      font-family: monospace;
      font-weight: bold;
      font-size: 18px;
      letter-spacing: 2px;
      color: #2e7d32;
      border: 1px solid #c8e6c9;
    }
    .empty-state {
      text-align: center;
      padding: 40px;
      color: #66bb6a;
    }
    .loading {
      text-align: center;
      padding: 40px;
      color: #43a047;
    }
    .fade-in {
      animation: fadeIn 0.6s ease-out;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media (max-width: 768px) {
      .generate-form {
        grid-template-columns: 1fr;
      }
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .admin-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
      }
      .admin-header > div {
        width: 100%;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }
      .admin-header > div .btn {
        flex: 1 1 160px;
      }
      .btn-group {
        flex-wrap: wrap;
      }
      .btn-group .btn {
        flex: 1 1 180px;
      }
      .filter-group {
        flex-wrap: wrap;
      }
      .filter-group select {
        flex: 1 1 180px;
      }
      .search-box input {
        width: 100%;
      }
      .codes-grid {
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      }
      .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
      .table th, .table td {
        white-space: nowrap;
      }
      .code-text {
        font-size: 14px;
        letter-spacing: 1px;
      }
    }
    @media (max-width: 480px) {
      .admin-container {
        padding: 12px;
      }
      .stats-grid {
        grid-template-columns: 1fr;
      }
      .card {
        padding: 16px;
      }
      .admin-header > div, .btn-group {
        flex-direction: column;
      }
      .admin-header > div .btn, .btn-group .btn {
        width: 100%;
      }
      .generate-form {
        gap: 12px;
      }
      .codes-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .code-item {
        font-size: 15px;
        letter-spacing: 1px;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <header class="admin-header fade-in">
      <h1><i class="bi bi-ticket-perforated me-2"></i>จัดการรหัสเกม</h1>
      <div class="btn-group">
        <a href="/coopgame/admin/" class="btn btn-outline-success">
          <i class="bi bi-speedometer2"></i> Dashboard
        </a>
        <a href="/coopgame/admin/questions" class="btn btn-outline-success">
          <i class="bi bi-card-checklist"></i> จัดการคำถาม
        </a>
        <a href="/coopgame/game/start" class="btn" style="background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); color: white; border: none;">
          <i class="bi bi-controller"></i> เล่นเกม
        </a>
        <span style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
          <span style="font-weight:600; color:#2e7d32;"><i class="bi bi-person-circle"></i> <%= adminUser.username %></span>
          <a href="/coopgame/admin/logout" class="btn btn-outline-success">
            <i class="bi bi-box-arrow-right"></i> ออกจากระบบ
          </a>
        </span>
      </div>
    </header>

    <!-- Stats -->
    <div class="stats-grid fade-in">
      <div class="stat-card">
        <h3><i class="bi bi-ticket-perforated me-2"></i>รหัสทั้งหมด</h3>
        <div class="number" id="totalCodes">-</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-check-circle me-2"></i>รหัสว่าง</h3>
        <div class="number" id="unusedCodes">-</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-controller me-2"></i>กำลังเล่น</h3>
        <div class="number" id="inProgressCodes">-</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-check2-all me-2"></i>ใช้แล้ว</h3>
        <div class="number" id="usedCodes">-</div>
      </div>
      <div class="stat-card">
        <h3><i class="bi bi-clock-history me-2"></i>หมดอายุ</h3>
        <div class="number" id="expiredCodes">-</div>
      </div>
    </div>

    <!-- Generate Codes -->
    <div class="card fade-in">
      <h2><i class="bi bi-plus-circle me-2" style="color: #43a047;"></i>สร้างรหัสใหม่</h2>
      <form id="generateForm" class="generate-form">
        <div class="form-group">
          <label for="count" class="form-label">จำนวนรหัส *</label>
          <input type="number" id="count" name="count" class="form-control" min="1" max="1000" value="10" required>
        </div>
        <div class="form-group">
          <label for="expiry" class="form-label">หมดอายุ (ชั่วโมง)</label>
          <select id="expiry" name="expiry" class="form-select">
            <option value="24">24 ชั่วโมง (1 วัน)</option>
            <option value="48">48 ชั่วโมง (2 วัน)</option>
            <option value="72">72 ชั่วโมง (3 วัน)</option>
            <option value="168">168 ชั่วโมง (7 วัน)</option>
            <option value="720">720 ชั่วโมง (30 วัน)</option>
          </select>
        </div>
      </form>
      <div class="btn-group">
        <button type="submit" form="generateForm" class="btn" style="background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); color: white; border: none; border-radius: 12px; padding: 10px 30px;">
          <i class="bi bi-dice-5"></i> สร้างรหัส
        </button>
        <button type="button" class="btn btn-outline-success" onclick="markExpired()" style="border-radius: 12px;">
          <i class="bi bi-clock"></i> ทำเครื่องหมายหมดอายุ
        </button>
        <button type="button" class="btn" onclick="clearCodes()" style="background: #e53935; color: white; border: none; border-radius: 12px; padding: 10px 30px;">
          <i class="bi bi-trash"></i> เคลียร์รหัสทั้งหมด
        </button>
      </div>
       
      <div id="generatedCodes" class="generated-codes">
        <h3><i class="bi bi-check2-circle me-2" style="color: #43a047;"></i>รหัสที่สร้าง:</h3>
        <div id="codesGrid" class="codes-grid"></div>
        <button class="btn btn-outline-success" onclick="copyAllCodes()" style="margin-top: 15px; border-radius: 12px;">
          <i class="bi bi-clipboard-check"></i> คัดลอกทั้งหมด
        </button>
      </div>
    </div>

    <!-- Codes List -->
    <div class="card fade-in">
      <h2><i class="bi bi-list-ul me-2" style="color: #43a047;"></i>รายการรหัส</h2>
      
      <div class="filter-group">
        <select id="filterStatus" class="form-select" style="flex: 1 1 200px;">
          <option value="">ทุกสถานะ</option>
          <option value="unused">ว่าง</option>
          <option value="in_progress">กำลังเล่น</option>
          <option value="used">ใช้แล้ว</option>
          <option value="expired">หมดอายุ</option>
        </select>
        <select id="limit" class="form-select" style="flex: 1 1 200px;">
          <option value="20">20 รายการ</option>
          <option value="50">50 รายการ</option>
          <option value="100">100 รายการ</option>
          <option value="500">500 รายการ</option>
        </select>
      </div>

      <div class="search-box">
        <input type="text" id="searchInput" class="form-control" placeholder="🔍 ค้นหารหัส...">
      </div>

      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th style="width: 50px;">#</th>
              <th>รหัส</th>
              <th style="width: 100px;">สถานะ</th>
              <th style="width: 150px;">สร้างเมื่อ</th>
              <th style="width: 150px;">หมดอายุ</th>
              <th style="width: 100px;">ใช้เมื่อ</th>
              <th style="width: 120px;">จัดการ</th>
            </tr>
          </thead>
          <tbody id="codesList">
            <tr><td colspan="7" class="loading">กำลังโหลด...</td></tr>
          </tbody>
        </table>
      </div>

      <div class="d-flex justify-content-center gap-2 mt-3" id="pagination"></div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    let currentCodes = [];
    let generatedCodesList = [];

    // Load codes on page load
    document.addEventListener('DOMContentLoaded', () => {
      loadStats();
      loadCodes();
    });

    // Load statistics
    async function loadStats() {
      try {
        const response = await fetch('/coopgame/admin/api/codes/stats');
        const result = await response.json();
        
        if (result.success && result.data) {
          const stats = result.data;
          document.getElementById('totalCodes').textContent = stats.total || 0;
          document.getElementById('unusedCodes').textContent = stats.unused || 0;
          document.getElementById('inProgressCodes').textContent = stats.inProgress || 0;
          document.getElementById('usedCodes').textContent = stats.used || 0;
          document.getElementById('expiredCodes').textContent = stats.expired || 0;
        }
      } catch (error) {
        console.error('Error loading stats:', error);
      }
    }

    // Load codes
    async function loadCodes() {
      const status = document.getElementById('filterStatus').value;
      const limit = document.getElementById('limit').value;
      const searchTerm = document.getElementById('searchInput').value.toUpperCase();
      const tbody = document.getElementById('codesList');
      
      try {
        const response = await fetch(`/coopgame/admin/api/codes?status=${status}&limit=${limit}`);
        const result = await response.json();
        
        if (result.success && result.data) {
          const payload = result.data;
          currentCodes = Array.isArray(payload) ? payload : (payload.codes || []);
          
          // Filter by search term
          let filtered = currentCodes;
          if (searchTerm) {
            filtered = currentCodes.filter(c => c.code.toUpperCase().includes(searchTerm));
          }

          if (filtered.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="empty-state">ไม่พบรหัส</td></tr>';
            return;
          }

          tbody.innerHTML = filtered.map((c, index) => {
            const statusClass = `status-${c.status}`;
            const statusText = {
              'unused': 'ว่าง',
              'in_progress': 'ใช้แล้ว',
              'used': 'ใช้แล้ว',
              'expired': 'หมดอายุ'
            }[c.status] || c.status;

            const createdAt = new Date(c.created_at).toLocaleString('th-TH');
            const expiresAt = new Date(c.expires_at).toLocaleString('th-TH');
            const usedAt = c.used_at ? new Date(c.used_at).toLocaleString('th-TH') : '-';
            const canDelete = !['used', 'in_progress'].includes(c.status);
            const deleteButton = canDelete
              ? `<button type='button' class='btn btn-danger btn-sm' onclick="deleteCode(${c.id}, '${c.code}')">🗑️ ลบ</button>`
              : `<button type="button" class="btn btn-danger btn-sm" disabled title="ลบได้เฉพาะรหัสที่ยังไม่ถูกใช้งาน">🗑️ ลบ</button>`;

            return `
              <tr>
                <td>${index + 1}</td>
                <td><span class="code-text">${c.code}</span></td>
                <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                <td>${createdAt}</td>
                <td>${expiresAt}</td>
                <td>${usedAt}</td>
                <td><div class="action-buttons">${deleteButton}</div></td>
              </tr>
            `;
          }).join('');
        } else {
          tbody.innerHTML = '<tr><td colspan="7" class="empty-state">ไม่พบรหัส</td></tr>';
        }
      } catch (error) {
        console.error('Error loading codes:', error);
        tbody.innerHTML = '<tr><td colspan="7" class="empty-state">เกิดข้อผิดพลาด</td></tr>';
      }
    }

    // Generate codes
    document.getElementById('generateForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const count = parseInt(document.getElementById('count').value);
      const expiry = parseInt(document.getElementById('expiry').value);

      if (count < 1 || count > 1000) {
        alert('จำนวนรหัสต้องอยู่ระหว่าง 1-1000');
        return;
      }

      try {
        const response = await fetch('/coopgame/admin/api/codes/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ count, expiryHours: expiry })
        });

        const result = await response.json();

        if (result.success && result.data) {
          generatedCodesList = result.data.codes || [];
          displayGeneratedCodes(generatedCodesList);
          alert(`✅ สร้างรหัส ${generatedCodesList.length} รหัสสำเร็จ!`);
          loadStats();
          loadCodes();
        } else {
          alert('❌ ' + result.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    });

    // Display generated codes
    function displayGeneratedCodes(codes) {
      const container = document.getElementById('generatedCodes');
      const grid = document.getElementById('codesGrid');
      
      if (codes.length === 0) {
        container.classList.remove('show');
        return;
      }

      grid.innerHTML = codes.map(code => `<div class="code-item">${code}</div>`).join('');
      container.classList.add('show');
    }

    // Copy all generated codes
    function copyAllCodes() {
      if (generatedCodesList.length === 0) return;
      
      const text = generatedCodesList.join('\n');
      navigator.clipboard.writeText(text).then(() => {
        alert('✅ คัดลอกรหัสทั้งหมดแล้ว');
      }).catch(() => {
        alert('ไม่สามารถคัดลอกได้');
      });
    }

    // Mark expired codes
    async function markExpired() {
      if (!confirm('⚠️ คุณแน่ใจหรือไม่ที่จะทำเครื่องหมายรหัสที่หมดอายุ?')) return;

      try {
        const response = await fetch('/coopgame/admin/api/codes/mark-expired', {
          method: 'POST'
        });

        const result = await response.json();

        if (result.success) {
          alert(`✅ ทำเครื่องหมายรหัสหมดอายุ ${result.data.count} รหัส`);
          loadStats();
          loadCodes();
        } else {
          alert('❌ ' + result.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    }

    // Clear all codes
    async function clearCodes() {
      if (!confirm('⚠️ ต้องการเคลียร์รหัสทั้งหมดออกจากระบบถาวรหรือไม่? ประวัติเกมทั้งหมดที่ผูกกับรหัสจะถูกลบตามไปด้วย')) return;

      try {
        const response = await fetch('/coopgame/admin/api/codes/clear', {
          method: 'POST'
        });

        const result = await response.json();

        if (result.success) {
          alert(`✅ เคลียร์รหัสทั้งหมด ${result.data.count} รหัสสำเร็จ`);
          loadStats();
          loadCodes();
        } else {
          alert('❌ ' + result.message);
        }
      } catch (error) {
        console.error('Error clearing codes:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    }

    // Delete code
    async function deleteCode(id, code) {
      if (!confirm(`⚠️ ต้องการลบรหัส ${code} ใช่หรือไม่?`)) return;

      try {
        const response = await fetch(`/coopgame/admin/api/codes/${id}`, {
          method: 'DELETE'
        });

        const result = await response.json();

        if (response.ok && result.success) {
          alert(`✅ ลบรหัส ${code} เรียบร้อยแล้ว`);
          loadStats();
          loadCodes();
        } else {
          alert('❌ ' + (result.message || 'ไม่สามารถลบรหัสได้'));
        }
      } catch (error) {
        console.error('Error deleting code:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    }

    // Filter and search handlers
    document.getElementById('filterStatus').addEventListener('change', loadCodes);
    document.getElementById('limit').addEventListener('change', loadCodes);
    document.getElementById('searchInput').addEventListener('input', loadCodes);
  </script>
</body>
</html>
