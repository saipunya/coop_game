<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>จัดการคำถาม - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700;800&display=swap');
    
    body {
      background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 50%, #a5d6a7 100%);
      min-height: 100vh;
      font-family: 'Sarabun', -apple-system, BlinkMacSystemFont, sans-serif;
    }
    .admin-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }
    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      padding: 20px 30px;
      background: rgba(255, 255, 255, 0.95);
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(46, 125, 50, 0.1);
      backdrop-filter: blur(10px);
    }
    .admin-header h1 {
      background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-weight: 800;
      font-size: 2rem;
      margin: 0;
    }
    .question-form {
      background: rgba(255, 255, 255, 0.95);
      padding: 25px;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(46, 125, 50, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(200, 230, 201, 0.5);
      margin-bottom: 30px;
    }
    .question-form h3 {
      margin-bottom: 20px;
      color: #1b5e20;
      font-weight: 700;
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 15px;
      margin-bottom: 15px;
    }
    .form-group {
      margin-bottom: 15px;
    }
    .form-group label {
      display: block;
      margin-bottom: 5px;
      font-weight: 600;
      color: #2e7d32;
    }
    .form-control, .form-select {
      width: 100%;
      padding: 10px 16px;
      border: 2px solid #a5d6a7;
      border-radius: 12px;
      font-size: 14px;
      transition: all 0.3s ease;
    }
    .form-control:focus, .form-select:focus {
      border-color: #43a047;
      box-shadow: 0 0 0 4px rgba(67, 160, 71, 0.1);
      background: white;
    }
    .form-control, .form-select, textarea {
      font-size: 14px;
    }
    textarea.form-control {
      min-height: 80px;
      resize: vertical;
    }
    .options-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 15px;
    }
    .option-input {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px;
      background: #f1f8e9;
      border-radius: 12px;
      border: 2px solid #c8e6c9;
    }
    .option-input input[type="radio"] {
      width: 20px;
      height: 20px;
      accent-color: #43a047;
    }
    .option-input input[type="text"] {
      flex: 1;
      border: none;
      background: transparent;
      padding: 5px;
    }
    .option-input input[type="text"]:focus {
      outline: none;
    }
    .btn-group {
      display: flex;
      gap: 10px;
      margin-top: 20px;
      flex-wrap: wrap;
    }
    .table {
      color: #2e7d32;
      border-radius: 10px;
      overflow: hidden;
    }
    .table thead th {
      background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
      color: white;
      font-weight: 600;
      padding: 12px 15px;
      border: none;
    }
    .table tbody td {
      padding: 12px 15px;
      border-bottom: 1px solid #e8f5e9;
    }
    .table tbody tr:hover {
      background: rgba(200, 230, 201, 0.3);
    }
    .difficulty-badge {
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
    }
    .difficulty-easy {
      background: #e8f5e9;
      color: #1b5e20;
      border: 1px solid #a5d6a7;
    }
    .difficulty-medium {
      background: #fff8e1;
      color: #f57f17;
      border: 1px solid #ffe082;
    }
    .difficulty-hard {
      background: #ffebee;
      color: #c62828;
      border: 1px solid #ef9a9a;
    }
    .action-btns {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .btn-sm {
      padding: 8px 12px;
      font-size: 13px;
      border-radius: 10px;
    }
    .stats-cards {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-bottom: 30px;
    }
    .stat-card {
      background: rgba(255, 255, 255, 0.95);
      padding: 20px;
      border-radius: 20px;
      text-align: center;
      box-shadow: 0 10px 30px rgba(46, 125, 50, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(200, 230, 201, 0.5);
      transition: transform 0.3s ease;
    }
    .stat-card:hover {
      transform: translateY(-5px);
    }
    .stat-card .number {
      font-size: 36px;
      font-weight: bold;
      background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .stat-card .label {
      color: #2e7d32;
      margin-top: 5px;
      font-weight: 600;
    }
    .hidden {
      display: none;
    }
    .search-box {
      margin-bottom: 20px;
    }
    .search-box input {
      padding: 10px 16px;
      width: 300px;
      border: 2px solid #a5d6a7;
      border-radius: 12px;
      font-size: 14px;
      transition: all 0.3s ease;
    }
    .search-box input:focus {
      border-color: #43a047;
      box-shadow: 0 0 0 4px rgba(67, 160, 71, 0.1);
      outline: none;
      background: white;
    }
    .filter-group {
      display: flex;
      gap: 15px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .filter-group select {
      padding: 10px 16px;
      border: 2px solid #a5d6a7;
      border-radius: 12px;
      font-size: 14px;
      background: #f1f8e9;
      color: #2e7d32;
      transition: all 0.3s ease;
    }
    .filter-group select:focus {
      border-color: #43a047;
      box-shadow: 0 0 0 4px rgba(67, 160, 71, 0.1);
      outline: none;
    }

    .fade-in {
      animation: fadeIn 0.6s ease-out;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 768px) {
      .form-row {
        grid-template-columns: 1fr;
      }
      .options-grid {
        grid-template-columns: 1fr;
      }
      .stats-cards {
        grid-template-columns: repeat(2, 1fr);
      }
      .admin-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
      }
      .admin-header > div {
        width: 100%;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }
      .admin-header > div .btn {
        flex: 1 1 160px;
      }
      .question-form {
        padding: 20px;
      }
      .btn-group {
        flex-wrap: wrap;
      }
      .btn-group .btn {
        flex: 1 1 180px;
      }
      .search-box input {
        width: 100%;
      }
      .filter-group {
        flex-wrap: wrap;
      }
      .filter-group select {
        flex: 1 1 180px;
      }
      .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
      .table th, .table td {
        white-space: nowrap;
      }
    }

    @media (max-width: 480px) {
      .admin-container {
        padding: 12px;
      }
      .stats-cards {
        grid-template-columns: 1fr;
      }
      .question-form {
        padding: 16px;
      }
      .btn-group, .admin-header > div {
        flex-direction: column;
      }
      .btn-group .btn, .admin-header > div .btn {
        width: 100%;
      }
      .form-control, .form-select, textarea {
        font-size: 16px;
      }
      .action-btns {
        flex-direction: column;
      }
      .action-btns .btn {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <header class="admin-header fade-in">
      <h1><i class="bi bi-card-checklist me-2"></i>จัดการคำถาม</h1>
      <div class="btn-group">
        <a href="/coopgame/admin/" class="btn btn-outline-success">
          <i class="bi bi-speedometer2"></i> Dashboard
        </a>
        <a href="/coopgame/admin/codes" class="btn btn-outline-success">
          <i class="bi bi-ticket-perforated"></i> จัดการรหัส
        </a>
        <a href="/coopgame/game/start" class="btn" style="background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); color: white; border: none;">
          <i class="bi bi-controller"></i> เล่นเกม
        </a>
        <span style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
          <span style="font-weight:600; color:#2e7d32;"><i class="bi bi-person-circle"></i> <%= adminUser.username %></span>
          <a href="/coopgame/admin/logout" class="btn btn-outline-success">
            <i class="bi bi-box-arrow-right"></i> ออกจากระบบ
          </a>
        </span>
      </div>
    </header>

    <!-- Stats -->
    <div class="stats-cards fade-in">
      <div class="stat-card">
        <div class="number" id="totalQuestions">-</div>
        <div class="label"><i class="bi bi-card-text me-1"></i>คำถามทั้งหมด</div>
      </div>
      <div class="stat-card">
        <div class="number" id="easyCount">-</div>
        <div class="label"><i class="bi bi-emoji-smile me-1"></i>คำถามง่าย</div>
      </div>
      <div class="stat-card">
        <div class="number" id="mediumCount">-</div>
        <div class="label"><i class="bi bi-emoji-neutral me-1"></i>คำถามปานกลาง</div>
      </div>
      <div class="stat-card">
        <div class="number" id="hardCount">-</div>
        <div class="label"><i class="bi bi-emoji-frown me-1"></i>คำถามยาก</div>
      </div>
    </div>

    <!-- Question Form -->
    <div class="question-form fade-in">
      <h3 id="formTitle"><i class="bi bi-plus-circle me-2" style="color: #43a047;"></i>เพิ่มคำถามใหม่</h3>
      <form id="questionForm">
        <input type="hidden" id="questionId" value="">
        
        <div class="form-group">
          <label for="questionText" class="form-label">
            <i class="bi bi-question-circle me-1"></i>คำถาม *
          </label>
          <textarea id="questionText" name="questionText" class="form-control" placeholder="พิมพ์คำถามที่นี่..." required></textarea>
        </div>

        <div class="options-grid">
          <div class="form-group">
            <label class="form-label">ตัวเลือก A *</label>
            <div class="option-input">
              <input type="radio" name="correctAnswer" value="A" id="answerA" required>
              <input type="text" id="optionA" name="optionA" class="form-control" placeholder="ตัวเลือก A" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">ตัวเลือก B *</label>
            <div class="option-input">
              <input type="radio" name="correctAnswer" value="B" id="answerB">
              <input type="text" id="optionB" name="optionB" class="form-control" placeholder="ตัวเลือก B" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">ตัวเลือก C *</label>
            <div class="option-input">
              <input type="radio" name="correctAnswer" value="C" id="answerC">
              <input type="text" id="optionC" name="optionC" class="form-control" placeholder="ตัวเลือก C" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">ตัวเลือก D *</label>
            <div class="option-input">
              <input type="radio" name="correctAnswer" value="D" id="answerD">
              <input type="text" id="optionD" name="optionD" class="form-control" placeholder="ตัวเลือก D" required>
            </div>
          </div>
        </div>

        <p style="color: #66bb6a; font-size: 13px; margin: 10px 0;">
          <i class="bi bi-info-circle me-1"></i>* เลือกตัวเลือกที่เป็นคำตอบที่ถูกต้องโดยคลิกปุ่มวงกลม
        </p>

        <div class="form-row">
          <div class="form-group">
            <label for="difficulty" class="form-label">
              <i class="bi bi-speedometer2 me-1"></i>ระดับความยาก *
            </label>
            <select id="difficulty" name="difficulty" class="form-select" required>
              <option value="">-- เลือกระดับ --</option>
              <option value="easy">ง่าย (10 วินาที)</option>
              <option value="medium">ปานกลาง (15 วินาที)</option>
              <option value="hard">ยาก (20 วินาที)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="timeLimit" class="form-label">
              <i class="bi bi-stopwatch me-1"></i>เวลาตอบ (วินาที) *
            </label>
            <select id="timeLimit" name="timeLimit" class="form-select" required>
              <option value="">-- เลือกเวลา --</option>
              <option value="10">10 วินาที</option>
              <option value="15">15 วินาที</option>
              <option value="20">20 วินาที</option>
              <option value="30">30 วินาที</option>
            </select>
          </div>
        </div>

        <div class="btn-group">
          <button type="submit" class="btn" id="submitBtn" style="background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); color: white; border: none; border-radius: 12px; padding: 10px 30px;">
            <i class="bi bi-save"></i> บันทึกคำถาม
          </button>
          <button type="button" class="btn btn-outline-success" id="cancelBtn" style="display: none; border-radius: 12px;">
            <i class="bi bi-x-circle"></i> ยกเลิก
          </button>
        </div>
      </form>
    </div>

    <!-- Questions List -->
    <h2 class="fade-in" style="color: #1b5e20; font-weight: 700; margin-bottom: 20px;">
      <i class="bi bi-list-ul me-2" style="color: #43a047;"></i>รายการคำถาม
    </h2>
    
    <div class="filter-group">
      <select id="filterDifficulty" class="form-select" style="flex: 1 1 200px;">
        <option value="">ทุกระดับ</option>
        <option value="easy">ง่าย</option>
        <option value="medium">ปานกลาง</option>
        <option value="hard">ยาก</option>
      </select>
      <select id="filterStatus" class="form-select" style="flex: 1 1 200px;">
        <option value="">ทุกสถานะ</option>
        <option value="active">เปิดใช้งาน</option>
        <option value="inactive">ปิดใช้งาน</option>
      </select>
    </div>

    <div class="search-box">
      <input type="text" id="searchInput" class="form-control" placeholder="🔍 ค้นหาคำถาม...">
    </div>

    <div class="card fade-in">
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th style="width: 50px;">#</th>
              <th>คำถาม</th>
              <th style="width: 100px;">ระดับ</th>
              <th style="width: 80px;">เวลา</th>
              <th style="width: 80px;">สถานะ</th>
              <th style="width: 150px;">จัดการ</th>
            </tr>
          </thead>
          <tbody id="questionsList">
            <tr>
              <td colspan="6" style="text-align: center; padding: 30px;">กำลังโหลด...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    let questions = [];
    let editingId = null;

    // Load questions on page load
    document.addEventListener('DOMContentLoaded', () => {
      loadQuestions();
      loadStats();
    });

    // Load questions from API
    async function loadQuestions() {
      try {
        const response = await fetch('/coopgame/admin/api/questions');
        const result = await response.json();
        
        if (result.success) {
          questions = result.data || [];
          renderQuestions();
        } else {
          console.error('Error loading questions:', result.message);
        }
      } catch (error) {
        console.error('Error:', error);
      }
    }

    // Load statistics
    async function loadStats() {
      try {
        const response = await fetch('/coopgame/admin/api/stats');
        const result = await response.json();
        
        if (result.success && result.data) {
          document.getElementById('totalQuestions').textContent = result.data.totalQuestions || 0;
          document.getElementById('easyCount').textContent = result.data.easyQuestions || 0;
          document.getElementById('mediumCount').textContent = result.data.mediumQuestions || 0;
          document.getElementById('hardCount').textContent = result.data.hardQuestions || 0;
        }
      } catch (error) {
        console.error('Error loading stats:', error);
      }
    }

    // Render questions table
    function renderQuestions() {
      const tbody = document.getElementById('questionsList');
      const filterDiff = document.getElementById('filterDifficulty').value;
      const filterStat = document.getElementById('filterStatus').value;
      const searchTerm = document.getElementById('searchInput').value.toLowerCase();

      let filtered = questions.filter(q => {
        if (filterDiff && q.difficulty !== filterDiff) return false;
        if (filterStat === 'active' && !q.is_active) return false;
        if (filterStat === 'inactive' && q.is_active) return false;
        if (searchTerm && !q.question_text.toLowerCase().includes(searchTerm)) return false;
        return true;
      });

      if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; padding: 30px;">ไม่พบคำถาม</td></tr>';
        return;
      }

      tbody.innerHTML = filtered.map((q, index) => `
        <tr>
          <td>${index + 1}</td>
          <td>
            <strong>${escapeHtml(q.question_text.substring(0, 80))}${q.question_text.length > 80 ? '...' : ''}</strong>
            <br><small style="color: #666;">A: ${escapeHtml(q.option_a)} | B: ${escapeHtml(q.option_b)} | C: ${escapeHtml(q.option_c)} | D: ${escapeHtml(q.option_d)}</small>
            <br><small style="color: #4CAF50;">✓ คำตอบ: ${q.correct_answer}</small>
          </td>
          <td><span class="difficulty-badge difficulty-${q.difficulty}">${getDifficultyText(q.difficulty)}</span></td>
          <td>${q.time_limit} วิ</td>
          <td>${q.is_active ? '<span style="color: green;">✓ เปิด</span>' : '<span style="color: red;">✗ ปิด</span>'}</td>
          <td>
            <div class="action-btns">
              <button class="btn btn-small btn-edit" onclick="editQuestion(${q.id})">✏️ แก้ไข</button>
              <button class="btn btn-small btn-delete" onclick="deleteQuestion(${q.id})">🗑️ ลบ</button>
            </div>
          </td>
        </tr>
      `).join('');
    }

    // Helper functions
    function escapeHtml(text) {
      if (!text) return '';
      return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function getDifficultyText(diff) {
      const texts = { easy: 'ง่าย', medium: 'ปานกลาง', hard: 'ยาก' };
      return texts[diff] || diff;
    }

    // Form submission
    document.getElementById('questionForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = {
        questionText: document.getElementById('questionText').value,
        optionA: document.getElementById('optionA').value,
        optionB: document.getElementById('optionB').value,
        optionC: document.getElementById('optionC').value,
        optionD: document.getElementById('optionD').value,
        correctAnswer: document.querySelector('input[name="correctAnswer"]:checked')?.value,
        difficulty: document.getElementById('difficulty').value,
        timeLimit: parseInt(document.getElementById('timeLimit').value)
      };

      if (!formData.correctAnswer) {
        alert('กรุณาเลือกคำตอบที่ถูกต้อง');
        return;
      }

      try {
        const url = editingId 
          ? `/coopgame/admin/api/questions/${editingId}`
          : '/coopgame/admin/api/questions';
        
        const method = editingId ? 'PUT' : 'POST';

        const response = await fetch(url, {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });

        const result = await response.json();

        if (result.success) {
          alert(editingId ? '✅ แก้ไขคำถามสำเร็จ!' : '✅ เพิ่มคำถามสำเร็จ!');
          resetForm();
          loadQuestions();
          loadStats();
        } else {
          alert('❌ ' + result.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    });

    // Edit question
    function editQuestion(id) {
      const q = questions.find(q => q.id === id);
      if (!q) return;

      editingId = id;
      document.getElementById('formTitle').textContent = '✏️ แก้ไขคำถาม';
      document.getElementById('submitBtn').textContent = '💾 บันทึกการแก้ไข';
      document.getElementById('cancelBtn').style.display = 'inline-block';
      
      document.getElementById('questionId').value = id;
      document.getElementById('questionText').value = q.question_text;
      document.getElementById('optionA').value = q.option_a;
      document.getElementById('optionB').value = q.option_b;
      document.getElementById('optionC').value = q.option_c;
      document.getElementById('optionD').value = q.option_d;
      document.getElementById('answer' + q.correct_answer).checked = true;
      document.getElementById('difficulty').value = q.difficulty;
      document.getElementById('timeLimit').value = q.time_limit;

      // Scroll to form
      document.querySelector('.question-form').scrollIntoView({ behavior: 'smooth' });
    }

    // Delete question
    async function deleteQuestion(id) {
      if (!confirm('⚠️ คุณแน่ใจหรือไม่ที่จะลบคำถามนี้?')) return;

      try {
        const response = await fetch(`/coopgame/admin/api/questions/${id}`, {
          method: 'DELETE'
        });

        const result = await response.json();

        if (result.success) {
          alert('✅ ลบคำถามสำเร็จ!');
          loadQuestions();
          loadStats();
        } else {
          alert('❌ ' + result.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    }

    // Reset form
    function resetForm() {
      editingId = null;
      document.getElementById('formTitle').textContent = '➕ เพิ่มคำถามใหม่';
      document.getElementById('submitBtn').textContent = '💾 บันทึกคำถาม';
      document.getElementById('cancelBtn').style.display = 'none';
      document.getElementById('questionForm').reset();
      document.querySelectorAll('input[name="correctAnswer"]').forEach(r => r.checked = false);
    }

    // Cancel button
    document.getElementById('cancelBtn').addEventListener('click', resetForm);

    // Filter and search
    document.getElementById('filterDifficulty').addEventListener('change', renderQuestions);
    document.getElementById('filterStatus').addEventListener('change', renderQuestions);
    document.getElementById('searchInput').addEventListener('input', renderQuestions);

    // Auto-set time limit based on difficulty
    document.getElementById('difficulty').addEventListener('change', (e) => {
      const timeSelect = document.getElementById('timeLimit');
      const times = { easy: '10', medium: '15', hard: '20' };
      if (times[e.target.value]) {
        timeSelect.value = times[e.target.value];
      }
    });
  </script>
</body>
</html>
