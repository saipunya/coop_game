<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>จัดการคำถาม - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700;800&display=swap');

    :root {
      --green-900: #1b5e20;
      --green-700: #2e7d32;
      --green-500: #43a047;
      --green-300: #81c784;
      --mint-50: #f5fbf4;
      --mint-100: #eaf5e8;
      --card: rgba(255, 255, 255, 0.96);
    }

    body {
      min-height: 100vh;
      font-family: 'Sarabun', -apple-system, BlinkMacSystemFont, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(67, 160, 71, 0.17), transparent 28%),
        radial-gradient(circle at top right, rgba(129, 199, 132, 0.16), transparent 24%),
        linear-gradient(135deg, #eef8ec 0%, #d7ecd6 50%, #b8dfb9 100%);
      color: var(--green-900);
    }

    .admin-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }

    .admin-header,
    .panel,
    .stat-card {
      background: var(--card);
      border: 1px solid rgba(129, 199, 132, 0.35);
      box-shadow: 0 16px 45px rgba(46, 125, 50, 0.08);
      backdrop-filter: blur(10px);
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
      padding: 20px 24px;
      border-radius: 22px;
    }

    .admin-header h1 {
      margin: 0;
      font-size: 1.9rem;
      font-weight: 800;
      background: linear-gradient(135deg, var(--green-700) 0%, var(--green-500) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .btn-group {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }

    .panel {
      border-radius: 22px;
      padding: 22px;
      margin-bottom: 24px;
    }

    .panel h3,
    .panel h2 {
      margin: 0 0 18px;
      color: var(--green-900);
      font-weight: 800;
    }

    .settings-grid,
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .form-group {
      margin-bottom: 14px;
    }

    .form-group label {
      display: block;
      margin-bottom: 6px;
      font-weight: 700;
      color: var(--green-700);
    }

    .form-control,
    .form-select {
      width: 100%;
      padding: 10px 14px;
      border: 2px solid #a5d6a7;
      border-radius: 12px;
      font-size: 14px;
      transition: all 0.25s ease;
      background: #fff;
    }

    .form-control:focus,
    .form-select:focus {
      border-color: var(--green-500);
      box-shadow: 0 0 0 4px rgba(67, 160, 71, 0.1);
      outline: none;
    }

    textarea.form-control {
      min-height: 90px;
      resize: vertical;
    }

    .option-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .option-input {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      background: var(--mint-100);
      border: 2px solid #dcedc8;
      border-radius: 14px;
    }

    .option-input input[type="radio"] {
      width: 18px;
      height: 18px;
      accent-color: var(--green-500);
    }

    .option-input input[type="text"] {
      flex: 1;
      border: none;
      background: transparent;
      padding: 4px 2px;
    }

    .option-input input[type="text"]:focus {
      outline: none;
    }

    .time-limit-display {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 46px;
      padding: 12px 16px;
      border-radius: 12px;
      background: #f1f8e9;
      border: 2px solid #a5d6a7;
      color: var(--green-900);
      font-weight: 800;
    }

    .distribution-preview {
      display: grid;
      gap: 10px;
    }

    .distribution-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      border-radius: 12px;
      background: #f8fcf7;
      border: 1px solid #dcedc8;
      color: var(--green-700);
      font-weight: 700;
    }

    .question-meta {
      color: #5f9f63;
      font-size: 13px;
      margin: 10px 0 0;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      margin-bottom: 24px;
    }

    .stat-card {
      border-radius: 20px;
      padding: 20px;
      text-align: center;
      transition: transform 0.25s ease;
    }

    .stat-card:hover {
      transform: translateY(-3px);
    }

    .stat-number {
      font-size: 2.2rem;
      line-height: 1;
      font-weight: 800;
      margin: 0;
      background: linear-gradient(135deg, var(--green-700) 0%, var(--green-500) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .stat-label {
      margin-top: 8px;
      color: var(--green-700);
      font-weight: 700;
    }

    .table {
      color: var(--green-700);
    }

    .table thead th {
      background: linear-gradient(135deg, #edf7ec 0%, #f8fcf6 100%);
      color: var(--green-900);
      font-weight: 800;
      border-bottom: 2px solid #d8ead8;
      padding: 12px;
    }

    .table tbody td {
      padding: 12px;
      border-bottom: 1px solid #edf4ed;
      vertical-align: middle;
    }

    .table tbody tr:hover {
      background: rgba(200, 230, 201, 0.25);
    }

    .difficulty-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 0.9rem;
      font-weight: 700;
    }

    .difficulty-easy {
      background: #e8f5e9;
      color: #1b5e20;
      border: 1px solid #a5d6a7;
    }

    .difficulty-medium {
      background: #fff8e1;
      color: #f57f17;
      border: 1px solid #ffe082;
    }

    .difficulty-hard {
      background: #ffebee;
      color: #c62828;
      border: 1px solid #ef9a9a;
    }

    .action-btns {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .status-switch {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-width: 86px;
      margin: 0;
      color: var(--green-700);
      font-weight: 700;
    }

    .status-switch .form-check-input {
      cursor: pointer;
      margin-top: 0;
      width: 42px;
      height: 22px;
    }

    .status-switch .form-check-input:checked {
      background-color: var(--green-500);
      border-color: var(--green-500);
    }

    .btn-sm {
      padding: 8px 12px;
      font-size: 13px;
      border-radius: 10px;
    }

    .empty-state,
    .loading {
      text-align: center;
      padding: 34px 16px;
      color: #63a668;
      font-weight: 700;
    }

    .fade-in {
      animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 1024px) {
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .admin-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .btn-group {
        width: 100%;
      }

      .btn-group .btn {
        flex: 1 1 160px;
      }

      .settings-grid,
      .form-row,
      .option-grid {
        grid-template-columns: 1fr;
      }

      .card-title-inline {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 480px) {
      .admin-container {
        padding: 12px;
      }

      .stats-grid {
        grid-template-columns: 1fr;
      }

      .admin-header {
        padding: 16px;
      }

      .admin-header h1 {
        font-size: 1.45rem;
      }

      .btn-group {
        flex-direction: column;
      }

      .btn-group .btn {
        width: 100%;
      }

      .panel {
        padding: 16px;
      }

      .form-control,
      .form-select,
      textarea {
        font-size: 16px;
      }

      .table {
        display: block;
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      .table th,
      .table td {
        white-space: nowrap;
      }

      .action-btns {
        flex-direction: column;
      }

      .action-btns .btn {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <header class="admin-header fade-in">
      <h1><i class="bi bi-card-checklist me-2"></i>จัดการคำถาม</h1>
      <div class="btn-group">
        <a href="/coopgame/admin/" class="btn btn-outline-success">
          <i class="bi bi-speedometer2"></i> แดชบอร์ด
        </a>
        <a href="/coopgame/admin/codes" class="btn btn-outline-success">
          <i class="bi bi-ticket-perforated"></i> จัดการรหัส
        </a>
        <a href="/coopgame/game/start" class="btn" style="background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); color: white; border: none;">
          <i class="bi bi-controller"></i> เล่นเกม
        </a>
        <span style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
          <span style="font-weight:600; color:#2e7d32;"><i class="bi bi-person-circle"></i> <%= adminUser.username %></span>
          <a href="/coopgame/admin/logout" class="btn btn-outline-success">
            <i class="bi bi-box-arrow-right"></i> ออกจากระบบ
          </a>
        </span>
      </div>
    </header>

    <section class="panel fade-in">
      <h3><i class="bi bi-sliders me-2" style="color:#43a047;"></i>ตั้งค่าเกมและเวลาในการตอบ</h3>
      <form id="gameSettingsForm">
        <div class="settings-grid">
          <div class="form-group">
            <label for="gameEnabledSwitch"><i class="bi bi-power me-1"></i>สถานะระบบเกม</label>
            <div class="form-check form-switch status-switch" style="min-height:46px;">
              <input class="form-check-input" type="checkbox" role="switch" id="gameEnabledSwitch" checked>
              <label class="form-check-label" for="gameEnabledSwitch" id="gameEnabledLabel">เปิดให้เล่น</label>
            </div>
          </div>
          <div class="form-group">
            <label for="gameTotalQuestions"><i class="bi bi-list-ol me-1"></i>จำนวนข้อสอบทั้งหมด</label>
            <input type="number" id="gameTotalQuestions" name="totalQuestions" class="form-control" min="1" max="100" step="1" required>
          </div>
        </div>
        <div class="settings-grid">
          <div class="form-group">
            <label><i class="bi bi-diagram-3 me-1"></i>ตัวอย่างจำนวนข้อจากสัดส่วน</label>
            <div id="distributionPreview" class="distribution-preview"></div>
          </div>
        </div>
        <div class="settings-grid">
          <div class="form-group">
            <label for="easyQuestionRatio"><i class="bi bi-emoji-smile me-1"></i>สัดส่วนคำถามง่าย (%)</label>
            <input type="number" id="easyQuestionRatio" class="form-control difficulty-ratio-input" min="0" max="100" step="1" data-difficulty="easy" required>
          </div>
          <div class="form-group">
            <label for="mediumQuestionRatio"><i class="bi bi-emoji-neutral me-1"></i>สัดส่วนคำถามปานกลาง (%)</label>
            <input type="number" id="mediumQuestionRatio" class="form-control difficulty-ratio-input" min="0" max="100" step="1" data-difficulty="medium" required>
          </div>
          <div class="form-group">
            <label for="hardQuestionRatio"><i class="bi bi-emoji-frown me-1"></i>สัดส่วนคำถามยาก (%)</label>
            <input type="number" id="hardQuestionRatio" class="form-control difficulty-ratio-input" min="0" max="100" step="1" data-difficulty="hard" required>
          </div>
          <div class="form-group">
            <label><i class="bi bi-percent me-1"></i>รวมสัดส่วน</label>
            <div id="distributionTotalPreview" class="time-limit-display">100%</div>
          </div>
        </div>
        <div class="settings-grid">
          <div class="form-group">
            <label for="easyTimeLimit"><i class="bi bi-emoji-smile me-1"></i>เวลาตอบคำถามง่าย (วินาที)</label>
            <input type="number" id="easyTimeLimit" class="form-control difficulty-time-input" min="5" max="300" step="1" data-difficulty="easy" required>
          </div>
          <div class="form-group">
            <label for="mediumTimeLimit"><i class="bi bi-emoji-neutral me-1"></i>เวลาตอบคำถามปานกลาง (วินาที)</label>
            <input type="number" id="mediumTimeLimit" class="form-control difficulty-time-input" min="5" max="300" step="1" data-difficulty="medium" required>
          </div>
          <div class="form-group">
            <label for="hardTimeLimit"><i class="bi bi-emoji-frown me-1"></i>เวลาตอบคำถามยาก (วินาที)</label>
            <input type="number" id="hardTimeLimit" class="form-control difficulty-time-input" min="5" max="300" step="1" data-difficulty="hard" required>
          </div>
          <div class="form-group">
            <label><i class="bi bi-stopwatch me-1"></i>เวลาที่จะใช้กับคำถามใหม่/เดิม</label>
            <div id="timeSettingsPreview" class="distribution-preview"></div>
          </div>
        </div>
        <div class="btn-group">
          <button type="submit" class="btn" style="background: linear-gradient(135deg, #2e7d32 0%, #43a047 100%); color: white; border: none;">
            <i class="bi bi-save"></i> บันทึกการตั้งค่า
          </button>
        </div>
      </form>
    </section>

    <section class="panel fade-in">
      <h3><i class="bi bi-cloud-arrow-up me-2" style="color:#43a047;"></i>นำเข้าคำถาม</h3>
      <p style="margin-bottom: 12px; color:#4f8d52; font-weight:600;">
        วางข้อความในช่องด้านล่างหรืออัปโหลดไฟล์ <code>.docx</code> ใช้ตัวเลือกได้ทั้ง <code>ก ข ค ง</code> หรือ <code>A B C D</code> และใช้รูปแบบนี้:
      </p>
      <pre style="background:#f6fbf5; border:1px solid #d7ead6; border-radius:14px; padding:14px; overflow:auto; color:#2f6f34; font-size:13px; line-height:1.7; margin-bottom: 16px;">ข้อ 1
คำถาม: สหกรณ์คืออะไร?
ตัวเลือก ก: กลุ่มการค้า
ตัวเลือก ข: องค์กรทางเศรษฐกิจ
ตัวเลือก ค: บริษัทเอกชน
ตัวเลือก ง: หน่วยงานราชการ
คำตอบ: ข
ระดับ: easy</pre>
      <form id="importTextForm">
        <div class="form-group">
          <label for="importText"><i class="bi bi-clipboard-plus me-1"></i>วางข้อความคำถามที่ต้องการนำเข้า</label>
          <textarea
            id="importText"
            name="importText"
            class="form-control"
            placeholder="วางคำถามหลายข้อได้เลย เช่น&#10;&#10;ข้อ 1&#10;คำถาม: ...&#10;ตัวเลือก ก: ...&#10;ตัวเลือก ข: ...&#10;ตัวเลือก ค: ...&#10;ตัวเลือก ง: ...&#10;คำตอบ: ก&#10;ระดับ: easy"
            style="min-height: 220px;"
          ></textarea>
        </div>
        <div class="btn-group" style="margin-bottom: 18px;">
          <button type="submit" class="btn" style="background: linear-gradient(135deg, #1b5e20 0%, #43a047 100%); color: white; border: none;">
            <i class="bi bi-clipboard-check"></i> นำเข้าจากข้อความ
          </button>
          <button type="button" class="btn btn-outline-success" id="clearImportTextBtn">
            <i class="bi bi-eraser"></i> ล้างข้อความ
          </button>
        </div>
        <div id="importTextStatus" style="margin: -6px 0 18px; color:#4f8d52; font-weight:600;"></div>
      </form>

      <form id="importDocxForm">
        <div class="form-row">
          <div class="form-group">
            <label for="docxFile"><i class="bi bi-upload me-1"></i>เลือกไฟล์ Word (.docx)</label>
            <input
              type="file"
              id="docxFile"
              name="file"
              class="form-control"
              accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
              required
            >
          </div>
          <div class="form-group">
            <label>&nbsp;</label>
            <div class="btn-group">
              <button type="submit" class="btn" style="background: linear-gradient(135deg, #1b5e20 0%, #43a047 100%); color: white; border: none;">
                <i class="bi bi-cloud-arrow-up"></i> นำเข้าคำถาม
              </button>
              <button type="button" class="btn btn-outline-success" id="downloadImportTemplateBtn">
                <i class="bi bi-info-circle"></i> ดูตัวอย่างรูปแบบ
              </button>
            </div>
          </div>
        </div>
        <div id="importStatus" style="margin-top: 10px; color:#4f8d52; font-weight:600;"></div>
      </form>
    </section>

    <div class="stats-grid fade-in">
      <div class="stat-card">
        <div class="stat-number" id="totalQuestions">-</div>
        <div class="stat-label"><i class="bi bi-card-text me-1"></i>คำถามทั้งหมด</div>
      </div>
      <div class="stat-card">
        <div class="stat-number" id="easyCount">-</div>
        <div class="stat-label"><i class="bi bi-emoji-smile me-1"></i>คำถามง่าย</div>
      </div>
      <div class="stat-card">
        <div class="stat-number" id="mediumCount">-</div>
        <div class="stat-label"><i class="bi bi-emoji-neutral me-1"></i>คำถามปานกลาง</div>
      </div>
      <div class="stat-card">
        <div class="stat-number" id="hardCount">-</div>
        <div class="stat-label"><i class="bi bi-emoji-frown me-1"></i>คำถามยาก</div>
      </div>
    </div>

    <section class="panel fade-in">
      <h3 id="formTitle"><i class="bi bi-plus-circle me-2" style="color:#43a047;"></i>เพิ่มคำถามใหม่</h3>
      <form id="questionForm">
        <input type="hidden" id="questionId" value="">

        <div class="form-group">
          <label for="questionText"><i class="bi bi-question-circle me-1"></i>คำถาม</label>
          <textarea id="questionText" name="questionText" class="form-control" placeholder="พิมพ์คำถามที่นี่..." required></textarea>
        </div>

        <div class="option-grid">
          <div class="form-group">
            <label>ตัวเลือก ก</label>
            <div class="option-input">
              <input type="radio" name="correctAnswer" value="A" id="answerA" required>
              <input type="text" id="optionA" name="optionA" class="form-control" placeholder="ตัวเลือก ก" required>
            </div>
          </div>
          <div class="form-group">
            <label>ตัวเลือก ข</label>
            <div class="option-input">
              <input type="radio" name="correctAnswer" value="B" id="answerB">
              <input type="text" id="optionB" name="optionB" class="form-control" placeholder="ตัวเลือก ข" required>
            </div>
          </div>
          <div class="form-group">
            <label>ตัวเลือก ค</label>
            <div class="option-input">
              <input type="radio" name="correctAnswer" value="C" id="answerC">
              <input type="text" id="optionC" name="optionC" class="form-control" placeholder="ตัวเลือก ค" required>
            </div>
          </div>
          <div class="form-group">
            <label>ตัวเลือก ง</label>
            <div class="option-input">
              <input type="radio" name="correctAnswer" value="D" id="answerD">
              <input type="text" id="optionD" name="optionD" class="form-control" placeholder="ตัวเลือก ง" required>
            </div>
          </div>
        </div>

        <p class="question-meta">
          <i class="bi bi-info-circle me-1"></i>เลือกปุ่มวงกลมของตัวเลือกที่ถูกต้อง (ก ข ค ง)
        </p>

        <div class="form-row">
          <div class="form-group">
            <label for="difficulty"><i class="bi bi-speedometer2 me-1"></i>ระดับความยาก</label>
            <select id="difficulty" name="difficulty" class="form-select" required>
              <option value="">-- เลือกระดับ --</option>
              <option value="easy">ง่าย</option>
              <option value="medium">ปานกลาง</option>
              <option value="hard">ยาก</option>
            </select>
          </div>
          <div class="form-group">
            <label><i class="bi bi-stopwatch me-1"></i>เวลาตอบตามระดับ</label>
            <div id="timeLimitDisplay" class="time-limit-display">15 วินาที</div>
            <input type="hidden" id="timeLimit" name="timeLimit" value="15">
          </div>
        </div>

        <div class="btn-group">
          <button type="submit" class="btn" id="submitBtn" style="background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%); color: white; border: none;">
            <i class="bi bi-save"></i> บันทึกคำถาม
          </button>
          <button type="button" class="btn btn-outline-success" id="cancelBtn" style="display: none;">
            <i class="bi bi-x-circle"></i> ยกเลิก
          </button>
        </div>
      </form>
    </section>

    <h2 class="fade-in" style="font-weight:800; color:var(--green-900); margin-bottom: 16px;">
      <i class="bi bi-list-ul me-2" style="color:#43a047;"></i>รายการคำถาม
    </h2>

    <div class="btn-group fade-in" style="margin-bottom: 16px;">
      <select id="filterDifficulty" class="form-select" style="max-width: 200px;">
        <option value="">ทุกระดับ</option>
        <option value="easy">ง่าย</option>
        <option value="medium">ปานกลาง</option>
        <option value="hard">ยาก</option>
      </select>
      <select id="filterStatus" class="form-select" style="max-width: 200px;">
        <option value="">ทุกสถานะ</option>
        <option value="active">เปิดใช้งาน</option>
        <option value="inactive">ปิดใช้งาน</option>
      </select>
    </div>

    <div class="form-group fade-in">
      <input type="text" id="searchInput" class="form-control" placeholder="ค้นหาคำถาม...">
    </div>

    <section class="panel fade-in">
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th style="width: 50px;">#</th>
              <th>คำถาม</th>
              <th style="width: 110px;">ระดับ</th>
              <th style="width: 90px;">เวลา</th>
              <th style="width: 90px;">สถานะ</th>
              <th style="width: 150px;">จัดการ</th>
            </tr>
          </thead>
          <tbody id="questionsList">
            <tr>
              <td colspan="6" class="loading">กำลังโหลด...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let questions = [];
    let editingId = null;
    let gameSettings = {
      gameEnabled: true,
      totalQuestions: 9,
      timeLimits: {
        easy: 15,
        medium: 20,
        hard: 25
      },
      questionDistribution: {
        easy: 30,
        medium: 35,
        hard: 35
      }
    };

    const DEFAULT_DIFFICULTY_TIME_LIMITS = {
      easy: 15,
      medium: 20,
      hard: 25
    };

    const DEFAULT_QUESTION_DISTRIBUTION = {
      easy: 30,
      medium: 35,
      hard: 35
    };

    document.addEventListener('DOMContentLoaded', () => {
      setGameEnabledSwitch(gameSettings.gameEnabled);
      setTimeLimitInputs(gameSettings.timeLimits);
      setDistributionInputs(gameSettings.questionDistribution);
      renderTimeSettingsPreview();
      loadQuestions();
      loadStats();
      loadGameSettings();
      updateQuestionTimeLimit(document.getElementById('difficulty').value || 'easy');
    });

    async function loadQuestions() {
      try {
        const response = await fetch('/coopgame/admin/api/questions');
        const result = await response.json();

        if (result.success) {
          questions = result.data || [];
          renderQuestions();
        } else {
          console.error('Error loading questions:', result.message);
        }
      } catch (error) {
        console.error('Error loading questions:', error);
      }
    }

    async function loadGameSettings() {
      try {
        const response = await fetch('/coopgame/admin/api/game-settings');
        const result = await response.json();

        if (result.success && result.data) {
          gameSettings.gameEnabled = result.data.gameEnabled !== false;
          gameSettings.totalQuestions = parseInt(result.data.totalQuestions, 10) || 9;
          gameSettings.timeLimits = normalizeTimeLimits(result.data.timeLimits);
          gameSettings.questionDistribution = normalizeQuestionDistribution(result.data.questionDistribution);
          document.getElementById('gameTotalQuestions').value = gameSettings.totalQuestions;
          setGameEnabledSwitch(gameSettings.gameEnabled);
          setTimeLimitInputs(gameSettings.timeLimits);
          setDistributionInputs(gameSettings.questionDistribution);
          renderDistributionPreview(gameSettings.totalQuestions);
          renderTimeSettingsPreview();
          updateQuestionTimeLimit(document.getElementById('difficulty').value || 'easy');
          renderQuestions();
        }
      } catch (error) {
        console.error('Error loading game settings:', error);
        setGameEnabledSwitch(gameSettings.gameEnabled);
        document.getElementById('gameTotalQuestions').value = gameSettings.totalQuestions;
        setTimeLimitInputs(gameSettings.timeLimits);
        setDistributionInputs(gameSettings.questionDistribution);
        renderDistributionPreview(gameSettings.totalQuestions);
        renderTimeSettingsPreview();
      }
    }

    async function loadStats() {
      try {
        const response = await fetch('/coopgame/admin/api/stats');
        const result = await response.json();

        if (result.success && result.data) {
          document.getElementById('totalQuestions').textContent = result.data.totalQuestions || 0;
          document.getElementById('easyCount').textContent = result.data.easyQuestions || 0;
          document.getElementById('mediumCount').textContent = result.data.mediumQuestions || 0;
          document.getElementById('hardCount').textContent = result.data.hardQuestions || 0;
        }
      } catch (error) {
        console.error('Error loading stats:', error);
      }
    }

    function buildDistribution(totalQuestions, questionDistribution = gameSettings.questionDistribution) {
      const normalizedDistribution = normalizeQuestionDistribution(questionDistribution);
      const ratios = [
        { key: 'easy', ratio: normalizedDistribution.easy / 100 },
        { key: 'medium', ratio: normalizedDistribution.medium / 100 },
        { key: 'hard', ratio: normalizedDistribution.hard / 100 }
      ];

      const baseCounts = ratios.map(item => Math.floor(totalQuestions * item.ratio));
      const fractions = ratios.map((item, index) => ({
        index,
        fraction: totalQuestions * item.ratio - baseCounts[index]
      }));

      let remainder = totalQuestions - baseCounts.reduce((sum, count) => sum + count, 0);

      fractions.sort((a, b) => {
        if (b.fraction !== a.fraction) return b.fraction - a.fraction;
        return a.index - b.index;
      });

      let cursor = 0;
      while (remainder > 0) {
        baseCounts[fractions[cursor % fractions.length].index] += 1;
        remainder -= 1;
        cursor += 1;
      }

      return {
        easy: baseCounts[0],
        medium: baseCounts[1],
        hard: baseCounts[2]
      };
    }

    function renderDistributionPreview(totalQuestions) {
      const preview = document.getElementById('distributionPreview');
      const totalPreview = document.getElementById('distributionTotalPreview');
      if (!preview) return;

      const questionDistribution = getDistributionFromInputs();
      const distributionTotal = Object.values(questionDistribution).reduce((sum, value) => (
        sum + (Number.isInteger(value) ? value : 0)
      ), 0);

      if (totalPreview) {
        totalPreview.textContent = `${distributionTotal}%`;
        totalPreview.style.color = distributionTotal === 100 ? 'var(--green-900)' : '#b42318';
        totalPreview.style.borderColor = distributionTotal === 100 ? '#a5d6a7' : '#f6b1ad';
        totalPreview.style.background = distributionTotal === 100 ? '#f1f8e9' : '#fff4f2';
      }

      if (!Number.isInteger(totalQuestions) || totalQuestions <= 0) {
        preview.innerHTML = '<div class="distribution-item"><span>กรุณากรอกจำนวนข้อ</span><span>-</span></div>';
        return;
      }

      if (distributionTotal !== 100) {
        preview.innerHTML = '<div class="distribution-item"><span>สัดส่วนรวมต้องเท่ากับ 100%</span><span>-</span></div>';
        return;
      }

      const distribution = buildDistribution(totalQuestions, questionDistribution);
      preview.innerHTML = `
        <div class="distribution-item"><span>ง่าย (${questionDistribution.easy}%)</span><span>${distribution.easy} ข้อ</span></div>
        <div class="distribution-item"><span>ปานกลาง (${questionDistribution.medium}%)</span><span>${distribution.medium} ข้อ</span></div>
        <div class="distribution-item"><span>ยาก (${questionDistribution.hard}%)</span><span>${distribution.hard} ข้อ</span></div>
      `;
    }

    function getTimeLimitByDifficulty(diff) {
      return gameSettings.timeLimits[diff] || DEFAULT_DIFFICULTY_TIME_LIMITS[diff] || DEFAULT_DIFFICULTY_TIME_LIMITS.easy;
    }

    function normalizeTimeLimits(timeLimits = {}) {
      return ['easy', 'medium', 'hard'].reduce((normalized, difficulty) => {
        const parsed = parseInt(timeLimits[difficulty], 10);
        normalized[difficulty] = Number.isInteger(parsed) && parsed >= 5 && parsed <= 300
          ? parsed
          : DEFAULT_DIFFICULTY_TIME_LIMITS[difficulty];
        return normalized;
      }, {});
    }

    function setTimeLimitInputs(timeLimits) {
      document.getElementById('easyTimeLimit').value = timeLimits.easy;
      document.getElementById('mediumTimeLimit').value = timeLimits.medium;
      document.getElementById('hardTimeLimit').value = timeLimits.hard;
    }

    function setGameEnabledSwitch(isEnabled) {
      const switchEl = document.getElementById('gameEnabledSwitch');
      const labelEl = document.getElementById('gameEnabledLabel');
      if (!switchEl || !labelEl) return;

      switchEl.checked = Boolean(isEnabled);
      labelEl.textContent = switchEl.checked ? 'เปิดให้เล่น' : 'ปิดระบบเกม';
      labelEl.style.color = switchEl.checked ? 'var(--green-700)' : '#b42318';
    }

    function normalizeQuestionDistribution(questionDistribution = {}) {
      const normalized = ['easy', 'medium', 'hard'].reduce((result, difficulty) => {
        const parsed = parseInt(questionDistribution[difficulty], 10);
        result[difficulty] = Number.isInteger(parsed) && parsed >= 0 && parsed <= 100
          ? parsed
          : DEFAULT_QUESTION_DISTRIBUTION[difficulty];
        return result;
      }, {});

      const total = normalized.easy + normalized.medium + normalized.hard;
      return total === 100 ? normalized : { ...DEFAULT_QUESTION_DISTRIBUTION };
    }

    function setDistributionInputs(questionDistribution) {
      document.getElementById('easyQuestionRatio').value = questionDistribution.easy;
      document.getElementById('mediumQuestionRatio').value = questionDistribution.medium;
      document.getElementById('hardQuestionRatio').value = questionDistribution.hard;
    }

    function getDistributionFromInputs() {
      return {
        easy: parseInt(document.getElementById('easyQuestionRatio').value, 10),
        medium: parseInt(document.getElementById('mediumQuestionRatio').value, 10),
        hard: parseInt(document.getElementById('hardQuestionRatio').value, 10)
      };
    }

    function getTimeLimitsFromInputs() {
      return {
        easy: parseInt(document.getElementById('easyTimeLimit').value, 10),
        medium: parseInt(document.getElementById('mediumTimeLimit').value, 10),
        hard: parseInt(document.getElementById('hardTimeLimit').value, 10)
      };
    }

    function renderTimeSettingsPreview() {
      const preview = document.getElementById('timeSettingsPreview');
      if (!preview) return;

      preview.innerHTML = `
        <div class="distribution-item"><span>ง่าย</span><span>${getTimeLimitByDifficulty('easy')} วินาที</span></div>
        <div class="distribution-item"><span>ปานกลาง</span><span>${getTimeLimitByDifficulty('medium')} วินาที</span></div>
        <div class="distribution-item"><span>ยาก</span><span>${getTimeLimitByDifficulty('hard')} วินาที</span></div>
      `;
    }

    function updateQuestionTimeLimit(difficulty) {
      const timeLimit = getTimeLimitByDifficulty(difficulty);
      const timeLimitDisplay = document.getElementById('timeLimitDisplay');
      const timeLimitInput = document.getElementById('timeLimit');

      if (timeLimitDisplay) {
        timeLimitDisplay.textContent = `${timeLimit} วินาที`;
      }
      if (timeLimitInput) {
        timeLimitInput.value = String(timeLimit);
      }
    }

    function getDifficultyText(diff) {
      const texts = { easy: 'ง่าย', medium: 'ปานกลาง', hard: 'ยาก' };
      return texts[diff] || diff;
    }

    function getAnswerLabel(answer) {
      const labels = { A: 'ก', B: 'ข', C: 'ค', D: 'ง' };
      return labels[String(answer || '').toUpperCase()] || answer || '-';
    }

    function renderQuestions() {
      const tbody = document.getElementById('questionsList');
      const filterDiff = document.getElementById('filterDifficulty').value;
      const filterStat = document.getElementById('filterStatus').value;
      const searchTerm = document.getElementById('searchInput').value.toLowerCase();

      const filtered = questions.filter(q => {
        if (filterDiff && q.difficulty !== filterDiff) return false;
        if (filterStat === 'active' && !q.is_active) return false;
        if (filterStat === 'inactive' && q.is_active) return false;
        if (searchTerm && !String(q.question_text || '').toLowerCase().includes(searchTerm)) return false;
        return true;
      });

      if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="empty-state">ไม่พบคำถาม</td></tr>';
        return;
      }

      tbody.innerHTML = filtered.map((q, index) => `
        <tr>
          <td>${index + 1}</td>
          <td>
            <strong>${escapeHtml((q.question_text || '').substring(0, 80))}${(q.question_text || '').length > 80 ? '...' : ''}</strong>
            <br><small style="color:#666;">ก: ${escapeHtml(q.option_a)} | ข: ${escapeHtml(q.option_b)} | ค: ${escapeHtml(q.option_c)} | ง: ${escapeHtml(q.option_d)}</small>
            <br><small style="color:#4CAF50;">✓ คำตอบ: ${getAnswerLabel(q.correct_answer)}</small>
          </td>
          <td><span class="difficulty-badge difficulty-${q.difficulty}">${getDifficultyText(q.difficulty)}</span></td>
          <td>${getTimeLimitByDifficulty(q.difficulty)} วินาที</td>
          <td>
            <div class="form-check form-switch status-switch">
              <input class="form-check-input" type="checkbox" role="switch" id="statusSwitch${q.id}" ${q.is_active ? 'checked' : ''} onchange="toggleQuestionStatus(${q.id}, this)">
              <label class="form-check-label" for="statusSwitch${q.id}">${q.is_active ? 'เปิด' : 'ปิด'}</label>
            </div>
          </td>
          <td>
            <div class="action-btns">
              <button class="btn btn-sm btn-outline-primary" onclick="editQuestion(${q.id})">แก้ไข</button>
              <button class="btn btn-sm btn-outline-danger" onclick="deleteQuestion(${q.id})">ลบ</button>
            </div>
          </td>
        </tr>
      `).join('');
    }

    function escapeHtml(text) {
      if (!text) return '';
      return String(text)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    function buildQuestionPayload(question, overrides = {}) {
      return {
        questionText: question.question_text || '',
        optionA: question.option_a || '',
        optionB: question.option_b || '',
        optionC: question.option_c || '',
        optionD: question.option_d || '',
        correctAnswer: question.correct_answer,
        difficulty: question.difficulty,
        timeLimit: parseInt(question.time_limit, 10),
        ...overrides
      };
    }

    document.getElementById('gameSettingsForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const gameEnabled = document.getElementById('gameEnabledSwitch').checked;
      const totalQuestions = parseInt(document.getElementById('gameTotalQuestions').value, 10);
      const timeLimits = getTimeLimitsFromInputs();
      const questionDistribution = getDistributionFromInputs();
      if (!Number.isInteger(totalQuestions) || totalQuestions < 1 || totalQuestions > 100) {
        alert('กรุณากรอกจำนวนข้อสอบระหว่าง 1 ถึง 100');
        return;
      }
      if (Object.values(timeLimits).some(value => !Number.isInteger(value) || value < 5 || value > 300)) {
        alert('กรุณากรอกเวลาตอบระหว่าง 5 ถึง 300 วินาที');
        return;
      }
      if (Object.values(questionDistribution).some(value => !Number.isInteger(value) || value < 0 || value > 100)) {
        alert('กรุณากรอกสัดส่วนคำถามระหว่าง 0 ถึง 100');
        return;
      }
      if (questionDistribution.easy + questionDistribution.medium + questionDistribution.hard !== 100) {
        alert('สัดส่วนคำถามง่าย ปานกลาง และยาก ต้องรวมกันเท่ากับ 100%');
        return;
      }

      try {
        const response = await fetch('/coopgame/admin/api/game-settings', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ gameEnabled, totalQuestions, timeLimits, questionDistribution })
        });
        const result = await response.json();

        if (result.success) {
          gameSettings.gameEnabled = result.data?.gameEnabled !== false;
          gameSettings.totalQuestions = totalQuestions;
          gameSettings.timeLimits = normalizeTimeLimits(result.data?.timeLimits || timeLimits);
          gameSettings.questionDistribution = normalizeQuestionDistribution(result.data?.questionDistribution || questionDistribution);
          setGameEnabledSwitch(gameSettings.gameEnabled);
          setTimeLimitInputs(gameSettings.timeLimits);
          setDistributionInputs(gameSettings.questionDistribution);
          renderDistributionPreview(totalQuestions);
          renderTimeSettingsPreview();
          updateQuestionTimeLimit(document.getElementById('difficulty').value || 'easy');
          loadQuestions();
          alert('บันทึกการตั้งค่าสำเร็จ');
        } else {
          alert('❌ ' + result.message);
        }
      } catch (error) {
        console.error('Error saving game settings:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    });

    document.getElementById('questionForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = {
        questionText: document.getElementById('questionText').value,
        optionA: document.getElementById('optionA').value,
        optionB: document.getElementById('optionB').value,
        optionC: document.getElementById('optionC').value,
        optionD: document.getElementById('optionD').value,
        correctAnswer: document.querySelector('input[name="correctAnswer"]:checked')?.value,
        difficulty: document.getElementById('difficulty').value,
        timeLimit: parseInt(document.getElementById('timeLimit').value, 10)
      };

      if (!formData.correctAnswer) {
        alert('กรุณาเลือกคำตอบที่ถูกต้อง');
        return;
      }

      try {
        const url = editingId
          ? `/coopgame/admin/api/questions/${editingId}`
          : '/coopgame/admin/api/questions';
        const method = editingId ? 'PUT' : 'POST';

        const response = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });

        const result = await response.json();

        if (result.success) {
          const successMessage = editingId ? '✅ แก้ไขคำถามสำเร็จ' : '✅ เพิ่มคำถามสำเร็จ';
          resetForm();
          await loadQuestions();
          await loadStats();
          alert(successMessage);
        } else {
          alert('❌ ' + result.message);
        }
      } catch (error) {
        console.error('Error submitting question:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    });

    function editQuestion(id) {
      const q = questions.find(item => item.id === id);
      if (!q) return;

      editingId = id;
      document.getElementById('formTitle').innerHTML = '<i class="bi bi-pencil-square me-2" style="color:#43a047;"></i>แก้ไขคำถาม';
      document.getElementById('submitBtn').innerHTML = '<i class="bi bi-save"></i> บันทึกการแก้ไข';
      document.getElementById('cancelBtn').style.display = 'inline-block';

      document.getElementById('questionId').value = id;
      document.getElementById('questionText').value = q.question_text || '';
      document.getElementById('optionA').value = q.option_a || '';
      document.getElementById('optionB').value = q.option_b || '';
      document.getElementById('optionC').value = q.option_c || '';
      document.getElementById('optionD').value = q.option_d || '';
      const answer = document.getElementById(`answer${q.correct_answer}`);
      if (answer) answer.checked = true;
      document.getElementById('difficulty').value = q.difficulty || '';
      updateQuestionTimeLimit(q.difficulty || 'easy');

      document.querySelector('.panel').scrollIntoView({ behavior: 'smooth' });
    }

    async function toggleQuestionStatus(id, switchEl) {
      const q = questions.find(item => item.id === id);
      if (!q) return;

      const nextIsActive = switchEl ? switchEl.checked : !q.is_active;
      const actionText = nextIsActive ? 'เปิดใช้งาน' : 'ปิดใช้งาน';
      if (switchEl) switchEl.disabled = true;

      try {
        const response = await fetch(`/coopgame/admin/api/questions/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(buildQuestionPayload(q, { isActive: nextIsActive }))
        });

        const result = await response.json();
        if (result.success) {
          q.is_active = nextIsActive;
          renderQuestions();
          loadStats();
          alert(`✅ ${actionText}คำถามสำเร็จ`);
        } else {
          if (switchEl) switchEl.checked = !nextIsActive;
          alert('❌ ' + result.message);
        }
      } catch (error) {
        console.error('Error updating question status:', error);
        if (switchEl) switchEl.checked = !nextIsActive;
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      } finally {
        if (switchEl) switchEl.disabled = false;
      }
    }

    async function deleteQuestion(id) {
      if (!confirm('คุณแน่ใจหรือไม่ที่จะลบคำถามนี้ออกจากระบบถาวร? ประวัติเกมที่อ้างอิงคำถามนี้จะถูกลบตามไปด้วย')) return;

      try {
        const response = await fetch(`/coopgame/admin/api/questions/${id}`, {
          method: 'DELETE'
        });

        const result = await response.json();
        if (result.success) {
          alert('✅ ลบคำถามออกจากระบบถาวรสำเร็จ');
          loadQuestions();
          loadStats();
        } else {
          alert('❌ ' + result.message);
        }
      } catch (error) {
        console.error('Error deleting question:', error);
        alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
      }
    }

    function resetForm() {
      editingId = null;
      document.getElementById('formTitle').innerHTML = '<i class="bi bi-plus-circle me-2" style="color:#43a047;"></i>เพิ่มคำถามใหม่';
      document.getElementById('submitBtn').innerHTML = '<i class="bi bi-save"></i> บันทึกคำถาม';
      document.getElementById('cancelBtn').style.display = 'none';
      document.getElementById('questionForm').reset();
      document.querySelectorAll('input[name="correctAnswer"]').forEach(r => r.checked = false);
      updateQuestionTimeLimit('easy');
    }

    document.getElementById('cancelBtn').addEventListener('click', resetForm);
    document.getElementById('filterDifficulty').addEventListener('change', renderQuestions);
    document.getElementById('filterStatus').addEventListener('change', renderQuestions);
    document.getElementById('searchInput').addEventListener('input', renderQuestions);
    document.getElementById('difficulty').addEventListener('change', (e) => {
      updateQuestionTimeLimit(e.target.value || 'easy');
    });
    document.getElementById('gameTotalQuestions').addEventListener('input', (e) => {
      const value = parseInt(e.target.value, 10);
      renderDistributionPreview(Number.isInteger(value) && value > 0 ? value : 0);
    });
    document.getElementById('gameEnabledSwitch').addEventListener('change', (e) => {
      setGameEnabledSwitch(e.target.checked);
    });
    document.querySelectorAll('.difficulty-ratio-input').forEach(input => {
      input.addEventListener('input', () => {
        const draftDistribution = getDistributionFromInputs();
        if (Object.values(draftDistribution).every(value => Number.isInteger(value) && value >= 0 && value <= 100)) {
          const total = draftDistribution.easy + draftDistribution.medium + draftDistribution.hard;
          if (total === 100) {
            gameSettings.questionDistribution = draftDistribution;
          }
        }
        const totalQuestions = parseInt(document.getElementById('gameTotalQuestions').value, 10);
        renderDistributionPreview(Number.isInteger(totalQuestions) && totalQuestions > 0 ? totalQuestions : 0);
      });
    });
    document.querySelectorAll('.difficulty-time-input').forEach(input => {
      input.addEventListener('input', () => {
        const draftTimeLimits = getTimeLimitsFromInputs();
        if (Object.values(draftTimeLimits).every(value => Number.isInteger(value) && value >= 5 && value <= 300)) {
          gameSettings.timeLimits = draftTimeLimits;
          renderTimeSettingsPreview();
          updateQuestionTimeLimit(document.getElementById('difficulty').value || 'easy');
          renderQuestions();
        }
      });
    });

    function setImportStatus(message, isError = false, targetId = 'importStatus') {
      const statusEl = document.getElementById(targetId);
      if (!statusEl) return;
      statusEl.textContent = message || '';
      statusEl.style.color = isError ? '#b42318' : '#2f6f34';
    }

    document.getElementById('downloadImportTemplateBtn').addEventListener('click', () => {
      const preview = document.querySelector('pre');
      if (preview) {
        preview.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      alert('ให้ใช้รูปแบบตามตัวอย่างในกล่อง Word ด้านบน โดยใช้ตัวเลือก ก ข ค ง หรือ A B C D');
    });

    document.getElementById('clearImportTextBtn').addEventListener('click', () => {
      document.getElementById('importText').value = '';
      setImportStatus('', false, 'importTextStatus');
    });

    document.getElementById('importTextForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const importTextEl = document.getElementById('importText');
      const importText = importTextEl.value.trim();

      if (!importText) {
        alert('กรุณาวางข้อความคำถามก่อนนำเข้า');
        importTextEl.focus();
        return;
      }

      try {
        setImportStatus('กำลังนำเข้าคำถามจากข้อความ...', false, 'importTextStatus');

        const response = await fetch('/coopgame/admin/api/questions/import-text', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ importText })
        });

        const result = await response.json();

        if (result.success) {
          setImportStatus(`นำเข้าคำถามสำเร็จ ${result.data.importedCount} ข้อ`, false, 'importTextStatus');
          importTextEl.value = '';
          await loadQuestions();
          await loadStats();
          alert(`นำเข้าคำถามสำเร็จ ${result.data.importedCount} ข้อ`);
        } else {
          const errorText = (result.errors && result.errors.length > 0)
            ? result.errors.map(item => item.msg || item).join('\n')
            : result.message || 'ไม่สามารถนำเข้าคำถามได้';
          setImportStatus(errorText, true, 'importTextStatus');
          alert(errorText);
        }
      } catch (error) {
        console.error('Error importing text:', error);
        setImportStatus('ไม่สามารถนำเข้าคำถามจากข้อความได้', true, 'importTextStatus');
        alert('ไม่สามารถนำเข้าคำถามจากข้อความได้');
      }
    });

    document.getElementById('importDocxForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const fileInput = document.getElementById('docxFile');
      const file = fileInput.files[0];

      if (!file) {
        alert('กรุณาเลือกไฟล์ .docx');
        return;
      }

      const formData = new FormData();
      formData.append('file', file);

      try {
        setImportStatus('กำลังนำเข้าคำถามจากไฟล์ Word...');

        const response = await fetch('/coopgame/admin/api/questions/import-docx', {
          method: 'POST',
          body: formData
        });

        const result = await response.json();

        if (result.success) {
          setImportStatus(`นำเข้าคำถามสำเร็จ ${result.data.importedCount} ข้อ`);
          fileInput.value = '';
          await loadQuestions();
          await loadStats();
          alert(`นำเข้าคำถามสำเร็จ ${result.data.importedCount} ข้อ`);
        } else {
          const errorText = (result.errors && result.errors.length > 0)
            ? result.errors.map(item => item.msg || item).join('\n')
            : result.message || 'ไม่สามารถนำเข้าคำถามได้';
          setImportStatus(errorText, true);
          alert(errorText);
        }
      } catch (error) {
        console.error('Error importing DOCX:', error);
        setImportStatus('ไม่สามารถนำเข้าคำถามจากไฟล์ Word ได้', true);
        alert('ไม่สามารถนำเข้าคำถามจากไฟล์ Word ได้');
      }
    });
  </script>
</body>
</html>
