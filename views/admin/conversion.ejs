<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body{font-family:Arial,Helvetica,sans-serif;background:#f6f8fb}
    .stat-card{border-radius:12px;padding:1rem}
    pre{white-space:pre-wrap}
  </style>
</head>
<body>
  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h4">Conversion Dashboard</h1>
      <div>Admin: <strong><%= adminUser %></strong></div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-md-3">
        <div class="card stat-card">
          <div class="small text-muted">Hero CTA</div>
          <div class="h3"><%= data.counts['click_cta_hero'] || 0 %></div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card stat-card">
          <div class="small text-muted">Nav CTA</div>
          <div class="h3"><%= data.counts['click_cta_nav'] || 0 %></div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card stat-card">
          <div class="small text-muted">System: Game</div>
          <div class="h3"><%= data.counts['click_cta_system_game'] || 0 %></div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card stat-card">
          <div class="small text-muted">Main CTA</div>
          <div class="h3"><%= data.counts['click_cta_main'] || 0 %></div>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-md-4">
        <div class="card p-3">
          <div class="small text-muted">Total Clicks</div>
          <div class="h3"><%= data.totalClicks || 0 %></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card p-3">
          <div class="small text-muted">Visitors</div>
          <div class="h3"><%= data.funnel.visitors || 0 %></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card p-3">
          <div class="small text-muted">Started Trial</div>
          <div class="h3"><%= data.funnel.started || 0 %></div>
        </div>
      </div>
    </div>

    <div class="card mb-3">
      <div class="card-body">
        <h5 class="card-title">Latest events</h5>
        <div class="table-responsive">
          <table class="table table-striped">
            <thead>
              <tr><th>Time</th><th>Event</th><th>Label</th><th>Page</th></tr>
            </thead>
            <tbody>
              <% (data.latest || []).forEach(e => { %>
                <tr>
                  <td><%= new Date(e.created_at).toLocaleString() %></td>
                  <td><%= e.event_name %></td>
                  <td><%= e.event_label %></td>
                  <td><%= e.page %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</body>
</html>
